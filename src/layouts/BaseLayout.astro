---
/**
 * BaseLayout.astro
 * ─────────────────────────────────────────────────────────────
 * Root layout with dynamic JSON-LD schema injection tailored
 * for a medical professional's website.
 *
 * Props:
 *   title        — Page title (required)
 *   description  — Meta description (defaults to site tagline)
 *   ogImage      — Open Graph image URL (optional)
 *   canonicalUrl — Canonical URL (optional, auto-generated)
 *   type         — Page type: 'website' | 'article' (default: 'website')
 *   publishedDate — ISO date string for articles
 *   modifiedDate  — ISO modified date for articles
 *   breadcrumbs  — Array of { name, url } for BreadcrumbList schema
 *   faqItems     — Array of { question, answer } for FAQPage schema
 *   directAnswer — 40-60 word summary for AEO Direct Answer Box
 */

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedDate?: string;
  modifiedDate?: string;
  breadcrumbs?: BreadcrumbItem[];
  faqItems?: FaqItem[];
  directAnswer?: string;
}

const {
  title,
  description = 'Dr. Tim — Functional Medicine | Evidence-based metabolic health, longevity, and wellness.',
  ogImage,
  canonicalUrl,
  type = 'website',
  publishedDate,
  modifiedDate,
  breadcrumbs = [],
  faqItems = [],
  directAnswer,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || 'https://drtim.co';
const siteName = import.meta.env.SITE_NAME || 'Dr. Tim';
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage || `${siteUrl}/og-default.jpg`;

// ── JSON-LD Schema Construction ──────────────────────────────

// 1. Person schema — Dr. Tim (physician/author) — GEO-enhanced
const personSchema = {
  '@type': ['Person', 'Physician'],
  '@id': `${siteUrl}/#person`,
  name: 'Dr. Tim',
  alternateName: ['หมอทิม', 'Dr. Tim Diet Clinic'],
  jobTitle: 'Medical Doctor',
  description: 'Functional Medicine physician specializing in metabolic health, longevity, and evidence-based wellness at Ultramed Clinic Chonburi, Thailand.',
  url: siteUrl,
  image: `${siteUrl}/images/about/drtim.png`,
  medicalSpecialty: 'Functional Medicine',
  knowsAbout: [
    'Functional Medicine',
    'Metabolic Health',
    'Diabetes Management',
    'Insulin Resistance',
    'Longevity Science',
    'Root-Cause Diagnosis',
    'Thyroid Health',
    'Nutrition Science',
  ],
  knowsLanguage: ['th', 'en'],
  qualification: [
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Medical Degree',
      name: 'MD',
    },
  ],
  affiliation: {
    '@type': 'MedicalClinic',
    '@id': `${siteUrl}/#clinic`,
    name: 'Ultramed Clinic Chonburi',
    url: siteUrl,
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Chonburi',
      addressCountry: 'TH',
    },
    geo: {
      '@type': 'GeoCoordinates',
      latitude: '13.3611',
      longitude: '100.9847',
    },
    medicalSpecialty: 'Functional Medicine',
  },
  sameAs: [
    'https://www.facebook.com/dr.timdietclinic/',
    'https://www.youtube.com/@dr.timdietclinic',
    'https://www.instagram.com/dr.timdietclinic/',
    'https://lin.ee/LwEtisp',
  ],
};

// 2. MedicalWebPage schema (for articles/medical content)
const medicalWebPageSchema = type === 'article' ? {
  '@type': 'MedicalWebPage',
  '@id': resolvedCanonical,
  url: resolvedCanonical,
  name: title,
  description: description,
  datePublished: publishedDate,
  dateModified: modifiedDate || publishedDate,
  author: { '@id': `${siteUrl}/#person` },
  publisher: {
    '@type': 'Organization',
    name: siteName,
    url: siteUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${siteUrl}/logo.png`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': resolvedCanonical,
  },
  image: resolvedOgImage,
  medicalAudience: {
    '@type': 'MedicalAudience',
    audienceType: 'Patient',
  },
} : null;

// 3. WebSite schema (for the homepage / general pages)
const webSiteSchema = type === 'website' ? {
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  url: siteUrl,
  name: siteName,
  description: description,
  publisher: { '@id': `${siteUrl}/#person` },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/?s={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
} : null;

// 4. BreadcrumbList schema
const breadcrumbSchema = breadcrumbs.length > 0 ? {
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.url,
  })),
} : null;

// 5. FAQPage schema
const faqSchema = faqItems.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
} : null;

// Assemble the full JSON-LD graph
const jsonLdGraph: Record<string, unknown>[] = [personSchema];
if (medicalWebPageSchema) jsonLdGraph.push(medicalWebPageSchema);
if (webSiteSchema) jsonLdGraph.push(webSiteSchema);
if (breadcrumbSchema) jsonLdGraph.push(breadcrumbSchema);
if (faqSchema) jsonLdGraph.push(faqSchema);

// Speakable schema — AEO for voice search & AI assistants
if (type === 'article') {
  jsonLdGraph.push({
    '@type': 'WebPage',
    '@id': `${resolvedCanonical}#speakable`,
    speakable: {
      '@type': 'SpeakableSpecification',
      cssSelector: ['.direct-answer-content', '.post-header h1', '.direct-answer-question'],
    },
    url: resolvedCanonical,
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': jsonLdGraph,
};
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta -->
    <title>{title} | {siteName}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Preconnect to WordPress for faster media loading -->
    <link rel="preconnect" href="https://drtim.co" />
    <link rel="dns-prefetch" href="https://drtim.co" />

    <!-- Open Graph -->
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={resolvedOgImage} />
    {publishedDate && <meta property="article:published_time" content={publishedDate} />}
    {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- GEO: AI Crawler Hints -->
    <link rel="author" href={`${siteUrl}/#person`} />
    <link rel="me" href="https://www.facebook.com/dr.timdietclinic/" />
    <meta name="author" content="Dr. Tim (หมอทิม)" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="ai-content-declaration" content="human-authored medical content reviewed by Dr. Tim (MD)" />
    <meta name="citation_author" content="Dr. Tim" />
    {type === 'article' && <meta name="citation_title" content={title} />}
    {publishedDate && <meta name="citation_publication_date" content={publishedDate} />}

    <!-- GEO: Local/Regional SEO -->
    <meta name="geo.region" content="TH-20" />
    <meta name="geo.placename" content="Chonburi, Thailand" />
    <meta name="ICBM" content="13.3611, 100.9847" />
    <meta name="content-language" content="th" />

    <!-- AI Discovery -->
    <link rel="llms" href="/llms.txt" type="text/plain" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts — Inter for premium readability -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  /* ── CSS Reset & Design Tokens ── */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* Color Palette — Medical / Trust / Clean */
    --color-bg: #fafbfd;
    --color-surface: #ffffff;
    --color-text: #1a1a2e;
    --color-text-muted: #6b7280;
    --color-primary: #0f766e;
    --color-primary-light: #14b8a6;
    --color-primary-dark: #0d5f58;
    --color-accent: #06b6d4;
    --color-accent-warm: #f59e0b;
    --color-border: #e5e7eb;
    --color-answer-bg: #f0fdfa;
    --color-answer-border: #99f6e4;

    /* Typography */
    --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
    --font-serif: 'Merriweather', Georgia, serif;
    --text-xs: clamp(0.7rem, 0.65rem + 0.25vw, 0.75rem);
    --text-sm: clamp(0.8rem, 0.75rem + 0.25vw, 0.875rem);
    --text-base: clamp(0.95rem, 0.9rem + 0.25vw, 1.0625rem);
    --text-lg: clamp(1.1rem, 1rem + 0.5vw, 1.25rem);
    --text-xl: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
    --text-2xl: clamp(1.5rem, 1.25rem + 1.25vw, 2rem);
    --text-3xl: clamp(1.875rem, 1.5rem + 1.875vw, 2.5rem);

    /* Spacing */
    --space-1: 0.25rem;
    --space-2: 0.5rem;
    --space-3: 0.75rem;
    --space-4: 1rem;
    --space-6: 1.5rem;
    --space-8: 2rem;
    --space-12: 3rem;
    --space-16: 4rem;

    /* Layout */
    --max-width: 72rem;
    --content-width: 48rem;
    --radius: 0.5rem;
    --radius-lg: 0.75rem;

    /* Shadows */
    --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
    --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);

    /* Transitions */
    --transition: 150ms ease;
  }

  html {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text);
    background: var(--color-bg);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100dvh;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color var(--transition);
  }

  a:hover {
    color: var(--color-primary-dark);
  }

  /* Prose — Article content styling */
  .prose {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: 1.8;
    max-width: var(--content-width);
  }

  .prose h1,
  .prose h2,
  .prose h3,
  .prose h4 {
    font-family: var(--font-sans);
    font-weight: 700;
    line-height: 1.3;
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .prose h1 { font-size: var(--text-3xl); }
  .prose h2 { font-size: var(--text-2xl); }
  .prose h3 { font-size: var(--text-xl); }
  .prose h4 { font-size: var(--text-lg); }

  .prose p {
    margin-bottom: var(--space-4);
  }

  .prose ul,
  .prose ol {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .prose li {
    margin-bottom: var(--space-2);
  }

  .prose blockquote {
    border-left: 4px solid var(--color-primary-light);
    padding: var(--space-4) var(--space-6);
    margin: var(--space-6) 0;
    background: var(--color-answer-bg);
    border-radius: 0 var(--radius) var(--radius) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .prose img {
    border-radius: var(--radius-lg);
    margin: var(--space-6) 0;
    box-shadow: var(--shadow-md);
  }

  .prose code {
    background: #f1f5f9;
    padding: 0.15em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: var(--space-4);
    border-radius: var(--radius);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .prose pre code {
    background: none;
    padding: 0;
    color: inherit;
  }
</style>
