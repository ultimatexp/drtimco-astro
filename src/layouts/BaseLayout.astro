---
/**
 * BaseLayout.astro
 * ─────────────────────────────────────────────────────────────
 * Root layout with dynamic JSON-LD schema injection tailored
 * for a medical professional's website.
 *
 * Props:
 *   title        — Page title (required)
 *   description  — Meta description (defaults to site tagline)
 *   ogImage      — Open Graph image URL (optional)
 *   canonicalUrl — Canonical URL (optional, auto-generated)
 *   type         — Page type: 'website' | 'article' (default: 'website')
 *   publishedDate — ISO date string for articles
 *   modifiedDate  — ISO modified date for articles
 *   breadcrumbs  — Array of { name, url } for BreadcrumbList schema
 *   faqItems     — Array of { question, answer } for FAQPage schema
 *   directAnswer — 40-60 word summary for AEO Direct Answer Box
 */

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  type?: "website" | "article";
  publishedDate?: string;
  modifiedDate?: string;
  breadcrumbs?: BreadcrumbItem[];
  faqItems?: FaqItem[];
  directAnswer?: string;
}

const {
  title,
  description = "Dr. Tim — Functional Medicine | Evidence-based metabolic health, longevity, and wellness.",
  ogImage,
  canonicalUrl,
  type = "website",
  publishedDate,
  modifiedDate,
  breadcrumbs = [],
  faqItems = [],
  directAnswer,
} = Astro.props;

const siteUrl = import.meta.env.SITE_URL || "https://drtim.co";
const siteName = import.meta.env.SITE_NAME || "Dr. Tim";
const resolvedCanonical =
  canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage || `${siteUrl}/og-default.jpg`;

// Avoid "<title>… | Dr. Tim | Dr. Tim" when pages already pass a branded title.
const trimmedTitle = title.trim();
const brandSuffixPattern = new RegExp(
  `\\|\\s*${siteName.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")}\\s*$`,
  "i",
);
const documentTitle = brandSuffixPattern.test(trimmedTitle)
  ? trimmedTitle
  : `${trimmedTitle} | ${siteName}`;

// ── JSON-LD Schema Construction ──────────────────────────────

// 1. Person schema — Dr. Tim (physician/author) — GEO-enhanced
const personSchema = {
  "@type": ["Person", "Physician"],
  "@id": `${siteUrl}/#person`,
  name: "Dr. Tim",
  alternateName: ["หมอทิม", "Dr. Tim Diet Clinic"],
  jobTitle: "Medical Doctor",
  description:
    "Functional Medicine physician specializing in metabolic health, longevity, and evidence-based wellness at Ultramed Clinic Chonburi, Thailand.",
  url: siteUrl,
  image: `${siteUrl}/images/about/drtim.png`,
  medicalSpecialty: "Functional Medicine",
  knowsAbout: [
    "Functional Medicine",
    "Metabolic Health",
    "Diabetes Management",
    "Insulin Resistance",
    "Longevity Science",
    "Root-Cause Diagnosis",
    "Thyroid Health",
    "Nutrition Science",
  ],
  knowsLanguage: ["th", "en"],
  qualification: [
    {
      "@type": "EducationalOccupationalCredential",
      credentialCategory: "Medical Degree",
      name: "MD",
    },
  ],
  affiliation: {
    "@type": "MedicalClinic",
    "@id": `${siteUrl}/#clinic`,
    name: "Ultramed Clinic Chonburi",
    url: siteUrl,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Chonburi",
      addressCountry: "TH",
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: "13.3611",
      longitude: "100.9847",
    },
    medicalSpecialty: "Functional Medicine",
  },
  sameAs: [
    "https://www.facebook.com/dr.timdietclinic/",
    "https://www.youtube.com/@dr.timdietclinic",
    "https://www.instagram.com/dr.timdietclinic/",
    "https://lin.ee/LwEtisp",
  ],
};

// 2. MedicalWebPage schema (for articles/medical content)
const medicalWebPageSchema =
  type === "article"
    ? {
        "@type": "MedicalWebPage",
        "@id": resolvedCanonical,
        url: resolvedCanonical,
        name: title,
        description: description,
        datePublished: publishedDate,
        dateModified: modifiedDate || publishedDate,
        author: { "@id": `${siteUrl}/#person` },
        publisher: {
          "@type": "Organization",
          name: siteName,
          url: siteUrl,
          logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/logo.png`,
          },
        },
        mainEntityOfPage: {
          "@type": "WebPage",
          "@id": resolvedCanonical,
        },
        image: resolvedOgImage,
        medicalAudience: {
          "@type": "MedicalAudience",
          audienceType: "Patient",
        },
      }
    : null;

// 3. WebSite schema (for the homepage / general pages)
const webSiteSchema =
  type === "website"
    ? {
        "@type": "WebSite",
        "@id": `${siteUrl}/#website`,
        url: siteUrl,
        name: siteName,
        description: description,
        publisher: { "@id": `${siteUrl}/#person` },
        potentialAction: {
          "@type": "SearchAction",
          target: `${siteUrl}/?s={search_term_string}`,
          "query-input": "required name=search_term_string",
        },
      }
    : null;

// 4. BreadcrumbList schema
const breadcrumbSchema =
  breadcrumbs.length > 0
    ? {
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: crumb.name,
          item: crumb.url,
        })),
      }
    : null;

// 5. FAQPage schema
const faqSchema =
  faqItems.length > 0
    ? {
        "@type": "FAQPage",
        mainEntity: faqItems.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : null;

// Assemble the full JSON-LD graph
const jsonLdGraph: Record<string, unknown>[] = [personSchema];
if (medicalWebPageSchema) jsonLdGraph.push(medicalWebPageSchema);
if (webSiteSchema) jsonLdGraph.push(webSiteSchema);
if (breadcrumbSchema) jsonLdGraph.push(breadcrumbSchema);
if (faqSchema) jsonLdGraph.push(faqSchema);

// AEO / GEO: expose the layout-level direct answer in structured data (CreativeWork.abstract)
if (type === "website" && directAnswer?.trim()) {
  jsonLdGraph.push({
    "@type": "WebPage",
    "@id": `${resolvedCanonical}#direct-answer`,
    url: resolvedCanonical,
    name: trimmedTitle,
    abstract: directAnswer.trim(),
    inLanguage: "th",
    isPartOf: { "@id": `${siteUrl}/#website` },
    author: { "@id": `${siteUrl}/#person` },
  });
}

// Speakable schema — AEO for voice search & AI assistants
if (type === "article") {
  jsonLdGraph.push({
    "@type": "WebPage",
    "@id": `${resolvedCanonical}#speakable`,
    speakable: {
      "@type": "SpeakableSpecification",
      cssSelector: [
        ".direct-answer-content",
        ".post-header h1",
        ".direct-answer-question",
      ],
    },
    url: resolvedCanonical,
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": jsonLdGraph,
};
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta -->
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- dns-prefetch for external domains -->
    <link rel="dns-prefetch" href="https://drtim.co" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://connect.facebook.net" />

    <!-- Open Graph -->
    <meta
      property="og:type"
      content={type === "article" ? "article" : "website"}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={resolvedOgImage} />
    {
      publishedDate && (
        <meta property="article:published_time" content={publishedDate} />
      )
    }
    {
      modifiedDate && (
        <meta property="article:modified_time" content={modifiedDate} />
      )
    }

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- GEO: AI Crawler Hints -->
    <link rel="author" href={`${siteUrl}/#person`} />
    <link rel="me" href="https://www.facebook.com/dr.timdietclinic/" />
    <meta name="author" content="Dr. Tim (หมอทิม)" />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta
      name="ai-content-declaration"
      content="human-authored medical content reviewed by Dr. Tim (MD)"
    />
    <meta name="citation_author" content="Dr. Tim" />
    {type === "article" && <meta name="citation_title" content={title} />}
    {
      publishedDate && (
        <meta name="citation_publication_date" content={publishedDate} />
      )
    }

    <!-- GEO: Local/Regional SEO -->
    <meta name="geo.region" content="TH-20" />
    <meta name="geo.placename" content="Chonburi, Thailand" />
    <meta name="ICBM" content="13.3611, 100.9847" />
    <meta name="content-language" content="th" />

    <!-- AI Discovery -->
    <link rel="llms" href="/llms.txt" type="text/plain" />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}
    ></script>

    <!-- Google Analytics (GA4) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-M9MK57VP71"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-M9MK57VP71");
      gtag("config", "GT-TX9CZ99");
    </script>

    <!-- Meta (Facebook) Pixel -->
    <script is:inline>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod
            ? n.callMethod.apply(n, arguments)
            : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = "2.0";
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(
        window,
        document,
        "script",
        "https://connect.facebook.net/en_US/fbevents.js"
      );
      fbq("init", "26085245234467647");
      fbq("track", "PageView");
    </script>

    <!-- Fonts — Non-render-blocking Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Merriweather:wght@400;700&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>

  <body>
    <!-- Facebook Pixel noscript fallback -->
    <noscript
      ><img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=26085245234467647&ev=PageView&noscript=1"
      />
    </noscript>

    <main id="main-content">
      <slot />
    </main>

    <!-- PDPA Cookie Consent Banner -->
    <div
      class="cookie-consent"
      id="cookieConsent"
      role="alert"
      aria-live="polite"
    >
      <div class="cookie-consent-inner">
        <div class="cookie-consent-text">
          <svg
            class="cookie-icon"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <circle cx="8" cy="9" r="1" fill="currentColor"></circle>
            <circle cx="15" cy="11" r="1" fill="currentColor"></circle>
            <circle cx="10" cy="15" r="1" fill="currentColor"></circle>
            <circle cx="14" cy="7" r="0.5" fill="currentColor"></circle>
            <circle cx="17" cy="14" r="0.5" fill="currentColor"></circle>
          </svg>
          <p>
            เว็บไซต์นี้ใช้คุกกี้เพื่อพัฒนาประสบการณ์การใช้งานของคุณ ตาม <strong
              >พ.ร.บ. คุ้มครองข้อมูลส่วนบุคคล (PDPA)</strong
            >
            โดยการใช้งานเว็บไซต์นี้ต่อไป ถือว่าคุณยินยอมให้เราใช้คุกกี้ตามนโยบายความเป็นส่วนตัว
          </p>
        </div>
        <div class="cookie-consent-actions">
          <a href="/privacy-policy" class="cookie-link">นโยบายความเป็นส่วนตัว</a
          >
          <button class="cookie-accept" id="cookieAccept">ยอมรับ</button>
        </div>
      </div>
    </div>

    <script>
      (function () {
        const banner = document.getElementById("cookieConsent");
        const btn = document.getElementById("cookieAccept");
        if (!banner || !btn) return;

        if (localStorage.getItem("pdpa_consent") === "accepted") {
          banner.remove();
          return;
        }

        // Show banner after a short delay
        setTimeout(() => banner.classList.add("visible"), 800);

        btn.addEventListener("click", () => {
          localStorage.setItem("pdpa_consent", "accepted");
          banner.classList.remove("visible");
          setTimeout(() => banner.remove(), 400);
        });
      })();
    </script>
  </body>

  <style is:global>
    /* ── CSS Reset & Design Tokens ── */
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      /* Color Palette — Medical / Trust / Clean */
      --color-bg: #fafbfd;
      --color-surface: #ffffff;
      --color-text: #1a1a2e;
      --color-text-muted: #6b7280;
      --color-primary: #0f766e;
      --color-primary-light: #14b8a6;
      --color-primary-dark: #0d5f58;
      --color-accent: #06b6d4;
      --color-accent-warm: #f59e0b;
      --color-border: #e5e7eb;
      --color-answer-bg: #f0fdfa;
      --color-answer-border: #99f6e4;

      /* Typography */
      --font-sans: "Inter", system-ui, -apple-system, sans-serif;
      --font-serif: "Merriweather", Georgia, serif;
      --text-xs: clamp(0.7rem, 0.65rem + 0.25vw, 0.75rem);
      --text-sm: clamp(0.8rem, 0.75rem + 0.25vw, 0.875rem);
      --text-base: clamp(0.95rem, 0.9rem + 0.25vw, 1.0625rem);
      --text-lg: clamp(1.1rem, 1rem + 0.5vw, 1.25rem);
      --text-xl: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
      --text-2xl: clamp(1.5rem, 1.25rem + 1.25vw, 2rem);
      --text-3xl: clamp(1.875rem, 1.5rem + 1.875vw, 2.5rem);

      /* Spacing */
      --space-1: 0.25rem;
      --space-2: 0.5rem;
      --space-3: 0.75rem;
      --space-4: 1rem;
      --space-6: 1.5rem;
      --space-8: 2rem;
      --space-12: 3rem;
      --space-16: 4rem;

      /* Layout */
      --max-width: 72rem;
      --content-width: 48rem;
      --radius: 0.5rem;
      --radius-lg: 0.75rem;

      /* Shadows */
      --shadow-sm: 0 1px 2px 0 rgb(0 0 0 / 0.05);
      --shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
      --shadow-md: 0 4px 6px -1px rgb(0 0 0 / 0.1),
        0 2px 4px -2px rgb(0 0 0 / 0.1);

      /* Transitions */
      --transition: 150ms ease;
    }

    html {
      font-family: var(--font-sans);
      font-size: 16px;
      line-height: 1.7;
      color: var(--color-text);
      background: var(--color-bg);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      scroll-behavior: smooth;
    }

    body {
      min-height: 100dvh;
    }

    img {
      max-width: 100%;
      height: auto;
      display: block;
    }

    a {
      color: var(--color-primary);
      text-decoration: none;
      transition: color var(--transition);
    }

    a:hover {
      color: var(--color-primary-dark);
    }

    /* Prose — Article content styling */
    .prose {
      font-family: var(--font-serif);
      font-size: var(--text-base);
      line-height: 1.8;
      max-width: var(--content-width);
    }

    .prose h1,
    .prose h2,
    .prose h3,
    .prose h4 {
      font-family: var(--font-sans);
      font-weight: 700;
      line-height: 1.3;
      margin-top: var(--space-8);
      margin-bottom: var(--space-4);
      color: var(--color-text);
    }

    .prose h1 {
      font-size: var(--text-3xl);
    }
    .prose h2 {
      font-size: var(--text-2xl);
    }
    .prose h3 {
      font-size: var(--text-xl);
    }
    .prose h4 {
      font-size: var(--text-lg);
    }

    .prose p {
      margin-bottom: var(--space-4);
    }

    .prose ul,
    .prose ol {
      padding-left: var(--space-6);
      margin-bottom: var(--space-4);
    }

    .prose li {
      margin-bottom: var(--space-2);
    }

    .prose blockquote {
      border-left: 4px solid var(--color-primary-light);
      padding: var(--space-4) var(--space-6);
      margin: var(--space-6) 0;
      background: var(--color-answer-bg);
      border-radius: 0 var(--radius) var(--radius) 0;
      font-style: italic;
      color: var(--color-text-muted);
    }

    .prose img {
      border-radius: var(--radius-lg);
      margin: var(--space-6) 0;
      box-shadow: var(--shadow-md);
    }

    .prose code {
      background: #f1f5f9;
      padding: 0.15em 0.4em;
      border-radius: 0.25rem;
      font-size: 0.9em;
    }

    .prose pre {
      background: #1e293b;
      color: #e2e8f0;
      padding: var(--space-4);
      border-radius: var(--radius);
      overflow-x: auto;
      margin: var(--space-6) 0;
    }

    .prose pre code {
      background: none;
      padding: 0;
      color: inherit;
    }

    /* ── PDPA Cookie Consent Banner ── */
    .cookie-consent {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      padding: var(--space-4);
      transform: translateY(100%);
      opacity: 0;
      transition: transform 400ms cubic-bezier(0.16, 1, 0.3, 1),
        opacity 300ms ease;
      pointer-events: none;
    }

    .cookie-consent.visible {
      transform: translateY(0);
      opacity: 1;
      pointer-events: all;
    }

    .cookie-consent-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-4);
      padding: var(--space-4) var(--space-6);
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 -4px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .cookie-consent-text {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      flex: 1;
    }

    .cookie-icon {
      flex-shrink: 0;
      color: var(--color-primary);
      margin-top: 2px;
    }

    .cookie-consent-text p {
      font-size: var(--text-sm);
      line-height: 1.6;
      color: var(--color-text);
      margin: 0;
    }

    .cookie-consent-actions {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-shrink: 0;
    }

    .cookie-link {
      font-size: var(--text-xs);
      color: var(--color-text-muted);
      white-space: nowrap;
      transition: color var(--transition);
    }

    .cookie-link:hover {
      color: var(--color-primary);
    }

    .cookie-accept {
      padding: var(--space-2) var(--space-6);
      background: var(--color-primary);
      color: white;
      border: none;
      border-radius: 999px;
      font-size: var(--text-sm);
      font-weight: 600;
      font-family: var(--font-sans);
      cursor: pointer;
      white-space: nowrap;
      transition: background var(--transition), transform var(--transition);
    }

    .cookie-accept:hover {
      background: var(--color-primary-dark);
      transform: scale(1.03);
    }

    @media (max-width: 640px) {
      .cookie-consent-inner {
        flex-direction: column;
        text-align: center;
        padding: var(--space-4);
      }

      .cookie-consent-text {
        flex-direction: column;
        align-items: center;
      }

      .cookie-consent-actions {
        width: 100%;
        justify-content: center;
      }
    }
  </style>
</html>
