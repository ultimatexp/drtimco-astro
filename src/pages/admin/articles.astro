---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { neon } from '@neondatabase/serverless';

const DATABASE_URL = import.meta.env.NEON_DATABASE_URL;

const url = Astro.url;
const statusFilter = url.searchParams.get('status') || '';
const searchQuery = url.searchParams.get('search') || '';

let articles: any[] = [];

if (DATABASE_URL) {
    try {
        const sql = neon(DATABASE_URL);
        
        // Build query dynamically
        const pageNum = Math.max(1, parseInt(url.searchParams.get('page') || '1', 10));
        const limit = 20;
        const offset = (pageNum - 1) * limit;
        
        if (statusFilter && searchQuery) {
            articles = await sql`
                SELECT id, title, slug, category, status, created_at, reviewed_at
                FROM article_drafts
                WHERE status = ${statusFilter} 
                AND title ILIKE ${'%' + searchQuery + '%'}
                ORDER BY created_at DESC
                LIMIT ${limit} OFFSET ${offset}
            `;
        } else if (statusFilter) {
            articles = await sql`
                SELECT id, title, slug, category, status, created_at, reviewed_at
                FROM article_drafts
                WHERE status = ${statusFilter}
                ORDER BY created_at DESC
                LIMIT ${limit} OFFSET ${offset}
            `;
        } else if (searchQuery) {
            articles = await sql`
                SELECT id, title, slug, category, status, created_at, reviewed_at
                FROM article_drafts
                WHERE title ILIKE ${'%' + searchQuery + '%'}
                ORDER BY created_at DESC
                LIMIT ${limit} OFFSET ${offset}
            `;
        } else {
            articles = await sql`
                SELECT id, title, slug, category, status, created_at, reviewed_at
                FROM article_drafts
                ORDER BY created_at DESC
                LIMIT ${limit} OFFSET ${offset}
            `;
        }
    } catch (e) {
        console.error("Error fetching articles:", e);
    }
}
---

<AdminLayout title="Articles">
    <div class="page-header">
        <div class="header-content">
            <h1>Article Management</h1>
            <p class="text-muted">Manage your drafts, pending reviews, and published articles.</p>
        </div>
        <div class="header-actions">
            <a href="/admin/editor" class="btn-primary">✨ New Article</a>
        </div>
    </div>

    <!-- Filters & Search -->
    <div class="filters-card card">
        <form method="GET" class="filters-form" id="filterForm">
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <input 
                    type="text" 
                    name="search" 
                    placeholder="Search titles..." 
                    value={searchQuery}
                    class="form-input search-input"
                />
            </div>
            <select name="status" class="form-select status-select" onchange="document.getElementById('filterForm').submit()">
                <option value="">All Statuses</option>
                <option value="draft" selected={statusFilter === 'draft'}>Drafts</option>
                <option value="review" selected={statusFilter === 'review'}>Pending Review</option>
                <option value="approved" selected={statusFilter === 'approved'}>Approved</option>
                <option value="published" selected={statusFilter === 'published'}>Published</option>
            </select>
            {(searchQuery || statusFilter) && (
                <a href="/admin/articles" class="btn-text clear-filters">Clear</a>
            )}
        </form>
    </div>

    <!-- Table -->
    <div class="card table-container">
        {articles.length > 0 ? (
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th class="actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {articles.map(article => (
                        <tr class="article-row" data-id={article.id}>
                            <td>
                                <div class="cell-title">
                                    <a href={`/admin/editor?id=${article.id}`} class="title-link">{article.title}</a>
                                    {article.slug && <span class="slug-text">/{article.slug}</span>}
                                </div>
                            </td>
                            <td>
                                <span class="category-tag">{article.category || 'Uncategorized'}</span>
                            </td>
                            <td>
                                <span class={`status-badge status-${article.status}`}>{article.status}</span>
                            </td>
                            <td>
                                <div class="date-text">
                                    {new Date(article.reviewed_at || article.created_at).toLocaleDateString('en-GB')}
                                </div>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href={`/admin/editor?id=${article.id}`} class="btn-icon" title="Edit">✏️</a>
                                    
                                    {article.status === 'review' && (
                                        <button class="btn-icon approve-btn" data-id={article.id} title="Approve & Publish">✅</button>
                                    )}
                                    
                                    <a href={`/api/preview/${article.id}`} target="_blank" class="btn-icon" title="Preview">👁️</a>
                                </div>
                            </td>
                        </tr>
                    ))}
                </tbody>
            </table>
        ) : (
            <div class="empty-state">
                <div class="empty-icon">📝</div>
                <h3>No articles found</h3>
                <p>Try adjusting your search or filters, or create a new article.</p>
                <a href="/admin/editor" class="btn-primary" style="margin-top: 16px;">Create First Article</a>
            </div>
        )}
    </div>

</AdminLayout>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .page-header h1 {
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .filters-card {
        margin-bottom: 24px;
        padding: 16px 24px;
    }

    .filters-form {
        display: flex;
        gap: 16px;
        align-items: center;
        flex-wrap: wrap;
    }

    .search-box {
        position: relative;
        flex-grow: 1;
        min-width: 250px;
        max-width: 400px;
    }

    .search-icon {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.9rem;
        pointer-events: none;
    }

    .search-input {
        padding-left: 36px;
        width: 100%;
        background-color: var(--bg-base);
    }

    .status-select {
        width: 200px;
        background-color: var(--bg-base);
    }

    .form-input, .form-select {
        border: 1px solid var(--border);
        color: var(--text-main);
        padding: 10px;
        border-radius: 6px;
        outline: none;
        transition: border-color 0.2s;
    }

    .form-input:focus, .form-select:focus {
        border-color: var(--primary);
    }

    .clear-filters {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.875rem;
    }
    
    .clear-filters:hover {
        color: var(--text-main);
        text-decoration: underline;
    }

    .table-container {
        padding: 0;
        overflow-x: auto;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

    .data-table th, .data-table td {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border);
    }

    .data-table th {
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        background-color: rgba(0,0,0,0.1);
    }

    .data-table tr:last-child td {
        border-bottom: none;
    }

    .article-row:hover {
        background-color: var(--bg-base);
    }

    .cell-title {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .title-link {
        color: var(--text-main);
        font-weight: 500;
        text-decoration: none;
        font-size: 0.95rem;
    }

    .title-link:hover {
        color: var(--primary);
    }

    .slug-text {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .category-tag {
        background-color: rgba(148, 163, 184, 0.1);
        color: var(--text-muted);
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 500;
    }

    .status-badge {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
    }

    .status-published { background: rgba(34, 197, 94, 0.1); color: var(--success); }
    .status-approved  { background: rgba(59, 130, 246, 0.1); color: var(--primary); }
    .status-review    { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
    .status-draft     { background: rgba(148, 163, 184, 0.1); color: var(--text-muted); }
    .status-rejected  { background: rgba(239, 68, 68, 0.1); color: var(--danger); }

    .date-text {
        font-size: 0.875rem;
        color: var(--text-muted);
    }

    .actions-col {
        width: 120px;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
    }

    .btn-icon {
        background: transparent;
        border: none;
        padding: 6px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 1.1rem;
        transition: background-color 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .btn-icon:hover {
        background-color: var(--bg-surface-hover);
    }

    .empty-state {
        text-align: center;
        padding: 48px 24px;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        margin-bottom: 8px;
    }

    .empty-state p {
        color: var(--text-muted);
    }
</style>

<script>
    // Approve article logic
    document.querySelectorAll('.approve-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const currentTarget = e.currentTarget;
            if (!(currentTarget instanceof HTMLButtonElement)) return;
            
            const id = currentTarget.getAttribute('data-id');
            const row = currentTarget.closest('tr');
            
            if (!confirm('Are you sure you want to approve & publish this article? This may trigger a Facebook post.')) {
                return;
            }

            currentTarget.textContent = '⏳';
            currentTarget.disabled = true;

            try {
                // Fetch the auth token from cookies is tricky out of the box in client JS without an explicit endpoint 
                // Wait! The endpoint /api/approve-article previously took `key` param:
                // `if (key !== import.meta.env.ADMIN_PASSWORD) ...`
                // Let's modify the approve request slightly to read the cookies, or we use a pass-through here.
                
                // Read from cookies in the browser: Look for adminSession
                const getCookie = (name: string) => {
                    const value = `; ${document.cookie}`;
                    const parts = value.split(`; ${name}=`);
                    if (parts.length === 2) return parts.pop().split(';').shift();
                }
                const password = getCookie("adminSession");

                const res = await fetch('/api/approve-article', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, action: 'approve', key: password })
                });

                const data = await res.json();
                
                if (data.success) {
                    alert('Successfully approved and published!');
                    window.location.reload();
                } else {
                    alert('Error: ' + data.error);
                    currentTarget.textContent = '✅';
                    currentTarget.disabled = false;
                }
            } catch (err) {
                alert('Network error during approval.');
                currentTarget.textContent = '✅';
                currentTarget.disabled = false;
            }
        });
    });
</script>
