---
/**
 * Admin Article Dashboard
 * ─────────────────────────────────────────────
 * Review, approve, and reject AI-generated article drafts.
 * Protected by admin password.
 */
export const prerender = false;
---

<html lang="th">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="noindex, nofollow" />
        <title>Admin — จัดการบทความ | Dr. Tim</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <!-- Login Screen -->
        <div id="loginScreen" class="login-screen">
            <div class="login-card">
                <h1>🔐 Admin Access</h1>
                <p>กรุณาใส่รหัสผ่านเพื่อเข้าสู่ระบบ</p>
                <input
                    type="password"
                    id="passwordInput"
                    placeholder="Admin Password"
                />
                <button id="loginBtn" onclick="login()">เข้าสู่ระบบ</button>
                <p id="loginError" class="error" style="display:none">
                    รหัสผ่านไม่ถูกต้อง
                </p>
            </div>
        </div>

        <!-- Dashboard -->
        <div id="dashboard" style="display:none">
            <header class="admin-header">
                <div class="header-left">
                    <h1>📝 จัดการบทความ</h1>
                    <span class="badge" id="countBadge">0 บทความ</span>
                </div>
                <div class="header-right">
                    <select id="statusFilter" onchange="loadArticles()">
                        <option value="">ทั้งหมด</option>
                        <option value="review" selected>รอตรวจสอบ</option>
                        <option value="approved">อนุมัติแล้ว</option>
                        <option value="published">เผยแพร่แล้ว</option>
                        <option value="rejected">ปฏิเสธ</option>
                    </select>
                    <button class="btn-primary" onclick="openCompose()"
                        >✍️ เขียนบทความ</button
                    >
                    <button class="btn-secondary" onclick="loadArticles()"
                        >🔄 รีเฟรช</button
                    >
                    <button class="btn-secondary" onclick="toggleKeywords()"
                        >🔑 Keywords</button
                    >
                    <button class="btn-danger-sm" onclick="logout()"
                        >ออกจากระบบ</button
                    >
                </div>
            </header>

            <!-- Keywords Panel (hidden by default) -->
            <div id="keywordsPanel" class="panel" style="display:none">
                <h2>🔑 Keyword Queue</h2>
                <div class="keyword-form">
                    <input
                        type="text"
                        id="newKeyword"
                        placeholder="เพิ่ม keyword ใหม่..."
                    />
                    <input
                        type="text"
                        id="newCategory"
                        placeholder="หมวดหมู่"
                    />
                    <button onclick="addKeyword()">+ เพิ่ม</button>
                </div>
                <div id="keywordList"></div>
            </div>

            <!-- Article List -->
            <div id="articleList" class="article-grid"></div>

            <!-- Article Preview Modal -->
            <div id="previewModal" class="modal" style="display:none">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 id="previewTitle"></h2>
                        <button class="close-btn" onclick="closePreview()"
                            >✕</button
                        >
                    </div>
                    <div class="modal-meta">
                        <span id="previewCategory" class="tag"></span>
                        <span id="previewDate" class="meta-date"></span>
                        <span id="previewKeyword" class="meta-keyword"></span>
                    </div>
                    <div class="modal-seo">
                        <div class="seo-item">
                            <label>SEO Description:</label>
                            <p id="previewSEO"></p>
                        </div>
                        <div class="seo-item">
                            <label>Direct Answer:</label>
                            <p id="previewAnswer"></p>
                        </div>
                    </div>
                    <div id="previewContent" class="prose"></div>
                    <div class="modal-actions">
                        <textarea
                            id="adminNotes"
                            placeholder="หมายเหตุ (ถ้ามี)..."></textarea>
                        <div class="action-buttons">
                            <button class="btn-approve" id="approveBtn"
                                >✅ อนุมัติ & เผยแพร่</button
                            >
                            <button class="btn-reject" id="rejectBtn"
                                >❌ ปฏิเสธ</button
                            >
                        </div>
                    </div>
                </div>
            </div>

            <!-- Compose Article Modal -->
            <div id="composeModal" class="modal" style="display:none">
                <div class="modal-content compose-modal">
                    <div class="modal-header">
                        <h2>✍️ เขียนบทความใหม่</h2>
                        <button class="close-btn" onclick="closeCompose()"
                            >✕</button
                        >
                    </div>
                    <div class="compose-form">
                        <div class="form-row">
                            <div class="form-group full">
                                <label>หัวข้อบทความ *</label>
                                <input
                                    type="text"
                                    id="compTitle"
                                    placeholder="เช่น CGM คืออะไร ทำไมคนรักสุขภาพต้องรู้"
                                />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Slug (URL)</label>
                                <input
                                    type="text"
                                    id="compSlug"
                                    placeholder="auto-generated ถ้าไม่ระบุ"
                                />
                            </div>
                            <div class="form-group">
                                <label>หมวดหมู่</label>
                                <input
                                    type="text"
                                    id="compCategory"
                                    placeholder="เบาหวาน"
                                />
                            </div>
                        </div>
                        <div class="form-group full">
                            <label>Excerpt (สรุปสั้นๆ)</label>
                            <textarea
                                id="compExcerpt"
                                rows="2"
                                placeholder="สรุป 2-3 ประโยค สำหรับ meta description"
                            ></textarea>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>SEO Description</label>
                                <input
                                    type="text"
                                    id="compSEO"
                                    placeholder="150-160 ตัวอักษร"
                                />
                            </div>
                            <div class="form-group">
                                <label>Direct Answer</label>
                                <input
                                    type="text"
                                    id="compAnswer"
                                    placeholder="คำตอบสั้น 40-60 คำ"
                                />
                            </div>
                        </div>
                        <div class="form-group full">
                            <label>เนื้อหาบทความ * (HTML)</label>
                            <textarea
                                id="compContent"
                                rows="14"
                                placeholder="<h2>หัวข้อ</h2>
<p>เนื้อหา...</p>"
                            ></textarea>
                        </div>
                        <div class="form-group full">
                            <label>Tags (คั่นด้วย comma)</label>
                            <input
                                type="text"
                                id="compTags"
                                placeholder="CGM, เบาหวาน, น้ำตาลในเลือด"
                            />
                        </div>
                        <div class="compose-actions">
                            <button
                                class="btn-secondary"
                                onclick="closeCompose()">ยกเลิก</button
                            >
                            <button
                                class="btn-primary"
                                id="compSubmitBtn"
                                onclick="createArticle()"
                                >💾 บันทึกบทความ</button
                            >
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <script is:inline>
            let adminKey = "";

            function login() {
                adminKey = document.getElementById("passwordInput").value;
                fetch(
                    `/api/articles?key=${encodeURIComponent(
                        adminKey
                    )}&status=review`
                ).then((r) => {
                    if (r.status === 401) {
                        document.getElementById("loginError").style.display =
                            "block";
                        return;
                    }
                    sessionStorage.setItem("admin_key", adminKey);
                    document.getElementById("loginScreen").style.display =
                        "none";
                    document.getElementById("dashboard").style.display =
                        "block";
                    loadArticles();
                });
            }

            function logout() {
                sessionStorage.removeItem("admin_key");
                adminKey = "";
                document.getElementById("dashboard").style.display = "none";
                document.getElementById("loginScreen").style.display = "block";
                document.getElementById("passwordInput").value = "";
            }

            // Auto-login if session exists
            window.addEventListener("DOMContentLoaded", () => {
                const saved = sessionStorage.getItem("admin_key");
                if (saved) {
                    adminKey = saved;
                    document.getElementById("loginScreen").style.display =
                        "none";
                    document.getElementById("dashboard").style.display =
                        "block";
                    loadArticles();
                }
                document
                    .getElementById("passwordInput")
                    .addEventListener("keypress", (e) => {
                        if (e.key === "Enter") login();
                    });
            });

            async function loadArticles() {
                const status = document.getElementById("statusFilter").value;
                const url = `/api/articles?key=${encodeURIComponent(adminKey)}${
                    status ? `&status=${status}` : ""
                }`;
                const res = await fetch(url);
                if (res.status === 401) {
                    logout();
                    return;
                }
                const articles = await res.json();

                document.getElementById(
                    "countBadge"
                ).textContent = `${articles.length} บทความ`;

                const container = document.getElementById("articleList");
                if (articles.length === 0) {
                    container.innerHTML =
                        '<div class="empty-state"><p>🎉 ไม่มีบทความในสถานะนี้</p></div>';
                    return;
                }

                container.innerHTML = articles
                    .map(
                        (a) => `
        <div class="article-card" onclick="openPreview(${a.id})">
          <div class="card-status status-${a.status}">${statusLabel(
                            a.status
                        )}</div>
          <h3>${a.title}</h3>
          <p class="card-excerpt">${a.excerpt || ""}</p>
          <div class="card-meta">
            <span class="tag">${a.category || "ไม่ระบุ"}</span>
            <span class="meta-date">${new Date(a.created_at).toLocaleDateString(
                "th-TH",
                { day: "numeric", month: "short", year: "numeric" }
            )}</span>
          </div>
        </div>
      `
                    )
                    .join("");
            }

            function statusLabel(status) {
                const labels = {
                    draft: "📄 Draft",
                    review: "🔍 รอตรวจสอบ",
                    approved: "✅ อนุมัติ",
                    published: "🚀 เผยแพร่แล้ว",
                    rejected: "❌ ปฏิเสธ",
                };
                return labels[status] || status;
            }

            async function openPreview(id) {
                const res = await fetch(
                    `/api/article/${id}?key=${encodeURIComponent(adminKey)}`
                );
                const article = await res.json();

                document.getElementById("previewTitle").textContent =
                    article.title;
                document.getElementById("previewCategory").textContent =
                    article.category || "";
                document.getElementById("previewDate").textContent = new Date(
                    article.created_at
                ).toLocaleDateString("th-TH");
                document.getElementById("previewKeyword").textContent = `🔑 ${
                    article.keyword || ""
                }`;
                document.getElementById("previewSEO").textContent =
                    article.seo_description || "";
                document.getElementById("previewAnswer").textContent =
                    article.direct_answer || "";
                document.getElementById("previewContent").innerHTML =
                    article.content;
                document.getElementById("adminNotes").value =
                    article.admin_notes || "";

                const approveBtn = document.getElementById("approveBtn");
                const rejectBtn = document.getElementById("rejectBtn");

                if (article.status === "review") {
                    approveBtn.style.display = "inline-flex";
                    rejectBtn.style.display = "inline-flex";
                    approveBtn.onclick = () => handleAction(id, "approve");
                    rejectBtn.onclick = () => handleAction(id, "reject");
                } else {
                    approveBtn.style.display = "none";
                    rejectBtn.style.display = "none";
                }

                document.getElementById("previewModal").style.display = "flex";
                document.body.style.overflow = "hidden";
            }

            function closePreview() {
                document.getElementById("previewModal").style.display = "none";
                document.body.style.overflow = "";
            }

            async function handleAction(id, action) {
                const notes = document.getElementById("adminNotes").value;
                const btn =
                    action === "approve"
                        ? document.getElementById("approveBtn")
                        : document.getElementById("rejectBtn");
                btn.disabled = true;
                btn.textContent =
                    action === "approve"
                        ? "⏳ กำลังเผยแพร่..."
                        : "⏳ กำลังปฏิเสธ...";

                try {
                    const res = await fetch("/api/approve-article", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            id,
                            action,
                            notes,
                            key: adminKey,
                        }),
                    });
                    const result = await res.json();

                    if (result.success) {
                        let msg =
                            action === "approve"
                                ? "✅ บทความถูกอนุมัติแล้ว!"
                                : "❌ บทความถูกปฏิเสธแล้ว";
                        if (result.facebook?.success)
                            msg += "\n📘 โพสต์ลง Facebook แล้ว!";
                        if (result.deploy?.success)
                            msg += "\n🔄 กำลังอัปเดตเว็บไซต์...";
                        alert(msg);
                        closePreview();
                        loadArticles();
                    }
                } catch (err) {
                    alert("❌ เกิดข้อผิดพลาด: " + err.message);
                }

                btn.disabled = false;
                btn.textContent =
                    action === "approve" ? "✅ อนุมัติ & เผยแพร่" : "❌ ปฏิเสธ";
            }

            function toggleKeywords() {
                const panel = document.getElementById("keywordsPanel");
                panel.style.display =
                    panel.style.display === "none" ? "block" : "none";
                if (panel.style.display === "block") loadKeywords();
            }

            async function loadKeywords() {
                // TODO: Add keyword list API endpoint
                document.getElementById("keywordList").innerHTML =
                    '<p class="meta-date">กำลังโหลด...</p>';
            }

            async function addKeyword() {
                // TODO: Add keyword via API
                const keyword = document.getElementById("newKeyword").value;
                if (!keyword) return;
                alert(`Keyword "${keyword}" จะถูกเพิ่มเมื่อ API พร้อมใช้งาน`);
            }

            // ── Compose Article ──
            function openCompose() {
                document.getElementById("composeModal").style.display = "flex";
                document.body.style.overflow = "hidden";
                document.getElementById("compTitle").focus();
            }

            function closeCompose() {
                document.getElementById("composeModal").style.display = "none";
                document.body.style.overflow = "";
                // Reset form
                [
                    "compTitle",
                    "compSlug",
                    "compCategory",
                    "compExcerpt",
                    "compSEO",
                    "compAnswer",
                    "compContent",
                    "compTags",
                ].forEach((id) => {
                    document.getElementById(id).value = "";
                });
            }

            async function createArticle() {
                const title = document.getElementById("compTitle").value.trim();
                const content = document
                    .getElementById("compContent")
                    .value.trim();

                if (!title || !content) {
                    alert("กรุณากรอกหัวข้อและเนื้อหาบทความ");
                    return;
                }

                const btn = document.getElementById("compSubmitBtn");
                btn.disabled = true;
                btn.textContent = "⏳ กำลังบันทึก...";

                const tagsStr = document.getElementById("compTags").value;
                const tags = tagsStr
                    ? tagsStr
                          .split(",")
                          .map((t) => t.trim())
                          .filter(Boolean)
                    : [];

                try {
                    const res = await fetch("/api/create-article", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            key: adminKey,
                            title,
                            slug: document
                                .getElementById("compSlug")
                                .value.trim(),
                            content,
                            excerpt: document
                                .getElementById("compExcerpt")
                                .value.trim(),
                            seo_description: document
                                .getElementById("compSEO")
                                .value.trim(),
                            direct_answer: document
                                .getElementById("compAnswer")
                                .value.trim(),
                            category: document
                                .getElementById("compCategory")
                                .value.trim(),
                            tags,
                        }),
                    });
                    const result = await res.json();

                    if (result.success) {
                        alert(
                            `✅ บทความ "${result.article.title}" ถูกบันทึกแล้ว!`
                        );
                        closeCompose();
                        document.getElementById("statusFilter").value =
                            "review";
                        loadArticles();
                    } else {
                        alert("❌ " + (result.error || "เกิดข้อผิดพลาด"));
                    }
                } catch (err) {
                    alert("❌ เกิดข้อผิดพลาด: " + err.message);
                }

                btn.disabled = false;
                btn.textContent = "💾 บันทึกบทความ";
            }
        </script>

        <style is:global>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }
            body {
                font-family: "Inter", system-ui, sans-serif;
                background: #0f172a;
                color: #e2e8f0;
                min-height: 100dvh;
            }

            /* Login */
            .login-screen {
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100dvh;
                padding: 1rem;
            }
            .login-card {
                background: #1e293b;
                border: 1px solid #334155;
                border-radius: 1rem;
                padding: 2.5rem;
                max-width: 400px;
                width: 100%;
                text-align: center;
            }
            .login-card h1 {
                font-size: 1.5rem;
                margin-bottom: 0.5rem;
            }
            .login-card p {
                color: #94a3b8;
                margin-bottom: 1.5rem;
                font-size: 0.9rem;
            }
            .login-card input {
                width: 100%;
                padding: 0.75rem 1rem;
                background: #0f172a;
                border: 1px solid #334155;
                border-radius: 0.5rem;
                color: #e2e8f0;
                font-size: 1rem;
                margin-bottom: 1rem;
                outline: none;
            }
            .login-card input:focus {
                border-color: #0ea5e9;
            }
            .login-card button {
                width: 100%;
                padding: 0.75rem;
                background: linear-gradient(135deg, #0ea5e9, #0284c7);
                color: white;
                border: none;
                border-radius: 0.5rem;
                font-size: 1rem;
                font-weight: 600;
                cursor: pointer;
                transition: transform 0.15s;
            }
            .login-card button:hover {
                transform: scale(1.02);
            }
            .error {
                color: #f87171;
                margin-top: 0.75rem;
                font-size: 0.85rem;
            }

            /* Header */
            .admin-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 1.25rem 2rem;
                background: #1e293b;
                border-bottom: 1px solid #334155;
                position: sticky;
                top: 0;
                z-index: 100;
                flex-wrap: wrap;
                gap: 0.75rem;
            }
            .header-left {
                display: flex;
                align-items: center;
                gap: 0.75rem;
            }
            .header-left h1 {
                font-size: 1.25rem;
            }
            .header-right {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                flex-wrap: wrap;
            }
            .badge {
                background: #0ea5e9;
                color: white;
                padding: 0.2rem 0.6rem;
                border-radius: 999px;
                font-size: 0.75rem;
                font-weight: 600;
            }
            select {
                background: #0f172a;
                color: #e2e8f0;
                border: 1px solid #334155;
                padding: 0.5rem 0.75rem;
                border-radius: 0.375rem;
                font-size: 0.85rem;
            }
            .btn-secondary {
                padding: 0.5rem 1rem;
                background: #334155;
                border: 1px solid #475569;
                color: #e2e8f0;
                border-radius: 0.375rem;
                font-size: 0.85rem;
                cursor: pointer;
                transition: background 0.15s;
            }
            .btn-secondary:hover {
                background: #475569;
            }
            .btn-danger-sm {
                padding: 0.5rem 1rem;
                background: transparent;
                border: 1px solid #ef4444;
                color: #ef4444;
                border-radius: 0.375rem;
                font-size: 0.85rem;
                cursor: pointer;
            }
            .btn-danger-sm:hover {
                background: #ef44441a;
            }
            .btn-primary {
                padding: 0.5rem 1rem;
                background: linear-gradient(135deg, #0ea5e9, #0284c7);
                color: white;
                border: none;
                border-radius: 0.375rem;
                font-size: 0.85rem;
                font-weight: 600;
                cursor: pointer;
                transition: transform 0.15s;
            }
            .btn-primary:hover {
                transform: scale(1.02);
            }
            .btn-primary:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none;
            }

            /* Compose Form */
            .compose-modal {
                max-width: 900px;
            }
            .compose-form {
                display: flex;
                flex-direction: column;
                gap: 0.75rem;
            }
            .form-row {
                display: flex;
                gap: 0.75rem;
            }
            .form-group {
                flex: 1;
                display: flex;
                flex-direction: column;
                gap: 0.25rem;
            }
            .form-group.full {
                width: 100%;
            }
            .compose-form label {
                font-size: 0.75rem;
                font-weight: 600;
                color: #94a3b8;
                text-transform: uppercase;
                letter-spacing: 0.03em;
            }
            .compose-form input,
            .compose-form textarea {
                width: 100%;
                padding: 0.6rem 0.75rem;
                background: #0f172a;
                border: 1px solid #334155;
                border-radius: 0.375rem;
                color: #e2e8f0;
                font-size: 0.9rem;
                font-family: inherit;
                outline: none;
                transition: border-color 0.15s;
            }
            .compose-form input:focus,
            .compose-form textarea:focus {
                border-color: #0ea5e9;
            }
            .compose-form textarea {
                resize: vertical;
            }
            .compose-actions {
                display: flex;
                justify-content: flex-end;
                gap: 0.75rem;
                margin-top: 0.5rem;
                padding-top: 1rem;
                border-top: 1px solid #334155;
            }
            @media (max-width: 640px) {
                .form-row {
                    flex-direction: column;
                }
            }

            /* Keywords Panel */
            .panel {
                margin: 1rem 2rem;
                padding: 1.5rem;
                background: #1e293b;
                border: 1px solid #334155;
                border-radius: 0.75rem;
            }
            .panel h2 {
                font-size: 1.1rem;
                margin-bottom: 1rem;
            }
            .keyword-form {
                display: flex;
                gap: 0.5rem;
                margin-bottom: 1rem;
            }
            .keyword-form input {
                flex: 1;
                padding: 0.5rem 0.75rem;
                background: #0f172a;
                border: 1px solid #334155;
                border-radius: 0.375rem;
                color: #e2e8f0;
                font-size: 0.9rem;
            }
            .keyword-form button {
                padding: 0.5rem 1rem;
                background: #0ea5e9;
                color: white;
                border: none;
                border-radius: 0.375rem;
                cursor: pointer;
                font-weight: 600;
            }

            /* Article Grid */
            .article-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
                gap: 1rem;
                padding: 1.5rem 2rem;
            }
            .article-card {
                background: #1e293b;
                border: 1px solid #334155;
                border-radius: 0.75rem;
                padding: 1.25rem;
                cursor: pointer;
                transition: border-color 0.2s, transform 0.15s;
                position: relative;
            }
            .article-card:hover {
                border-color: #0ea5e9;
                transform: translateY(-2px);
            }
            .article-card h3 {
                font-size: 1rem;
                margin-bottom: 0.5rem;
                line-height: 1.4;
            }
            .card-excerpt {
                font-size: 0.85rem;
                color: #94a3b8;
                line-height: 1.5;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
                margin-bottom: 0.75rem;
            }
            .card-status {
                position: absolute;
                top: 0.75rem;
                right: 0.75rem;
                padding: 0.15rem 0.5rem;
                border-radius: 999px;
                font-size: 0.7rem;
                font-weight: 600;
            }
            .status-review {
                background: #f59e0b20;
                color: #fbbf24;
            }
            .status-approved {
                background: #10b98120;
                color: #34d399;
            }
            .status-published {
                background: #0ea5e920;
                color: #38bdf8;
            }
            .status-rejected {
                background: #ef444420;
                color: #f87171;
            }
            .card-meta {
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }
            .tag {
                background: #0f766e20;
                color: #14b8a6;
                padding: 0.125rem 0.5rem;
                border-radius: 999px;
                font-size: 0.75rem;
            }
            .meta-date {
                font-size: 0.75rem;
                color: #64748b;
            }
            .meta-keyword {
                font-size: 0.75rem;
                color: #818cf8;
            }
            .empty-state {
                grid-column: 1 / -1;
                text-align: center;
                padding: 4rem 2rem;
                color: #64748b;
                font-size: 1.1rem;
            }

            /* Modal */
            .modal {
                position: fixed;
                inset: 0;
                background: rgba(0, 0, 0, 0.7);
                backdrop-filter: blur(4px);
                z-index: 1000;
                display: flex;
                align-items: flex-start;
                justify-content: center;
                padding: 2rem;
                overflow-y: auto;
            }
            .modal-content {
                background: #1e293b;
                border: 1px solid #334155;
                border-radius: 1rem;
                max-width: 800px;
                width: 100%;
                padding: 2rem;
                margin-top: 2rem;
            }
            .modal-header {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                margin-bottom: 1rem;
            }
            .modal-header h2 {
                font-size: 1.25rem;
                line-height: 1.4;
                flex: 1;
            }
            .close-btn {
                background: none;
                border: none;
                color: #94a3b8;
                font-size: 1.5rem;
                cursor: pointer;
                padding: 0.25rem;
                line-height: 1;
            }
            .close-btn:hover {
                color: #e2e8f0;
            }
            .modal-meta {
                display: flex;
                gap: 0.75rem;
                margin-bottom: 1.25rem;
                flex-wrap: wrap;
            }
            .modal-seo {
                background: #0f172a;
                border: 1px solid #334155;
                border-radius: 0.5rem;
                padding: 1rem;
                margin-bottom: 1.5rem;
            }
            .seo-item {
                margin-bottom: 0.75rem;
            }
            .seo-item:last-child {
                margin-bottom: 0;
            }
            .seo-item label {
                font-size: 0.75rem;
                font-weight: 600;
                color: #0ea5e9;
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }
            .seo-item p {
                font-size: 0.85rem;
                color: #94a3b8;
                margin-top: 0.25rem;
            }

            /* Prose */
            .prose {
                font-size: 0.95rem;
                line-height: 1.8;
                color: #cbd5e1;
                max-height: 50vh;
                overflow-y: auto;
                padding-right: 0.5rem;
            }
            .prose h2 {
                font-size: 1.15rem;
                font-weight: 700;
                margin: 1.5rem 0 0.75rem;
                color: #e2e8f0;
            }
            .prose h3 {
                font-size: 1rem;
                font-weight: 600;
                margin: 1.25rem 0 0.5rem;
                color: #e2e8f0;
            }
            .prose p {
                margin-bottom: 0.75rem;
            }
            .prose ul,
            .prose ol {
                padding-left: 1.5rem;
                margin-bottom: 0.75rem;
            }
            .prose li {
                margin-bottom: 0.25rem;
            }
            .prose blockquote {
                border-left: 3px solid #0ea5e9;
                padding: 0.5rem 1rem;
                margin: 1rem 0;
                background: #0f172a;
                border-radius: 0 0.375rem 0.375rem 0;
                color: #94a3b8;
            }
            .prose strong {
                color: #e2e8f0;
            }

            /* Actions */
            .modal-actions {
                margin-top: 1.5rem;
                border-top: 1px solid #334155;
                padding-top: 1.25rem;
            }
            .modal-actions textarea {
                width: 100%;
                padding: 0.75rem;
                background: #0f172a;
                border: 1px solid #334155;
                border-radius: 0.5rem;
                color: #e2e8f0;
                font-size: 0.9rem;
                font-family: inherit;
                resize: vertical;
                min-height: 60px;
                margin-bottom: 1rem;
            }
            .action-buttons {
                display: flex;
                gap: 0.75rem;
            }
            .btn-approve,
            .btn-reject {
                flex: 1;
                padding: 0.75rem;
                border: none;
                border-radius: 0.5rem;
                font-size: 0.95rem;
                font-weight: 600;
                cursor: pointer;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 0.5rem;
                transition: transform 0.15s;
            }
            .btn-approve {
                background: linear-gradient(135deg, #10b981, #059669);
                color: white;
            }
            .btn-reject {
                background: linear-gradient(135deg, #ef4444, #dc2626);
                color: white;
            }
            .btn-approve:hover,
            .btn-reject:hover {
                transform: scale(1.02);
            }
            .btn-approve:disabled,
            .btn-reject:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                transform: none;
            }

            @media (max-width: 640px) {
                .admin-header {
                    padding: 1rem;
                }
                .article-grid {
                    padding: 1rem;
                    grid-template-columns: 1fr;
                }
                .modal {
                    padding: 0.5rem;
                }
                .modal-content {
                    padding: 1.25rem;
                }
                .action-buttons {
                    flex-direction: column;
                }
            }
        </style>
    </body>
</html>
