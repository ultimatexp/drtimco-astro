---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Categories">
    <div class="page-header">
        <div class="header-content">
            <h1>Categories</h1>
            <p class="text-muted">Manage the categories used for organizing articles.</p>
        </div>
    </div>

    <div class="split-layout">
        <!-- Add Category Form -->
        <div class="card add-card">
            <h3>Add New Category</h3>
            <form id="addCategoryForm" class="form-container">
                <div class="form-group">
                    <label>Category Name</label>
                    <input type="text" id="catName" class="form-input" placeholder="e.g. Health & Wellness" required />
                </div>
                <div class="form-group">
                    <label>Slug</label>
                    <input type="text" id="catSlug" class="form-input" placeholder="e.g. health-wellness" required />
                    <small class="text-muted">Friendly URL identifier (auto-generated if empty)</small>
                </div>
                <button type="submit" class="btn-primary" style="width: 100%;" id="addBtn">Add Category</button>
            </form>
        </div>

        <!-- Categories Table -->
        <div class="card table-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th style="width: 120px; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody id="categoriesTableBody">
                    <tr>
                        <td colspan="3" style="text-align: center; padding: 24px; color: var(--text-muted);">
                            Loading categories...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</AdminLayout>

<style>
    .page-header {
        margin-bottom: 24px;
    }

    .page-header h1 {
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .split-layout {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 24px;
        align-items: start;
    }

    @media (max-width: 768px) {
        .split-layout {
            grid-template-columns: 1fr;
        }
    }

    .form-container {
        display: flex;
        flex-direction: column;
        gap: 16px;
        margin-top: 16px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .form-input {
        padding: 10px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 0.95rem;
        background: var(--bg-surface);
        color: var(--text-main);
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th, .data-table td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        text-align: left;
    }

    .data-table th {
        background-color: var(--bg-surface);
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .data-table tr:hover {
        background-color: rgba(0, 0, 0, 0.01);
    }

    .btn-sm {
        padding: 4px 8px;
        font-size: 0.8rem;
        border: 1px solid var(--border);
        background: var(--bg-surface);
        border-radius: 4px;
        cursor: pointer;
    }

    .btn-sm:hover {
        background: var(--border);
    }

    .btn-danger {
        color: #ef4444;
        border-color: #fca5a5;
    }
    
    .btn-danger:hover {
        background: #fee2e2;
    }
</style>

<script>
    let categories: any[] = []; // explicit TS typing for Astro inline script

    const loadCategories = async () => {
        try {
            const res = await fetch('/api/admin/categories');
            const data = await res.json();
            
            if (data.success) {
                categories = data.categories || [];
                renderTable();
            } else {
                alert('Error loading categories: ' + data.error);
            }
        } catch (err) {
            console.error(err);
            alert('Failed to fetch categories.');
        }
    };

    const renderTable = () => {
        const tbody = document.getElementById('categoriesTableBody');
        if (!tbody) return;
        
        if (categories.length === 0) {
            tbody.innerHTML = `<tr><td colspan="3" style="text-align:center; padding:24px; color:var(--text-muted);">No categories found.</td></tr>`;
            return;
        }

        tbody.innerHTML = categories.map(cat => `
            <tr data-id="${cat.id}">
                <td>${cat.name}</td>
                <td><code style="background:var(--bg-base); padding:2px 6px; border-radius:4px;">${cat.slug}</code></td>
                <td style="text-align: right; display:flex; gap:8px; justify-content:flex-end;">
                    <button class="btn-sm edit-btn" data-id="${cat.id}">Edit</button>
                    <button class="btn-sm btn-danger del-btn" data-id="${cat.id}">Delete</button>
                </td>
            </tr>
        `).join('');

        attachListeners();
    };

    const attachListeners = () => {
        // Delete
        document.querySelectorAll('.del-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget;
                if (!(target instanceof HTMLButtonElement)) return;
                
                const id = target.getAttribute('data-id');
                if (!confirm('Are you sure you want to delete this category? Articles will not be deleted.')) return;
                
                try {
                    const res = await fetch('/api/admin/categories', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ action: 'delete', id })
                    });
                    const data = await res.json();
                    if (data.success) {
                        loadCategories();
                    } else {
                        alert(data.error);
                    }
                } catch (e) {
                    alert('Network error.');
                }
            });
        });

        // Edit (prompt basic implementation for simplicity)
        document.querySelectorAll('.edit-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const target = e.currentTarget;
                if (!(target instanceof HTMLButtonElement)) return;
                
                const id = target.getAttribute('data-id');
                const cat = categories.find(c => c.id == id);
                if (!cat) return;

                const newName = prompt('Enter new category name:', cat.name);
                if (!newName || newName === cat.name) return;

                const newSlug = prompt('Enter new slug (optional):', cat.slug);

                try {
                    const res = await fetch('/api/admin/categories', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            action: 'update', 
                            id, 
                            name: newName, 
                            slug: newSlug || cat.slug,
                            oldName: cat.name
                        })
                    });
                    const data = await res.json();
                    if (data.success) {
                        loadCategories();
                    } else {
                        alert(data.error);
                    }
                } catch (e) {
                    alert('Network error.');
                }
            });
        });
    };

    // Auto-slugify
    const nameInput = document.getElementById('catName') as HTMLInputElement | null;
    const slugInput = document.getElementById('catSlug') as HTMLInputElement | null;

    if (nameInput && slugInput) {
        nameInput.addEventListener('input', () => {
            if (!slugInput.value || slugInput.getAttribute('data-auto') === 'true') {
                slugInput.value = nameInput.value
                    .toLowerCase()
                    .replace(/[^a-z0-9]+/g, '-')
                    .replace(/(^-|-$)+/g, '');
                slugInput.setAttribute('data-auto', 'true');
            }
        });

        slugInput.addEventListener('input', () => {
            slugInput.setAttribute('data-auto', 'false');
        });
    }

    // Add Form
    const addForm = document.getElementById('addCategoryForm');
    if (addForm) {
        addForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('addBtn') as HTMLButtonElement | null;
            if (!nameInput || !slugInput) return;
            
            const name = nameInput.value;
            const slug = slugInput.value;

            if (btn) {
                btn.disabled = true;
                btn.textContent = 'Saving...';
            }

            try {
                const res = await fetch('/api/admin/categories', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ action: 'create', name, slug })
                });
                const data = await res.json();
                
                if (data.success) {
                    nameInput.value = '';
                    slugInput.value = '';
                    slugInput.setAttribute('data-auto', 'true');
                    loadCategories();
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (err) {
                alert('Network error.');
            } finally {
                if (btn) {
                    btn.disabled = false;
                    btn.textContent = 'Add Category';
                }
            }
        });
    }

    // Init
    loadCategories();
</script>
