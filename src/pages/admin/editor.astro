    /* Category Combo Dropdown */
    .category-combo {
        position: relative;
    }

    .category-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: var(--bg-secondary);
        border: 1px solid var(--border);
        border-top: none;
        border-radius: 0 0 8px 8px;
        max-height: 200px;
        overflow-y: auto;
        z-index: 100;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .category-dropdown.open {
        display: block;
    }

    .category-option {
        padding: 10px 14px;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--text-secondary);
        transition: all 0.15s;
    }

    .category-option:hover,
    .category-option.highlighted {
        background: rgba(99, 102, 241, 0.15);
        color: var(--text-primary);
    }

    .category-option.hidden {
        display: none;
    }

    .category-new-hint {
        padding: 10px 14px;
        font-size: 0.85rem;
        color: #a78bfa;
        border-top: 1px solid var(--border);
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background 0.15s;
    }

    .category-new-hint:hover {
        background: rgba(167, 139, 250, 0.1);
    }

    .hint-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background: #6366f1;
        color: white;
        font-size: 0.8rem;
        font-weight: 700;
    }

    .cta-button {
        display: inline-block;
        padding: 0.75rem 1.75rem;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white !important;
        text-decoration: none !important;
        border-radius: 8px;
        font-weight: 600;
        text-align: center;
        margin: 1.5rem 0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        border: none;
        cursor: pointer;
    }

    .cta-button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    }
</style>

<!-- TipTap Editor Script -->
<script>
    import { Editor, Node, mergeAttributes } from '@tiptap/core';
    import StarterKit from '@tiptap/starter-kit';
    import Underline from '@tiptap/extension-underline';
    import Link from '@tiptap/extension-link';
    import Image from '@tiptap/extension-image';
    import Placeholder from '@tiptap/extension-placeholder';
    import { Table } from '@tiptap/extension-table';
    import TableRow from '@tiptap/extension-table-row';
    import TableCell from '@tiptap/extension-table-cell';
    import TableHeader from '@tiptap/extension-table-header';

    console.log('[TipTap] All extensions loaded successfully');

    // Wait for DOM to be fully ready before accessing elements
    function initEditor() {

    // CTA Button TipTap Extension
    const CTAButton = Node.create({
        name: 'ctaButton',
        group: 'block',
        atom: true,
        addAttributes() {
            return {
                href: { default: null },
                text: { default: 'Check out' }
            };
        },
        parseHTML() {
            return [
                {
                    tag: 'a[data-type="cta-button"]'
                }
            ];
        },
        renderHTML({ HTMLAttributes }) {
            return ['a', mergeAttributes(HTMLAttributes, { 'data-type': 'cta-button', class: 'cta-button', target: '_blank', rel: 'noopener noreferrer' }), HTMLAttributes.text];
        },
        addCommands() {
            return {
                insertCTA: (options) => ({ commands }) => {
                    return commands.insertContent({
                        type: this.name,
                        attrs: options,
                    });
                },
            };
        },
    });

    // Initialize Editor
    const initialContent = document.getElementById('initialContent').value;
    
    // We export editor to window so button clicks can access it
    window.tiptapEditor = new Editor({
        element: document.getElementById('editorContent'),
        extensions: [
            CTAButton,
            StarterKit,
            Underline,
            Link.configure({
                openOnClick: false,
                HTMLAttributes: {
                    class: 'tiptap-link',
                },
            }),
            Image.configure({
                inline: true,
                allowBase64: true,
            }),
            Placeholder.configure({
                placeholder: 'Start writing your article here...',
            }),
            Table.configure({
                resizable: true,
                HTMLAttributes: { class: 'tiptap-table' },
            }),
            TableRow,
            TableCell,
            TableHeader
        ],
        content: initialContent,
        onUpdate: ({ editor }) => {
            updateToolbarState(editor);
            triggerAutosave();
        },
        onSelectionUpdate: ({ editor }) => {
            updateToolbarState(editor);
        }
    });

    // Toolbar logic
    function updateToolbarState(editor) {
        document.querySelectorAll('.toolbar-btn').forEach(btn => {
            const command = btn.getAttribute('data-command');
            
            // Map simple command names to TipTap isActive checks
            let isActive = false;
            switch(command) {
                case 'bold': isActive = editor.isActive('bold'); break;
                case 'italic': isActive = editor.isActive('italic'); break;
                case 'underline': isActive = editor.isActive('underline'); break;
                case 'strike': isActive = editor.isActive('strike'); break;
                case 'h2': isActive = editor.isActive('heading', { level: 2 }); break;
                case 'h3': isActive = editor.isActive('heading', { level: 3 }); break;
                case 'paragraph': isActive = editor.isActive('paragraph'); break;
                case 'bulletList': isActive = editor.isActive('bulletList'); break;
                case 'orderedList': isActive = editor.isActive('orderedList'); break;
                case 'blockquote': isActive = editor.isActive('blockquote'); break;
                case 'link': isActive = editor.isActive('link'); break;
            }

            if (isActive) {
                btn.classList.add('is-active');
            } else {
                btn.classList.remove('is-active');
            }
        });
    }

    document.querySelectorAll('.toolbar-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const command = btn.getAttribute('data-command');
            const editor = window.tiptapEditor;
            
            switch(command) {
                case 'bold': editor.chain().focus().toggleBold().run(); break;
                case 'italic': editor.chain().focus().toggleItalic().run(); break;
                case 'underline': editor.chain().focus().toggleUnderline().run(); break;
                case 'strike': editor.chain().focus().toggleStrike().run(); break;
                case 'h2': editor.chain().focus().toggleHeading({ level: 2 }).run(); break;
                case 'h3': editor.chain().focus().toggleHeading({ level: 3 }).run(); break;
                case 'paragraph': editor.chain().focus().setParagraph().run(); break;
                case 'bulletList': editor.chain().focus().toggleBulletList().run(); break;
                case 'orderedList': editor.chain().focus().toggleOrderedList().run(); break;
                case 'blockquote': editor.chain().focus().toggleBlockquote().run(); break;
                case 'link': 
                    const previousUrl = editor.getAttributes('link').href;
                    const url = window.prompt('URL', previousUrl);
                    if (url === null) return;
                    if (url === '') {
                        editor.chain().focus().extendMarkRange('link').unsetLink().run();
                    } else {
                        editor.chain().focus().extendMarkRange('link').setLink({ href: url }).run();
                    }
                    break;
                case 'cta':
                    const ctaUrl = window.prompt('CTA Button URL:');
                    if (ctaUrl) {
                        const ctaText = window.prompt('CTA Button Text:', 'Check out');
                        if (ctaText) {
                            editor.chain().focus().insertCTA({ href: ctaUrl, text: ctaText }).run();
                        }
                    }
                    break;
                case 'image':
                    const imgUrl = window.prompt('Image URL');
                    if (imgUrl) {
                        editor.chain().focus().setImage({ src: imgUrl }).run();
                    }
                    break;
                case 'insertTable':
                    editor.chain().focus().insertTable({ rows: 3, cols: 3, withHeaderRow: true }).run();
                    break;
                case 'addRowAfter':
                    editor.chain().focus().addRowAfter().run();
                    break;
                case 'addColAfter':
                    editor.chain().focus().addColumnAfter().run();
                    break;
                case 'deleteRow':
                    editor.chain().focus().deleteRow().run();
                    break;
                case 'deleteCol':
                    editor.chain().focus().deleteColumn().run();
                    break;
                case 'deleteTable':
                    editor.chain().focus().deleteTable().run();
                    break;
            }
        });
    });

    // Meta Description Counter
    const seoDesc = document.getElementById('seoDescription');
    const seoDescCount = document.getElementById('seoDescCount');
    if (seoDesc && seoDescCount) {
        const updateCount = () => {
            const len = seoDesc.value.length;
            seoDescCount.textContent = `${len}/160`;
            seoDescCount.style.color = len > 160 ? 'var(--danger)' : 'var(--text-muted)';
        };
        seoDesc.addEventListener('input', updateCount);
        updateCount();
    }

    // Featured Image Upload logic (stubbed to use window.prompt for now, or existing API)
    const btnUploadFeatured = document.getElementById('btnUploadFeatured');
    const featuredFileInput = document.getElementById('featuredFileInput');
    const featuredImageInput = document.getElementById('featuredImage');
    const featuredImagePreview = document.getElementById('featuredImagePreview');

    if (btnUploadFeatured && featuredFileInput) {
        // We reuse the existing /api/upload-image endpoint mechanics here
        btnUploadFeatured.addEventListener('click', () => {
            featuredFileInput.click();
        });

        featuredFileInput.addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const btnOriginalText = btnUploadFeatured.textContent;
            btnUploadFeatured.textContent = '⏳';
            
            const formData = new FormData();
            formData.append('file', file);
            formData.append('type', 'featured');

            try {
                const res = await fetch('/api/upload-image', {
                    method: 'POST',
                    body: formData
                });
                
                const data = await res.json();
                if (data.url) {
                    featuredImageInput.value = data.url;
                    if (featuredImagePreview) {
                        featuredImagePreview.src = data.url;
                        featuredImagePreview.style.display = 'block';
                    } else {
                        // Create preview if it didn't exist
                        const img = document.createElement('img');
                        img.id = 'featuredImagePreview';
                        img.src = data.url;
                        img.className = 'featured-preview';
                        featuredImageInput.parentElement.after(img);
                    }
                    triggerAutosave();
                } else {
                    alert('Upload failed: ' + (data.error || 'Unknown error'));
                }
            } catch (err) {
                alert('Upload error: ' + err.message);
            } finally {
                btnUploadFeatured.textContent = btnOriginalText;
            }
        });
    }

    // Save Logic (Draft and Publish)
    let autosaveTimeout = null;
    const saveStatus = document.getElementById('saveStatus');

    function triggerAutosave() {
        if (!document.getElementById('articleId').value) return; // Don't autosave purely new unsaved articles yet
        saveStatus.textContent = 'Unsaved changes...';
        clearTimeout(autosaveTimeout);
        autosaveTimeout = setTimeout(() => {
            saveArticle(false);
        }, 30000); // 30 sec autosave debounce
    }

    // Listen to title changes too
    document.getElementById('articleTitle').addEventListener('input', triggerAutosave);

    async function saveArticle(isPublishAction = false) {
        saveStatus.textContent = 'Saving...';
        
        // Gather data
        const id = document.getElementById('articleId').value;
        const title = document.getElementById('articleTitle').value;
        const content = window.tiptapEditor.getHTML();
        
        let status = document.getElementById('articleStatus').value;
        if (isPublishAction && status === 'draft') {
            status = 'published';
            document.getElementById('articleStatus').value = 'published';
        }

        const payload = {
            id: id || null,
            title,
            content,
            status,
            category: document.getElementById('articleCategory').value,
            seo_description: document.getElementById('seoDescription').value,
            direct_answer: document.getElementById('directAnswer').value,
            focus_keyword: document.getElementById('focusKeyword').value,
            featured_image_url: document.getElementById('featuredImage').value
        };

        try {
            // Using existing create-article endpoint that handles upsert
            // Or the new autosave endpoint if we build it. We'll use the robust one:
            const res = await fetch(id ? `/api/admin/article/${id}/autosave` : '/api/create-article', {
                method: id ? 'PATCH' : 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await res.json();
            
            if (data.success) {
                const now = new Date();
                saveStatus.textContent = `Saved at ${now.toLocaleTimeString()}`;
                
                // If it was new, set the ID
                if (!id && data.article && data.article.id) {
                    document.getElementById('articleId').value = data.article.id;
                    // Update URL without reload
                    window.history.replaceState({}, '', `/admin/editor?id=${data.article.id}`);
                }
            } else {
                saveStatus.textContent = `Error: ${data.error || 'Failed to save'}`;
            }
        } catch (err) {
            saveStatus.textContent = 'Network error saving draft.';
        }
    }

    document.getElementById('btnSaveDraft').addEventListener('click', () => saveArticle(false));
    document.getElementById('btnPublish').addEventListener('click', () => saveArticle(true));

    // ── AI Autofill SEO ──────────────────────────────────────
    const btnAiAutofill = document.getElementById('btnAiAutofill');
    const aiStatus = document.getElementById('aiAutofillStatus');

    btnAiAutofill.addEventListener('click', async () => {
        const title = document.getElementById('articleTitle').value;
        const content = window.tiptapEditor ? window.tiptapEditor.getHTML() : '';
        const category = document.getElementById('articleCategory').value;

        if (!title && !content) {
            aiStatus.textContent = '⚠️ Write a title or content first';
            aiStatus.style.color = 'var(--warning)';
            return;
        }

        btnAiAutofill.disabled = true;
        btnAiAutofill.innerHTML = '<span class="ai-spinner"></span> Generating...';
        aiStatus.textContent = '';

        try {
            const res = await fetch('/api/admin/ai-seo-autofill', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ title, content, category })
            });

            const data = await res.json();

            if (data.success) {
                // Fill fields with AI-generated content
                if (data.seo_description) {
                    document.getElementById('seoDescription').value = data.seo_description;
                    // Trigger char count update
                    document.getElementById('seoDescription').dispatchEvent(new Event('input'));
                }
                if (data.direct_answer) {
                    document.getElementById('directAnswer').value = data.direct_answer;
                }
                if (data.focus_keyword) {
                    document.getElementById('focusKeyword').value = data.focus_keyword;
                }

                aiStatus.textContent = '✅ SEO fields filled!';
                aiStatus.style.color = 'var(--success)';
                triggerAutosave();
            } else {
                aiStatus.textContent = '❌ ' + (data.error || 'Failed');
                aiStatus.style.color = 'var(--danger)';
            }
        } catch (err) {
            aiStatus.textContent = '❌ Network error';
            aiStatus.style.color = 'var(--danger)';
        } finally {
            btnAiAutofill.disabled = false;
            btnAiAutofill.innerHTML = '<span class="ai-icon">✨</span> AI Autofill SEO';
        }
    });

    // ───────── Category Combo Dropdown ─────────
    const catInput = document.getElementById('articleCategory');
    const catDropdown = document.getElementById('categoryDropdown');
    const catOptions = catDropdown.querySelectorAll('.category-option');
    const catNewHint = document.getElementById('categoryNewHint');
    const newCatName = document.getElementById('newCatName');

    function openDropdown() {
        catDropdown.classList.add('open');
        filterOptions();
    }

    function closeDropdown() {
        catDropdown.classList.remove('open');
    }

    function filterOptions() {
        const val = catInput.value.toLowerCase().trim();
        let hasExact = false;
        let visibleCount = 0;

        catOptions.forEach(opt => {
            const name = opt.dataset.value.toLowerCase();
            const match = !val || name.includes(val);
            opt.classList.toggle('hidden', !match);
            if (match) visibleCount++;
            if (name === val) hasExact = true;
        });

        // Show "add new" hint if typed value doesn't match existing
        if (val && !hasExact) {
            newCatName.textContent = catInput.value.trim();
            catNewHint.style.display = 'flex';
        } else {
            catNewHint.style.display = 'none';
        }
    }

    catInput.addEventListener('focus', openDropdown);
    catInput.addEventListener('input', () => {
        openDropdown();
    });

    // Select existing option
    catOptions.forEach(opt => {
        opt.addEventListener('click', () => {
            catInput.value = opt.dataset.value;
            closeDropdown();
            triggerAutosave();
        });
    });

    // Click on "add new" hint
    catNewHint.addEventListener('click', async () => {
        await createNewCategory(catInput.value.trim());
    });

    // Enter to add new category
    catInput.addEventListener('keydown', async (e) => {
        if (e.key === 'Enter') {
            e.preventDefault();
            const val = catInput.value.trim();
            if (!val) return;

            // Check if it matches an existing option
            const existing = [...catOptions].find(o => o.dataset.value.toLowerCase() === val.toLowerCase());
            if (existing) {
                catInput.value = existing.dataset.value;
                closeDropdown();
                triggerAutosave();
            } else {
                await createNewCategory(val);
            }
        }
    });

    async function createNewCategory(name) {
        try {
            const res = await fetch('/api/admin/categories', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name })
            });

            if (res.ok) {
                // Add new option to dropdown
                const newOpt = document.createElement('div');
                newOpt.className = 'category-option';
                newOpt.dataset.value = name;
                newOpt.textContent = name;
                newOpt.addEventListener('click', () => {
                    catInput.value = name;
                    closeDropdown();
                    triggerAutosave();
                });
                catDropdown.insertBefore(newOpt, catNewHint);

                catInput.value = name;
                closeDropdown();
                triggerAutosave();
            } else {
                const err = await res.json();
                console.error('Category create error:', err);
            }
        } catch (e) {
            console.error('Category create failed:', e);
        }
    }

    // Close dropdown on outside click
    document.addEventListener('click', (e) => {
        if (e.target && e.target.closest && !e.target.closest('.category-combo')) {
            closeDropdown();
        }
    });

    } // end initEditor

    // Run when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initEditor);
    } else {
        initEditor();
    }

</script>
