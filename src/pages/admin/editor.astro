    }

    .featured-preview {
        width: 100%;
        height: 160px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid var(--border);
        margin-top: 8px;
    }

    @media (max-width: 1024px) {
        .editor-container {
