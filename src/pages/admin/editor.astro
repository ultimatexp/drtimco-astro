---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { neon } from '@neondatabase/serverless';

const DATABASE_URL = import.meta.env.NEON_DATABASE_URL;

// Parse ID from URL
let articleId = Astro.url.searchParams.get('id');
let article = {
    title: '',
    slug: '',
    content: '',
    status: 'draft',
    category: '',
    tags: [],
    seo_description: '',
    direct_answer: '',
    focus_keyword: '',
    featured_image_url: ''
};

let categories = [];

// Fetch categories and existing article
if (DATABASE_URL) {
    try {
        const sql = neon(DATABASE_URL);
        
        // Load categories
        categories = await sql`SELECT id, name, slug FROM categories ORDER BY name ASC`;
        
        // Load existing article if ID provided
        if (articleId) {
            const [existing] = await sql`SELECT * FROM article_drafts WHERE id = ${articleId}`;
            if (existing) {
                article = {
                    ...existing,
                    tags: existing.tags || []
                };
            } else {
                articleId = null;
            }
        }
    } catch (e) {
        console.error("Error fetching data:", e);
    }
}
---

<AdminLayout title={articleId ? "Edit Article" : "New Article"}>
    <header class="editor-workspace-header">
        <div class="editor-heading">
            <div class="editor-kicker">Content editor</div>
            <h1>{articleId ? "Edit article" : "New article"}</h1>
        </div>
        <div class="editor-header-actions">
            <div id="saveStatus" class="save-status" aria-live="polite"></div>
            <button id="btnPreview" class="btn-secondary" type="button">Preview</button>
            <button id="btnSaveDraft" class="btn-secondary" type="button">Save Draft</button>
            <button id="btnPublish" class="btn-primary" type="button">Publish</button>
        </div>
    </header>

    <div class="editor-container">
        <!-- Editor Main Area -->
        <div class="editor-main">
            <!-- Toolbar -->
            <div class="editor-toolbar" id="toolbar" aria-label="Editor toolbar">
                <div class="toolbar-group">
                    <button class="toolbar-btn" type="button" data-command="bold" title="Bold" aria-label="Bold"><b>B</b></button>
                    <button class="toolbar-btn" type="button" data-command="italic" title="Italic" aria-label="Italic"><i>I</i></button>
                    <button class="toolbar-btn" type="button" data-command="underline" title="Underline" aria-label="Underline"><u>U</u></button>
                    <button class="toolbar-btn" type="button" data-command="strike" title="Strikethrough" aria-label="Strikethrough"><s>S</s></button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" type="button" data-command="h2" title="Heading 2">H2</button>
                    <button class="toolbar-btn" type="button" data-command="h3" title="Heading 3">H3</button>
                    <button class="toolbar-btn" type="button" data-command="paragraph" title="Paragraph">P</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" type="button" data-command="bulletList" title="Bullet List">List</button>
                    <button class="toolbar-btn" type="button" data-command="orderedList" title="Numbered List">1. List</button>
                    <button class="toolbar-btn" type="button" data-command="blockquote" title="Quote">Quote</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" type="button" data-command="link" title="Insert Link">Link</button>
                    <button class="toolbar-btn" type="button" data-command="image" title="Insert Image">Image</button>
                    <button class="toolbar-btn" type="button" data-command="cta" title="Insert CTA Button">CTA</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" type="button" data-command="insertTable" title="Insert Table">Table</button>
                    <button class="toolbar-btn" type="button" data-command="addRowAfter" title="Add Row Below">+ Row</button>
                    <button class="toolbar-btn" type="button" data-command="addColAfter" title="Add Column Right">+ Col</button>
                    <button class="toolbar-btn" type="button" data-command="deleteRow" title="Delete Row">- Row</button>
                    <button class="toolbar-btn" type="button" data-command="deleteCol" title="Delete Column">- Col</button>
                    <button class="toolbar-btn toolbar-btn-danger" type="button" data-command="deleteTable" title="Delete Table">Delete Table</button>
                </div>
            </div>

            <!-- Title Input -->
            <div class="title-field">
                <label for="articleTitle">Article title</label>
                <input type="text" id="articleTitle" class="article-title-input" placeholder="Enter article title here..." value={article.title} />
            </div>

            <!-- The Editor Content -->
            <div class="editor-content-wrapper">
                <div id="editorContent" class="tiptap-editor-container"></div>
            </div>
            
            <!-- Hidden Raw Content for initial load -->
            <textarea id="initialContent" style="display:none;">{article.content}</textarea>
        </div>

        <!-- SEO & Settings Sidebar -->
        <aside class="editor-sidebar">
            <div class="settings-header">
                <h2>Article settings</h2>
                <p>Publishing, media, and search metadata.</p>
            </div>

            <div class="sidebar-section facebook-import-section">
                <label for="facebookImportUrl">Import from Facebook URL</label>
                <div class="facebook-import-row">
                    <input type="url" id="facebookImportUrl" class="form-input" placeholder="https://www.facebook.com/..." autocomplete="off" />
                    <button id="btnFacebookImport" class="btn-facebook-import" type="button">Import Draft</button>
                </div>
                <div id="facebookImportStatus" class="facebook-import-status" aria-live="polite"></div>
            </div>

            <div class="sidebar-section">
                <label for="articleSlug">Slug</label>
                <div class="slug-field">
                    <span>/blog/</span>
                    <input type="text" id="articleSlug" class="form-input" value={article.slug} placeholder="article-url-slug" autocomplete="off" />
                </div>
            </div>

            <div class="sidebar-section">
                <label for="articleStatus">Status</label>
                <select id="articleStatus" class="form-select">
                    <option value="draft" selected={article.status === 'draft'}>Draft</option>
                    <option value="review" selected={article.status === 'review'}>Pending Review</option>
                    <option value="approved" selected={article.status === 'approved'}>Approved</option>
                    <option value="published" selected={article.status === 'published'}>Published</option>
                </select>
            </div>

            <div class="sidebar-section">
                <label for="articleCategory">Category</label>
                <div class="category-combo" id="categoryCombo">
                    <input type="text" id="articleCategory" class="form-input" value={article.category} placeholder="Select or type new category..." autocomplete="off" />
                    <div class="category-dropdown" id="categoryDropdown">
                        {categories.map(cat => (
                            <div class="category-option" data-value={cat.name}>{cat.name}</div>
                        ))}
                        <div class="category-new-hint" id="categoryNewHint" style="display:none;">
                            <span class="hint-icon">+</span> Press Enter to add "<span id="newCatName"></span>"
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <label for="featuredImage">Featured Image URL</label>
                <div class="image-upload-row">
                    <input type="text" id="featuredImage" class="form-input" value={article.featured_image_url} placeholder="https://..." />
                    <button id="btnUploadFeatured" class="btn-secondary btn-icon" type="button" title="Upload Image">Upload</button>
                </div>
                <!-- Hidden file input for featured image -->
                <input type="file" id="featuredFileInput" accept="image/*" style="display:none;" />
                {article.featured_image_url && (
                    <img id="featuredImagePreview" src={article.featured_image_url} alt="Preview" class="featured-preview" />
                )}
            </div>

            <div class="sidebar-section ai-autofill-section">
                <button id="btnAiAutofill" class="btn-ai-autofill" type="button">
                    AI Autofill SEO
                </button>
                <div id="aiAutofillStatus" class="ai-status"></div>
            </div>

            <div class="sidebar-section">
                <div class="section-title-with-badge">
                    <label for="seoDescription">SEO Description</label>
                    <span class="char-count" id="seoDescCount">0/160</span>
                </div>
                <textarea id="seoDescription" class="form-textarea" rows="3" placeholder="Meta description for search engines...">{article.seo_description}</textarea>
            </div>

            <div class="sidebar-section">
                <label for="directAnswer">Direct Answer (AI snippet)</label>
                <textarea id="directAnswer" class="form-textarea" rows="2" placeholder="Short answer for top-of-article snippet...">{article.direct_answer}</textarea>
            </div>
            
            <div class="sidebar-section">
                <label for="focusKeyword">Focus Keyword</label>
                <input type="text" id="focusKeyword" class="form-input" value={article.focus_keyword} placeholder="Primary SEO keyword" />
            </div>
            
            <input type="hidden" id="articleId" value={articleId || ''} />
        </aside>
    </div>

    <div id="previewModal" class="preview-modal" role="dialog" aria-modal="true" aria-labelledby="previewTitle" hidden>
        <div class="preview-backdrop" data-preview-close></div>
        <div class="preview-dialog">
            <div class="preview-toolbar">
                <div>
                    <div class="editor-kicker">Preview</div>
                    <h2 id="previewTitle">Article preview</h2>
                </div>
                <button id="btnClosePreview" class="btn-secondary" type="button">Close</button>
            </div>
            <article class="preview-article">
                <div id="previewMeta" class="preview-meta"></div>
                <h1 id="previewArticleTitle"></h1>
                <img id="previewImage" class="preview-image" alt="" hidden />
                <div id="previewDirectAnswer" class="preview-direct-answer" hidden></div>
                <div id="previewBody" class="preview-body"></div>
            </article>
        </div>
    </div>
</AdminLayout>

<style is:global>
    .editor-workspace-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        margin-bottom: 20px;
    }

    .editor-heading {
        min-width: 0;
    }

    .editor-kicker {
        color: var(--text-muted);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .editor-heading h1 {
        font-size: 1.5rem;
        line-height: 1.2;
        margin: 0;
    }

    .editor-header-actions {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 10px;
        flex-wrap: wrap;
    }

    .editor-container {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 360px;
        gap: 24px;
        min-height: calc(100vh - 172px);
    }

    /* Main Editor */
    .editor-main {
        min-width: 0;
        display: flex;
        flex-direction: column;
        background-color: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 18px 45px rgba(2, 6, 23, 0.18);
    }

    .editor-toolbar {
        display: flex;
        align-items: center;
        padding: 10px 12px;
        background-color: rgba(15, 23, 42, 0.72);
        border-bottom: 1px solid var(--border);
        gap: 8px;
        flex-wrap: wrap;
        position: sticky;
        top: 0;
        z-index: 3;
        backdrop-filter: blur(10px);
    }

    .toolbar-group {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
    }

    .toolbar-divider {
        width: 1px;
        height: 24px;
        background-color: var(--border);
        margin: 0 4px;
    }

    .toolbar-btn {
        min-height: 34px;
        background: transparent;
        border: 1px solid rgba(148, 163, 184, 0.14);
        color: var(--text-main);
        padding: 6px 9px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.84rem;
        line-height: 1;
        transition: background-color 0.2s, border-color 0.2s, color 0.2s;
    }

    .toolbar-btn:hover {
        background-color: var(--bg-surface-hover);
        border-color: rgba(148, 163, 184, 0.35);
    }

    .toolbar-btn:focus-visible,
    .btn-ai-autofill:focus-visible,
    .btn-facebook-import:focus-visible,
    .form-input:focus-visible,
    .form-select:focus-visible,
    .form-textarea:focus-visible,
    .article-title-input:focus-visible {
        outline: 2px solid var(--primary);
        outline-offset: 2px;
    }
    
    .toolbar-btn.is-active {
        background-color: rgba(59, 130, 246, 0.2);
        color: var(--primary);
        border-color: rgba(59, 130, 246, 0.48);
    }

    .toolbar-btn-danger {
        color: #fca5a5;
    }

    .title-field {
        padding: 28px 36px 16px;
        border-bottom: 1px solid rgba(51, 65, 85, 0.65);
    }

    .title-field label {
        display: block;
        color: var(--text-muted);
        font-size: 0.78rem;
        font-weight: 700;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0;
    }

    .article-title-input {
        width: 100%;
        font-size: 2.15rem;
        line-height: 1.18;
        font-weight: 700;
        padding: 0;
        background: transparent;
        border: none;
        color: var(--text-main);
        outline: none;
        font-family: inherit;
    }

    .article-title-input::placeholder {
        color: var(--text-muted);
    }

    .editor-content-wrapper {
        flex-grow: 1;
        overflow-y: auto;
        padding: 28px 36px 44px;
    }

    /* Target the automatically generated TipTap element */
    .tiptap-editor-container .ProseMirror {
        min-height: 560px;
        max-width: 760px;
        outline: none;
        font-size: 1.05rem;
        line-height: 1.8;
        color: #e2e8f0;
        margin: 0 auto;
    }

    .tiptap-editor-container .ProseMirror p.is-editor-empty:first-child::before {
        color: var(--text-muted);
        content: attr(data-placeholder);
        float: left;
        height: 0;
        pointer-events: none;
    }
    
    .tiptap-editor-container .ProseMirror h1 { font-size: 2rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; }
    .tiptap-editor-container .ProseMirror h2 { font-size: 1.6rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror h3 { font-size: 1.3rem; margin-top: 1.5rem; margin-bottom: 0.75rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror h4 { font-size: 1.1rem; margin-top: 1.25rem; margin-bottom: 0.5rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror p { margin-bottom: 1rem; }

    .tiptap-editor-container .ProseMirror blockquote {
        border-left: 4px solid var(--primary);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--text-muted);
        font-style: italic;
    }

    .tiptap-editor-container .ProseMirror img {
        max-width: 100%;
        border-radius: 8px;
        margin: 1.5rem 0;
        height: auto;
    }

    .tiptap-editor-container .ProseMirror a {
        color: var(--primary);
        text-decoration: underline;
    }

    /* Lists */
    .tiptap-editor-container .ProseMirror ul,
    .tiptap-editor-container .ProseMirror ol {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .tiptap-editor-container .ProseMirror ul { list-style: disc; }
    .tiptap-editor-container .ProseMirror ol { list-style: decimal; }

    .tiptap-editor-container .ProseMirror li {
        margin-bottom: 0.35rem;
    }

    .tiptap-editor-container .ProseMirror li p {
        margin-bottom: 0.25rem;
    }

    /* Tables */
    .tiptap-editor-container .ProseMirror table {
        border-collapse: collapse;
        width: 100%;
        margin: 1.5rem 0;
        font-size: 0.9rem;
        table-layout: fixed;
        overflow: hidden;
    }

    .tiptap-editor-container .ProseMirror th,
    .tiptap-editor-container .ProseMirror td {
        border: 1px solid var(--border);
        padding: 10px 14px;
        text-align: left;
        vertical-align: top;
        position: relative;
        min-width: 80px;
    }

    .tiptap-editor-container .ProseMirror th {
        background-color: rgba(59, 130, 246, 0.1);
        font-weight: 600;
        color: var(--text-main);
    }

    .tiptap-editor-container .ProseMirror td {
        background-color: var(--bg-surface);
    }

    /* Selected table cell highlight */
    .tiptap-editor-container .ProseMirror .selectedCell::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(99, 102, 241, 0.15);
        pointer-events: none;
        z-index: 2;
    }

    /* Column resize handle */
    .tiptap-editor-container .ProseMirror .column-resize-handle {
        position: absolute;
        right: -2px;
        top: 0;
        bottom: -2px;
        width: 4px;
        background-color: var(--primary);
        pointer-events: none;
    }

    .tiptap-editor-container .ProseMirror.resize-cursor {
        cursor: col-resize;
    }

    /* Table paragraph margin fix */
    .tiptap-editor-container .ProseMirror td p,
    .tiptap-editor-container .ProseMirror th p {
        margin-bottom: 0;
    }

    /* Code */
    .tiptap-editor-container .ProseMirror code {
        background: rgba(99, 102, 241, 0.15);
        color: #c4b5fd;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: 'Fira Code', monospace;
    }

    .tiptap-editor-container .ProseMirror pre {
        background: #0f172a;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
        margin: 1rem 0;
        overflow-x: auto;
    }

    .tiptap-editor-container .ProseMirror pre code {
        background: none;
        padding: 0;
        color: #e2e8f0;
    }

    /* Horizontal Rule */
    .tiptap-editor-container .ProseMirror hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
    }

    /* Strong / Emphasis */
    .tiptap-editor-container .ProseMirror strong { font-weight: 700; color: #f1f5f9; }
    .tiptap-editor-container .ProseMirror em { font-style: italic; }


    /* Sidebar */
    .editor-sidebar {
        min-width: 0;
        background-color: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 18px;
        overflow-y: auto;
        max-height: calc(100vh - 172px);
        position: sticky;
        top: 84px;
    }

    .settings-header {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }

    .settings-header h2 {
        font-size: 1rem;
        margin: 0;
    }

    .settings-header p {
        margin: 0;
        color: var(--text-muted);
        font-size: 0.86rem;
        line-height: 1.45;
    }

    .save-status {
        font-size: 0.84rem;
        color: var(--text-muted);
        min-width: 130px;
        text-align: right;
    }

    .sidebar-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sidebar-section label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .form-input, .form-select, .form-textarea {
        width: 100%;
        background-color: var(--bg-base);
        border: 1px solid var(--border);
        color: var(--text-main);
        padding: 11px 12px;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
        font-family: inherit;
    }

    .form-input:focus, .form-select:focus, .form-textarea:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
    }

    .form-textarea {
        resize: vertical;
    }

    .slug-field {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--bg-base);
    }

    .slug-field span {
        color: var(--text-muted);
        font-size: 0.86rem;
        padding: 0 0 0 12px;
        white-space: nowrap;
    }

    .slug-field .form-input {
        border: 0;
        background: transparent;
        padding-left: 2px;
    }

    .slug-field .form-input:focus {
        box-shadow: none;
    }

    .slug-field:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.12);
    }

    .section-title-with-badge {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .char-count {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .image-upload-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 8px;
    }

    .btn-icon {
        min-height: 42px;
        white-space: nowrap;
    }

    .featured-preview {
        width: 100%;
        height: 160px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid var(--border);
        margin-top: 8px;
    }

    .facebook-import-section {
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }

    .facebook-import-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 8px;
    }

    .btn-facebook-import {
        width: 100%;
        min-height: 42px;
        padding: 10px 14px;
        background: #0f766e;
        color: #ffffff;
        border: 0;
        border-radius: 6px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        font-family: inherit;
        transition: background-color 0.2s, transform 0.2s;
    }

    .btn-facebook-import:hover {
        background: #0d9488;
        transform: translateY(-1px);
    }

    .btn-facebook-import:disabled {
        opacity: 0.72;
        cursor: wait;
        transform: none;
    }

    .facebook-import-status {
        color: var(--text-muted);
        font-size: 0.8rem;
        line-height: 1.4;
        min-height: 1.2em;
    }

    @media (max-width: 1024px) {
        .editor-workspace-header {
            flex-direction: column;
            align-items: stretch;
        }

        .editor-header-actions {
            justify-content: flex-start;
        }

        .editor-container {
            grid-template-columns: 1fr;
            height: auto;
            min-height: 0;
        }

        .editor-sidebar {
            width: 100%;
            max-height: none;
            position: static;
        }
    }

    .preview-modal[hidden] {
        display: none;
    }

    .preview-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: grid;
        place-items: center;
        padding: 28px;
    }

    .preview-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(2, 6, 23, 0.78);
    }

    .preview-dialog {
        position: relative;
        width: min(920px, 100%);
        max-height: min(860px, calc(100vh - 56px));
        background: #f8fafc;
        color: #0f172a;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.36);
        display: flex;
        flex-direction: column;
    }

    .preview-toolbar {
        display: flex;
        justify-content: space-between;
