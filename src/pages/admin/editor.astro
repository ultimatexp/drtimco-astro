---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { neon } from '@neondatabase/serverless';

const DATABASE_URL = import.meta.env.NEON_DATABASE_URL;

// Parse ID from URL
let articleId = Astro.url.searchParams.get('id');
let article = {
    title: '',
    content: '',
    status: 'draft',
    category: '',
    tags: [],
    seo_description: '',
    direct_answer: '',
    focus_keyword: '',
    featured_image_url: ''
};

let categories = [];

// Fetch categories and existing article
if (DATABASE_URL) {
    try {
        const sql = neon(DATABASE_URL);
        
        // Load categories
        categories = await sql`SELECT id, name, slug FROM categories ORDER BY name ASC`;
        
        // Load existing article if ID provided
        if (articleId) {
            const [existing] = await sql`SELECT * FROM article_drafts WHERE id = ${articleId}`;
            if (existing) {
                article = {
                    ...existing,
                    tags: existing.tags || []
                };
            } else {
                articleId = null;
            }
        }
    } catch (e) {
        console.error("Error fetching data:", e);
    }
}
---

<AdminLayout title={articleId ? "Edit Article" : "New Article"}>
    <div class="editor-container">
        <!-- Editor Main Area -->
        <div class="editor-main">
            <!-- Toolbar -->
            <div class="editor-toolbar" id="toolbar">
                <div class="toolbar-group">
                    <button class="toolbar-btn" data-command="bold" title="Bold"><b>B</b></button>
                    <button class="toolbar-btn" data-command="italic" title="Italic"><i>I</i></button>
                    <button class="toolbar-btn" data-command="underline" title="Underline"><u>U</u></button>
                    <button class="toolbar-btn" data-command="strike" title="Strikethrough"><s>S</s></button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" data-command="h2" title="Heading 2">H2</button>
                    <button class="toolbar-btn" data-command="h3" title="Heading 3">H3</button>
                    <button class="toolbar-btn" data-command="paragraph" title="Paragraph">P</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" data-command="bulletList" title="Bullet List">• List</button>
                    <button class="toolbar-btn" data-command="orderedList" title="Numbered List">1. List</button>
                    <button class="toolbar-btn" data-command="blockquote" title="Quote">""</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" data-command="link" title="Insert Link">🔗 Link</button>
                    <button class="toolbar-btn" data-command="image" title="Insert Image">🖼️ Image</button>
                    <button class="toolbar-btn" data-command="cta" title="Insert CTA Button">🎯 CTA</button>
                </div>
                <div class="toolbar-divider"></div>
                <div class="toolbar-group">
                    <button class="toolbar-btn" data-command="insertTable" title="Insert Table">▦ Table</button>
                    <button class="toolbar-btn" data-command="addRowAfter" title="Add Row Below">+ Row</button>
                    <button class="toolbar-btn" data-command="addColAfter" title="Add Column Right">+ Col</button>
                    <button class="toolbar-btn" data-command="deleteRow" title="Delete Row">− Row</button>
                    <button class="toolbar-btn" data-command="deleteCol" title="Delete Column">− Col</button>
                    <button class="toolbar-btn" data-command="deleteTable" title="Delete Table">🗑 Table</button>
                </div>
            </div>

            <!-- Title Input -->
            <input type="text" id="articleTitle" class="article-title-input" placeholder="Enter article title here..." value={article.title} />

            <!-- The Editor Content -->
            <div class="editor-content-wrapper">
                <div id="editorContent" class="tiptap-editor-container"></div>
            </div>
            
            <!-- Hidden Raw Content for initial load -->
            <textarea id="initialContent" style="display:none;">{article.content}</textarea>
        </div>

        <!-- SEO & Settings Sidebar -->
        <aside class="editor-sidebar">
            <div class="sidebar-header">
                <h3>Publish Settings</h3>
                <div class="action-buttons">
                    <button id="btnSaveDraft" class="btn-secondary">Save Draft</button>
                    <button id="btnPublish" class="btn-primary">Publish</button>
                </div>
                <div id="saveStatus" class="save-status"></div>
            </div>

            <div class="sidebar-section">
                <label>Status</label>
                <select id="articleStatus" class="form-select">
                    <option value="draft" selected={article.status === 'draft'}>Draft</option>
                    <option value="review" selected={article.status === 'review'}>Pending Review</option>
                    <option value="approved" selected={article.status === 'approved'}>Approved</option>
                    <option value="published" selected={article.status === 'published'}>Published</option>
                </select>
            </div>

            <div class="sidebar-section">
                <label>Category</label>
                <div class="category-combo" id="categoryCombo">
                    <input type="text" id="articleCategory" class="form-input" value={article.category} placeholder="Select or type new category..." autocomplete="off" />
                    <div class="category-dropdown" id="categoryDropdown">
                        {categories.map(cat => (
                            <div class="category-option" data-value={cat.name}>{cat.name}</div>
                        ))}
                        <div class="category-new-hint" id="categoryNewHint" style="display:none;">
                            <span class="hint-icon">+</span> Press Enter to add "<span id="newCatName"></span>"
                        </div>
                    </div>
                </div>
            </div>

            <div class="sidebar-section">
                <label>Featured Image URL</label>
                <div class="image-upload-row">
                    <input type="text" id="featuredImage" class="form-input" value={article.featured_image_url} placeholder="https://..." />
                    <button id="btnUploadFeatured" class="btn-secondary btn-icon" title="Upload Image">⬆️</button>
                </div>
                <!-- Hidden file input for featured image -->
                <input type="file" id="featuredFileInput" accept="image/*" style="display:none;" />
                {article.featured_image_url && (
                    <img id="featuredImagePreview" src={article.featured_image_url} alt="Preview" class="featured-preview" />
                )}
            </div>

            <div class="sidebar-section ai-autofill-section">
                <button id="btnAiAutofill" class="btn-ai-autofill" type="button">
                    <span class="ai-icon">✨</span> AI Autofill SEO
                </button>
                <div id="aiAutofillStatus" class="ai-status"></div>
            </div>

            <div class="sidebar-section">
                <div class="section-title-with-badge">
                    <label>SEO Description</label>
                    <span class="char-count" id="seoDescCount">0/160</span>
                </div>
                <textarea id="seoDescription" class="form-textarea" rows="3" placeholder="Meta description for search engines...">{article.seo_description}</textarea>
            </div>

            <div class="sidebar-section">
                <label>Direct Answer (AI snippet)</label>
                <textarea id="directAnswer" class="form-textarea" rows="2" placeholder="Short answer for top-of-article snippet...">{article.direct_answer}</textarea>
            </div>
            
            <div class="sidebar-section">
                <label>Focus Keyword</label>
                <input type="text" id="focusKeyword" class="form-input" value={article.focus_keyword} placeholder="Primary SEO keyword" />
            </div>
            
            <input type="hidden" id="articleId" value={articleId || ''} />
        </aside>
    </div>
</AdminLayout>

<style is:global>
    .editor-container {
        display: flex;
        gap: 24px;
        height: calc(100vh - 140px); /* Fill remaining space minus topbar and padding */
    }

    /* Main Editor */
    .editor-main {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background-color: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
    }

    .editor-toolbar {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        background-color: var(--bg-surface);
        border-bottom: 1px solid var(--border);
        gap: 8px;
        flex-wrap: wrap;
    }

    .toolbar-group {
        display: flex;
        gap: 4px;
    }

    .toolbar-divider {
        width: 1px;
        height: 24px;
        background-color: var(--border);
        margin: 0 4px;
    }

    .toolbar-btn {
        background: transparent;
        border: 1px solid transparent;
        color: var(--text-main);
        padding: 6px 10px;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .toolbar-btn:hover {
        background-color: var(--bg-surface-hover);
    }
    
    .toolbar-btn.is-active {
        background-color: rgba(59, 130, 246, 0.2);
        color: var(--primary);
    }

    .article-title-input {
        width: 100%;
        font-size: 2rem;
        font-weight: 700;
        padding: 24px 32px 12px;
        background: transparent;
        border: none;
        color: var(--text-main);
        outline: none;
        font-family: inherit;
    }

    .article-title-input::placeholder {
        color: var(--text-muted);
    }

    .editor-content-wrapper {
        flex-grow: 1;
        overflow-y: auto;
        padding: 0 32px 32px;
    }

    /* Target the automatically generated TipTap element */
    .tiptap-editor-container .ProseMirror {
        min-height: 300px;
        outline: none;
        font-size: 1.05rem;
        line-height: 1.8;
        color: #e2e8f0;
    }

    .tiptap-editor-container .ProseMirror p.is-editor-empty:first-child::before {
        color: var(--text-muted);
        content: attr(data-placeholder);
        float: left;
        height: 0;
        pointer-events: none;
    }
    
    .tiptap-editor-container .ProseMirror h1 { font-size: 2rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 700; }
    .tiptap-editor-container .ProseMirror h2 { font-size: 1.6rem; margin-top: 2rem; margin-bottom: 1rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror h3 { font-size: 1.3rem; margin-top: 1.5rem; margin-bottom: 0.75rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror h4 { font-size: 1.1rem; margin-top: 1.25rem; margin-bottom: 0.5rem; font-weight: 600; }
    .tiptap-editor-container .ProseMirror p { margin-bottom: 1rem; }

    .tiptap-editor-container .ProseMirror blockquote {
        border-left: 4px solid var(--primary);
        padding-left: 1rem;
        margin: 1rem 0;
        color: var(--text-muted);
        font-style: italic;
    }

    .tiptap-editor-container .ProseMirror img {
        max-width: 100%;
        border-radius: 8px;
        margin: 1.5rem 0;
        height: auto;
    }

    .tiptap-editor-container .ProseMirror a {
        color: var(--primary);
        text-decoration: underline;
    }

    /* Lists */
    .tiptap-editor-container .ProseMirror ul,
    .tiptap-editor-container .ProseMirror ol {
        padding-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .tiptap-editor-container .ProseMirror ul { list-style: disc; }
    .tiptap-editor-container .ProseMirror ol { list-style: decimal; }

    .tiptap-editor-container .ProseMirror li {
        margin-bottom: 0.35rem;
    }

    .tiptap-editor-container .ProseMirror li p {
        margin-bottom: 0.25rem;
    }

    /* Tables */
    .tiptap-editor-container .ProseMirror table {
        border-collapse: collapse;
        width: 100%;
        margin: 1.5rem 0;
        font-size: 0.9rem;
        table-layout: fixed;
        overflow: hidden;
    }

    .tiptap-editor-container .ProseMirror th,
    .tiptap-editor-container .ProseMirror td {
        border: 1px solid var(--border);
        padding: 10px 14px;
        text-align: left;
        vertical-align: top;
        position: relative;
        min-width: 80px;
    }

    .tiptap-editor-container .ProseMirror th {
        background-color: rgba(59, 130, 246, 0.1);
        font-weight: 600;
        color: var(--text-main);
    }

    .tiptap-editor-container .ProseMirror td {
        background-color: var(--bg-surface);
    }

    /* Selected table cell highlight */
    .tiptap-editor-container .ProseMirror .selectedCell::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(99, 102, 241, 0.15);
        pointer-events: none;
        z-index: 2;
    }

    /* Column resize handle */
    .tiptap-editor-container .ProseMirror .column-resize-handle {
        position: absolute;
        right: -2px;
        top: 0;
        bottom: -2px;
        width: 4px;
        background-color: var(--primary);
        pointer-events: none;
    }

    .tiptap-editor-container .ProseMirror.resize-cursor {
        cursor: col-resize;
    }

    /* Table paragraph margin fix */
    .tiptap-editor-container .ProseMirror td p,
    .tiptap-editor-container .ProseMirror th p {
        margin-bottom: 0;
    }

    /* Code */
    .tiptap-editor-container .ProseMirror code {
        background: rgba(99, 102, 241, 0.15);
        color: #c4b5fd;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
        font-family: 'Fira Code', monospace;
    }

    .tiptap-editor-container .ProseMirror pre {
        background: #0f172a;
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
        margin: 1rem 0;
        overflow-x: auto;
    }

    .tiptap-editor-container .ProseMirror pre code {
        background: none;
        padding: 0;
        color: #e2e8f0;
    }

    /* Horizontal Rule */
    .tiptap-editor-container .ProseMirror hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2rem 0;
    }

    /* Strong / Emphasis */
    .tiptap-editor-container .ProseMirror strong { font-weight: 700; color: #f1f5f9; }
    .tiptap-editor-container .ProseMirror em { font-style: italic; }


    /* Sidebar */
    .editor-sidebar {
        width: 320px;
        flex-shrink: 0;
        background-color: var(--bg-surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 24px;
        display: flex;
        flex-direction: column;
        gap: 24px;
        overflow-y: auto;
    }

    .sidebar-header {
        display: flex;
        flex-direction: column;
        gap: 12px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border);
    }

    .sidebar-header h3 {
        font-size: 1.1rem;
        margin: 0;
    }

    .action-buttons {
        display: flex;
        gap: 10px;
    }

    .action-buttons button {
        flex: 1;
        justify-content: center;
    }

    .save-status {
        font-size: 0.8rem;
        color: var(--text-muted);
        text-align: center;
        min-height: 1.2em;
    }

    .sidebar-section {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .sidebar-section label {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .form-input, .form-select, .form-textarea {
        width: 100%;
        background-color: var(--bg-base);
        border: 1px solid var(--border);
        color: var(--text-main);
        padding: 10px;
        border-radius: 6px;
        font-size: 0.9rem;
        outline: none;
        transition: border-color 0.2s;
        font-family: inherit;
    }

    .form-input:focus, .form-select:focus, .form-textarea:focus {
        border-color: var(--primary);
    }

    .form-textarea {
        resize: vertical;
    }

    .section-title-with-badge {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .char-count {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .image-upload-row {
        display: flex;
