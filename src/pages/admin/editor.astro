    /* AI Autofill Button */
    .ai-autofill-section {
        padding: 16px 0;
        border-bottom: 1px solid var(--border);
    }

    .btn-ai-autofill {
        width: 100%;
        padding: 12px 16px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7);
        color: white;
        border: none;
        border-radius: 8px;
