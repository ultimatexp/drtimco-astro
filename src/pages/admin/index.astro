---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { neon } from '@neondatabase/serverless';

// Auth is handled by AdminLayout
const DATABASE_URL = import.meta.env.NEON_DATABASE_URL;
let stats = { total: 0, published: 0, pending: 0, draft: 0 };
let recentActivity: any[] = [];

if (DATABASE_URL) {
    try {
        const sql = neon(DATABASE_URL);
        
        // Get counts
        const counts = await sql`
            SELECT status, COUNT(*) as count 
            FROM article_drafts 
            GROUP BY status
        `;
        
        counts.forEach(row => {
            const count = parseInt(row.count, 10);
            stats.total += count;
            if (row.status === 'published') stats.published += count;
            if (row.status === 'review') stats.pending += count;
            if (row.status === 'draft') stats.draft += count;
        });

        // Get recent activity
        recentActivity = await sql`
            SELECT id, title, status, created_at, reviewed_at
            FROM article_drafts
            ORDER BY GREATEST(created_at, reviewed_at) DESC NULLS LAST
            LIMIT 5
        `;
    } catch (e) {
        console.error("Dashboard stats error:", e);
    }
}
---

<AdminLayout title="Dashboard">
    <div class="dashboard-header">
        <h1 class="page-title">Welcome back, Dr. Tim</h1>
        <p class="text-muted">Here's what's happening with your content today.</p>
    </div>

    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card card">
            <div class="stat-icon bg-primary-light">📝</div>
            <div class="stat-content">
                <div class="stat-value">{stats.total}</div>
                <div class="stat-label">Total Articles</div>
            </div>
        </div>
        
        <div class="stat-card card">
            <div class="stat-icon bg-success-light">✅</div>
            <div class="stat-content">
                <div class="stat-value">{stats.published}</div>
                <div class="stat-label">Published</div>
            </div>
        </div>

        <div class="stat-card card">
            <div class="stat-icon bg-warning-light">⏳</div>
            <div class="stat-content">
                <div class="stat-value">{stats.pending}</div>
                <div class="stat-label">Pending Review</div>
            </div>
        </div>

        <div class="stat-card card">
            <div class="stat-icon bg-gray-light">✍️</div>
            <div class="stat-content">
                <div class="stat-value">{stats.draft}</div>
                <div class="stat-label">Drafts</div>
            </div>
        </div>
    </div>

    <!-- Quick Actions & Recent -->
    <div class="dashboard-cols">
        <!-- Recent Activity -->
        <div class="card recent-activity">
            <div class="section-header">
                <h2>Recent Activity</h2>
                <a href="/admin/articles" class="btn-text">View All →</a>
            </div>
            
            {recentActivity.length > 0 ? (
                <div class="activity-list">
                    {recentActivity.map(item => (
                        <div class="activity-item">
                            <div class="activity-indicator" data-status={item.status}></div>
                            <div class="activity-details">
                                <a href={`/admin/editor?id=${item.id}`} class="activity-title">{item.title}</a>
                                <div class="activity-meta">
                                    Status: <span class="badge" data-status={item.status}>{item.status}</span> 
                                    • {new Date(item.reviewed_at || item.created_at).toLocaleDateString('th-TH')}
                                </div>
                            </div>
                            <a href={`/admin/editor?id=${item.id}`} class="btn-icon" title="Edit">✏️</a>
                        </div>
                    ))}
                </div>
            ) : (
                <p class="empty-state">No recent activity found.</p>
            )}
        </div>

        <!-- Quick Actions -->
        <div class="card quick-actions">
            <div class="section-header">
                <h2>Quick Actions</h2>
            </div>
            <div class="action-buttons">
                <a href="/admin/editor" class="action-btn">
                    <span class="action-icon">✨</span>
                    <span class="action-text">Create AI Article</span>
                </a>
                <a href="/admin/editor?mode=manual" class="action-btn">
                    <span class="action-icon">✍️</span>
                    <span class="action-text">Write Manually</span>
                </a>
                <a href="/admin/media" class="action-btn">
                    <span class="action-icon">🖼️</span>
                    <span class="action-text">Upload Media</span>
                </a>
                <a href="/admin/categories" class="action-btn">
                    <span class="action-icon">🏷️</span>
                    <span class="action-text">Manage Categories</span>
                </a>
            </div>
        </div>
    </div>

</AdminLayout>

<style>
    .dashboard-header {
        margin-bottom: 32px;
    }
    
    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 4px;
        color: var(--text-main);
    }
    
    .text-muted {
        color: var(--text-muted);
    }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 32px;
    }

    .stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 24px;
    }

    .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }

    .bg-primary-light { background: rgba(59, 130, 246, 0.1); }
    .bg-success-light { background: rgba(34, 197, 94, 0.1); }
    .bg-warning-light { background: rgba(245, 158, 11, 0.1); }
    .bg-gray-light    { background: rgba(148, 163, 184, 0.1); }

    .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .stat-label {
        font-size: 0.875rem;
        color: var(--text-muted);
    }

    .dashboard-cols {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 24px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .section-header h2 {
        font-size: 1.1rem;
        font-weight: 600;
    }

    .btn-text {
        color: var(--primary);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .btn-text:hover {
        text-decoration: underline;
    }

    .activity-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .activity-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
    }

    .activity-item:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .activity-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .activity-indicator[data-status="published"] { background: var(--success); }
    .activity-indicator[data-status="review"]    { background: var(--warning); }
    .activity-indicator[data-status="draft"]     { background: var(--text-muted); }
    .activity-indicator[data-status="rejected"]  { background: var(--danger); }

    .activity-details {
        flex-grow: 1;
        min-width: 0;
    }

    .activity-title {
        display: block;
        color: var(--text-main);
        text-decoration: none;
        font-weight: 500;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .activity-title:hover {
        color: var(--primary);
    }

    .activity-meta {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 8px;
    }
    
    .badge {
        font-size: 0.7rem;
        padding: 2px 6px;
        border-radius: 4px;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }
    .badge[data-status="published"] { background: rgba(34, 197, 94, 0.1); color: var(--success); }
    .badge[data-status="review"]    { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
    .badge[data-status="draft"]     { background: rgba(148, 163, 184, 0.1); color: var(--text-muted); }
    .badge[data-status="rejected"]  { background: rgba(239, 68, 68, 0.1); color: var(--danger); }

    .btn-icon {
        color: var(--text-muted);
        text-decoration: none;
        padding: 6px;
        border-radius: 6px;
        transition: background-color 0.2s;
    }

    .btn-icon:hover {
        background-color: var(--bg-base);
    }

    .empty-state {
        color: var(--text-muted);
        text-align: center;
        padding: 32px 0;
        font-size: 0.875rem;
    }

    .action-buttons {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background-color: var(--bg-base);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-main);
        text-decoration: none;
        transition: all 0.2s;
    }

    .action-btn:hover {
        border-color: var(--primary);
        background-color: rgba(59, 130, 246, 0.05);
    }

    .action-text {
        font-weight: 500;
        font-size: 0.9rem;
    }

    @media (max-width: 1024px) {
        .dashboard-cols {
            grid-template-columns: 1fr;
        }
    }
</style>
