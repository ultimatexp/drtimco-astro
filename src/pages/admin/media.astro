---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Media Library">
    <div class="page-header">
        <div class="header-content">
            <h1>Media Library</h1>
            <p class="text-muted">Manage your uploaded images directly on the CDN.</p>
        </div>
        <div class="header-actions">
            <button class="btn-primary" id="uploadBtn">⬆️ Upload File</button>
            <input type="file" id="fileInput" accept="image/*" style="display: none;" multiple />
        </div>
    </div>

    <!-- Upload Progress -->
    <div class="card upload-card" id="uploadProgressCard" style="display: none;">
        <h3>Uploading...</h3>
        <div class="progress-bar-bg">
            <div class="progress-bar-fill" id="progressBar"></div>
        </div>
        <p class="text-muted" id="uploadStatusText">Starting upload...</p>
    </div>

    <!-- Media Grid -->
    <div class="card">
        <div id="mediaLoading" class="loading-state">
            <div class="spinner"></div>
            <p>Loading media library from FTP...</p>
        </div>
        
        <div id="mediaGrid" class="media-grid" style="display: none;">
            <!-- Rendered by JS -->
        </div>

        <div id="mediaEmpty" class="empty-state" style="display: none;">
            <div class="empty-icon">🖼️</div>
            <h3>No media found</h3>
            <p>Upload some images to see them here.</p>
        </div>
    </div>
</AdminLayout>

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .page-header h1 {
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.95rem;
    }

    .upload-card {
        margin-bottom: 24px;
        background-color: rgba(59, 130, 246, 0.05);
        border: 1px solid rgba(59, 130, 246, 0.2);
    }
    
    .progress-bar-bg {
        width: 100%;
        height: 8px;
        background-color: var(--border);
        border-radius: 4px;
        margin: 12px 0;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        width: 0%;
        background-color: var(--primary);
        transition: width 0.3s ease;
    }

    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 64px 24px;
        gap: 16px;
        color: var(--text-muted);
    }

    .spinner {
        border: 4px solid rgba(0, 0, 0, 0.1);
        border-left-color: var(--primary);
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    .media-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 24px;
        padding: 8px;
    }

    /* Keep the images clean and square */
    :global(.media-item) {
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        background-color: var(--bg-base);
        transition: transform 0.2s, box-shadow 0.2s;
        cursor: pointer;
        position: relative;
    }

    :global(.media-item:hover) {
        transform: translateY(-2px);
        box-shadow: var(--shadow);
    }

    :global(.media-preview) {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        background-color: var(--bg-surface);
    }

    :global(.media-info) {
        padding: 12px;
        font-size: 0.8rem;
    }

    :global(.media-name) {
        font-weight: 500;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text-main);
    }

    :global(.media-meta) {
        display: flex;
        justify-content: space-between;
        color: var(--text-muted);
    }

    :global(.media-actions) {
        position: absolute;
        top: 8px;
        right: 8px;
        display: flex;
        gap: 4px;
        opacity: 0;
        transition: opacity 0.2s;
    }

    :global(.media-item:hover .media-actions) {
        opacity: 1;
    }

    :global(.media-action-btn) {
        background: rgba(255, 255, 255, 0.9);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 4px 8px;
        font-size: 0.8rem;
        cursor: pointer;
        color: var(--text-main);
        transition: background 0.2s;
    }
    
    :global(.media-action-btn:hover) {
        background: #fff;
        color: var(--primary);
    }

    .empty-state {
        text-align: center;
        padding: 64px 24px;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 16px;
        opacity: 0.5;
    }
</style>

<script>
    const getCookie = (name) => {
        const value = `; ${document.cookie}`;
        const parts = value.split(`; ${name}=`);
        if (parts.length === 2) return parts.pop().split(';').shift();
    }

    const loadMedia = async () => {
        try {
            const res = await fetch('/api/admin/media');
            const data = await res.json();
            
            document.getElementById('mediaLoading').style.display = 'none';

            if (!data.success) {
                alert('Failed to load media: ' + data.error);
                return;
            }

            if (data.files.length === 0) {
                document.getElementById('mediaEmpty').style.display = 'block';
                return;
            }

            const grid = document.getElementById('mediaGrid');
            grid.innerHTML = '';
            grid.style.display = 'grid';

            data.files.forEach(file => {
                const isImage = file.name.match(/\.(jpg|jpeg|png|gif|webp|svg)$/i);
                
                const formatSize = (bytes) => {
                    const k = 1024;
                    if (bytes < k) return bytes + ' B';
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(1)) + ' ' + ['B', 'KB', 'MB', 'GB'][i];
                };

                const div = document.createElement('div');
                div.className = 'media-item';
                div.innerHTML = `
                    <div class="media-actions">
                        <button class="media-action-btn copy-btn" data-url="${file.url}" title="Copy URL">📋</button>
                        <a href="${file.url}" target="_blank" class="media-action-btn" title="View">👁️</a>
                    </div>
                    ${isImage 
                        ? `<img src="${file.url}" alt="${file.name}" class="media-preview" loading="lazy" />`
                        : `<div class="media-preview" style="display:flex;align-items:center;justify-content:center;font-size:2rem;color:var(--text-muted)">📄</div>`
                    }
                    <div class="media-info">
                        <div class="media-name" title="${file.name}">${file.name}</div>
                        <div class="media-meta">
                            <span>${formatSize(file.size)}</span>
                            <span>${new Date(file.date).toLocaleDateString()}</span>
                        </div>
                    </div>
                `;
                grid.appendChild(div);
            });

            // Add copy listener
            document.querySelectorAll('.copy-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    const url = e.currentTarget.getAttribute('data-url');
                    navigator.clipboard.writeText(url).then(() => {
                        const originalText = e.currentTarget.textContent;
                        e.currentTarget.textContent = '✅';
                        setTimeout(() => e.currentTarget.textContent = originalText, 1000);
                    });
                });
            });

        } catch (err) {
            console.error(err);
            alert('Network error loading media map.');
        }
    };

    // Upload Logic
    const uploadBtn = document.getElementById('uploadBtn');
    const fileInput = document.getElementById('fileInput');
    const uploadCard = document.getElementById('uploadProgressCard');
    const progressBar = document.getElementById('progressBar');
    const uploadStatusText = document.getElementById('uploadStatusText');

    uploadBtn.addEventListener('click', () => fileInput.click());

    fileInput.addEventListener('change', async (e) => {
        const files = Array.from(e.target.files);
        if (files.length === 0) return;

        uploadCard.style.display = 'block';
        let successCount = 0;

        for (let i = 0; i < files.length; i++) {
            const file = files[i];
            uploadStatusText.textContent = `Uploading ${file.name} (${i + 1}/${files.length})...`;
            progressBar.style.width = `${((i) / files.length) * 100}%`;

            const formData = new FormData();
            formData.append('image', file);
            formData.append('key', getCookie('adminSession')); // Pass auth token

            try {
                const res = await fetch('/api/upload-image', {
                    method: 'POST',
                    body: formData
                });
                const data = await res.json();
                
                if (data.success) {
                    successCount++;
                } else {
                    console.error('Failed to upload', file.name, data.error);
                }
            } catch (err) {
                console.error('Error uploading', file.name, err);
            }
        }

        progressBar.style.width = `100%`;
        uploadStatusText.textContent = `Completed! ${successCount}/${files.length} uploaded successfully.`;

        // Reset and reload after 1 sec
        setTimeout(() => {
            uploadCard.style.display = 'none';
            progressBar.style.width = `0%`;
            fileInput.value = ''; // Reset input
            document.getElementById('mediaGrid').style.display = 'none';
            document.getElementById('mediaEmpty').style.display = 'none';
            document.getElementById('mediaLoading').style.display = 'flex';
            loadMedia();
        }, 1500);
    });

    // Run on mount
    loadMedia();
</script>
