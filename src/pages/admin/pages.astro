---
import AdminLayout from '../../layouts/AdminLayout.astro';

// In a real application, you might read the file system or a dedicated database table
// For this CMS, static pages are managed in the codebase.
const staticPages = [
    { title: 'Home', path: '/', file: 'src/pages/index.astro' },
    { title: 'About Us', path: '/about', file: 'src/pages/about.astro' },
    { title: 'Contact', path: '/contact', file: 'src/pages/contact.astro' },
    { title: 'Services', path: '/services', file: 'src/pages/services.astro' },
];
---

<AdminLayout title="Static Pages">
    <div class="page-header">
        <div class="header-content">
            <h1>Static Pages</h1>
            <p class="text-muted">Overview of static pages managed in the Astro codebase.</p>
        </div>
    </div>

    <div class="info-card">
        <h3>ℹ️ How Static Pages Work</h3>
        <p>In this architecture, dynamic content (Articles) is managed via the database, but core structural pages are built directly as Astro files for maximum performance.</p>
        <p>To edit the content of these pages, modify the corresponding <code>.astro</code> files in your code editor.</p>
    </div>

    <div class="card table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Page Title</th>
                    <th>URL Path</th>
                    <th>Source File</th>
                    <th style="text-align: right;">Action</th>
                </tr>
            </thead>
            <tbody>
                {staticPages.map(page => (
                    <tr>
                        <td style="font-weight: 500;">{page.title}</td>
                        <td><a href={page.path} target="_blank" style="color: var(--primary); text-decoration: none;">{page.path}</a></td>
                        <td><code style="background: var(--bg-base); padding: 4px 8px; border-radius: 4px; font-size: 0.85rem;">{page.file}</code></td>
                        <td style="text-align: right;">
                            <a href={page.path} target="_blank" class="btn-sm" style="text-decoration: none; display: inline-block;">View Live</a>
                        </td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>
</AdminLayout>

<style>
    .page-header {
        margin-bottom: 24px;
    }

    .page-header h1 {
        font-size: 1.5rem;
        margin-bottom: 4px;
    }

    .text-muted {
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .info-card {
        background-color: rgba(59, 130, 246, 0.05);
        border: 1px solid rgba(59, 130, 246, 0.2);
        padding: 24px;
        border-radius: 12px;
        margin-bottom: 24px;
    }

    .info-card h3 {
        margin-top: 0;
        margin-bottom: 12px;
        color: var(--primary);
    }

    .info-card p {
        margin-bottom: 8px;
        color: var(--text-main);
        line-height: 1.5;
    }

    .info-card p:last-child {
        margin-bottom: 0;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th, .data-table td {
        padding: 12px 16px;
        border-bottom: 1px solid var(--border);
        text-align: left;
    }

    .data-table th {
        background-color: var(--bg-surface);
        font-weight: 500;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .data-table tr:hover {
        background-color: rgba(0, 0, 0, 0.01);
    }

    .btn-sm {
        padding: 6px 12px;
        font-size: 0.85rem;
        border: 1px solid var(--border);
        background: var(--bg-surface);
        border-radius: 6px;
        cursor: pointer;
        color: var(--text-main);
    }

    .btn-sm:hover {
        background: var(--border);
    }
</style>
