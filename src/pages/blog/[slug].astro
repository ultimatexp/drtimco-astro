---
/**
 * Blog Post Template — /blog/[slug]
 * Generates static pages for every WordPress post.
 * Includes: MedicalWebPage JSON-LD, DirectAnswerBox, related posts.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import DirectAnswerBox from '../../components/DirectAnswerBox.astro';
import {
  getAllPosts,
  getPostBySlug,
  getRelatedPosts,
  stripHtml,
  generateMetaDescription,
  generateDirectAnswer,
  formatDate,
  sanitizeContent,
  localizeImageUrl,
  getAuthorName,
} from '../../lib/api.js';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = getRelatedPosts(post, 3);
const description = generateMetaDescription(post.excerpt, post.content);
const directAnswer = generateDirectAnswer(post.excerpt, post.content);
const plainTitle = stripHtml(post.title);
const cleanContent = sanitizeContent(post.content);

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', url: 'https://drtim.co' },
  { name: 'Blog', url: 'https://drtim.co/blog' },
];
if (post.categories?.length > 0) {
  const cat = post.categories[0];
  breadcrumbs.push({
    name: cat.name,
    url: `https://drtim.co/category/${cat.slug}`,
  });
}
breadcrumbs.push({
  name: plainTitle,
  url: `https://drtim.co/blog/${post.slug}`,
});
---

<BaseLayout
  title={plainTitle}
  description={description}
  type="article"
  publishedDate={post.date}
  modifiedDate={post.modified}
  ogImage={localizeImageUrl(post.featuredImage?.sourceUrl)}
  canonicalUrl={`https://drtim.co/blog/${post.slug}`}
  breadcrumbs={breadcrumbs}
>
  <article class="post-page">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((crumb, i) => (
          <li>
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url}>{crumb.name}</a>
            ) : (
              <span aria-current="page">{crumb.name}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Post Header -->
    <header class="post-header">
      {post.categories?.length > 0 && (
        <div class="post-categories">
          {post.categories.map((cat) => (
            <a href={`/category/${cat.slug}`} class="category-badge">
              {cat.name}
            </a>
          ))}
        </div>
      )}

      <h1 set:html={post.title} />

      <div class="post-meta">
        <div class="post-author">
          {post.author?.avatar && (
            <img
              src={post.author.avatar}
              alt={post.author.name}
              class="author-avatar"
              width="40"
              height="40"
              loading="lazy"
            />
          )}
          <div>
            <span class="author-name">{getAuthorName(post.author)}</span>
            <time datetime={post.date} class="post-date">
              {formatDate(post.date)}
            </time>
          </div>
        </div>
      </div>
    </header>

    <!-- Featured Image -->
    {post.featuredImage?.sourceUrl && (
      <figure class="post-featured-image">
        <img
          src={localizeImageUrl(post.featuredImage.sourceUrl)}
          alt={post.featuredImage.altText || plainTitle}
          width={post.featuredImage.width || 1200}
          height={post.featuredImage.height || 630}
          loading="eager"
        />
      </figure>
    )}

    <!-- AEO Direct Answer Box -->
    <DirectAnswerBox
      answer={directAnswer}
      question={plainTitle}
      author={getAuthorName(post.author)}
      specialty="Functional Medicine"
    />

    <!-- Post Content -->
    <div class="prose post-content" set:html={cleanContent} />

    <!-- Tags -->
    {post.tags?.length > 0 && (
      <footer class="post-tags">
        <span class="tags-label">Tags:</span>
        {post.tags.map((tag) => (
          <span class="tag-pill">{tag.name}</span>
        ))}
      </footer>
    )}

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="related-posts" aria-label="Related Articles">
        <h2>Related Articles</h2>
        <div class="related-grid">
          {relatedPosts.map((rp) => (
            <a href={`/blog/${rp.slug}`} class="related-card">
              {rp.featuredImage?.sourceUrl && (
                <img
                  src={localizeImageUrl(rp.featuredImage.sourceUrl)}
                  alt={stripHtml(rp.title)}
                  class="related-image"
                  loading="lazy"
                />
              )}
              <div class="related-content">
                <h3 set:html={rp.title} />
                <time datetime={rp.date}>{formatDate(rp.date)}</time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .post-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  /* Breadcrumbs */
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-1);
    color: var(--color-border);
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs [aria-current] {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Post Header */
  .post-header {
    margin-top: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .post-categories {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .category-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-primary);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
    transition: background var(--transition);
  }

  .category-badge:hover {
    background: var(--color-primary-dark);
    color: white;
  }

  .post-header h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .author-avatar {
    border-radius: 50%;
    border: 2px solid var(--color-primary-light);
  }

  .author-name {
    font-weight: 600;
    color: var(--color-text);
    display: block;
    font-size: var(--text-sm);
  }

  .post-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    display: block;
  }

  /* Featured Image */
  .post-featured-image {
    margin: 0 calc(-1 * var(--space-4)) var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .post-featured-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  /* Post Content */
  .post-content {
    margin-bottom: var(--space-8);
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .tags-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .tag-pill {
    padding: var(--space-1) var(--space-3);
    background: #f1f5f9;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  /* Related Posts */
  .related-posts {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 2px solid var(--color-border);
  }

  .related-posts h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-6);
  }

  .related-card {
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    color: var(--color-text);
  }

  .related-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .related-image {
    width: 100%;
    height: 140px;
    object-fit: cover;
  }

  .related-content {
    padding: var(--space-4);
  }

  .related-content h3 {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: var(--space-2);
  }

  .related-content time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-featured-image {
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
