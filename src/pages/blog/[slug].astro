---
/**
 * Blog Post Template — /blog/[slug]
 * Generates static pages for every WordPress post.
 * Includes: MedicalWebPage JSON-LD, DirectAnswerBox, related posts.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import DirectAnswerBox from '../../components/DirectAnswerBox.astro';
import {
  getAllPosts,
  getPostBySlug,
  getRelatedPosts,
  stripHtml,
  generateMetaDescription,
  generateDirectAnswer,
  formatDate,
  sanitizeContent,
  localizeImageUrl,
  getAuthorName,
} from '../../lib/api.js';

export function getStaticPaths() {
  const posts = getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = getRelatedPosts(post, 3);
const description = generateMetaDescription(post.excerpt, post.content);
const directAnswer = generateDirectAnswer(post.excerpt, post.content);
const plainTitle = stripHtml(post.title);
const cleanContent = sanitizeContent(post.content);

// Reading time estimate (Thai averages ~200 words/min)
const wordCount = stripHtml(post.content).split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Thai-formatted date
const thaiDate = new Date(post.date).toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Updated date (if different from publish date)
const hasUpdated = post.modified && post.modified !== post.date;
const thaiUpdatedDate = hasUpdated ? new Date(post.modified).toLocaleDateString('th-TH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}) : '';

// Share URL
const shareUrl = `https://drtim.co/blog/${post.slug}`;

// Breadcrumbs
const breadcrumbs = [
  { name: 'Home', url: 'https://drtim.co' },
  { name: 'Blog', url: 'https://drtim.co/blog' },
];
if (post.categories?.length > 0) {
  const cat = post.categories[0];
  breadcrumbs.push({
    name: cat.name,
    url: `https://drtim.co/category/${cat.slug}`,
  });
}
breadcrumbs.push({
  name: plainTitle,
  url: shareUrl,
});
---

<BaseLayout
  title={plainTitle}
  description={description}
  type="article"
  publishedDate={post.date}
  modifiedDate={post.modified}
  ogImage={localizeImageUrl(post.featuredImage?.sourceUrl)}
  canonicalUrl={`https://drtim.co/blog/${post.slug}`}
  breadcrumbs={breadcrumbs}
>
  <article class="post-page">
    <!-- Breadcrumb Navigation -->
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((crumb, i) => (
          <li>
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url}>{crumb.name}</a>
            ) : (
              <span aria-current="page">{crumb.name}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Post Header -->
    <header class="post-header">
      <div class="post-header-accent"></div>

      {post.categories?.length > 0 && (
        <div class="post-categories">
          {post.categories.map((cat) => (
            <a href={`/category/${cat.slug}`} class="category-badge">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 3H4a1 1 0 00-1 1v6a1 1 0 001 1h6a1 1 0 001-1V4a1 1 0 00-1-1zm10 0h-6a1 1 0 00-1 1v6a1 1 0 001 1h6a1 1 0 001-1V4a1 1 0 00-1-1zM10 13H4a1 1 0 00-1 1v6a1 1 0 001 1h6a1 1 0 001-1v-6a1 1 0 00-1-1zm10 0h-6a1 1 0 00-1 1v6a1 1 0 001 1h6a1 1 0 001-1v-6a1 1 0 00-1-1z"/>
              </svg>
              {cat.name}
            </a>
          ))}
        </div>
      )}

      <h1 set:html={post.title} />

      <!-- Meta chips row -->
      <div class="post-meta-chips">
        <span class="meta-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          {readingTime} นาทีในการอ่าน
        </span>
        <span class="meta-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          <time datetime={post.date}>{thaiDate}</time>
        </span>
        {hasUpdated && (
          <span class="meta-chip meta-chip-updated">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
            อัปเดต: {thaiUpdatedDate}
          </span>
        )}
      </div>

      <!-- Author & Share row -->
      <div class="post-meta">
        <div class="post-author">
          {post.author?.avatar && (
            <img
              src={post.author.avatar}
              alt={post.author.name}
              class="author-avatar"
              width="44"
              height="44"
              loading="lazy"
            />
          )}
          <div>
            <span class="author-name">{getAuthorName(post.author)}</span>
            <span class="author-role">Functional Medicine</span>
          </div>
        </div>

        <div class="post-share">
          <span class="share-label">แชร์</span>
          <a
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-facebook"
            aria-label="Share on Facebook"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(shareUrl)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-btn share-line"
            aria-label="Share on LINE"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
          </a>
          <button
            class="share-btn share-copy"
            data-url={shareUrl}
            aria-label="Copy link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
              <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
            </svg>
          </button>
        </div>
      </div>
    </header>

    <!-- Copy link script -->
    <script>
      document.querySelectorAll('.share-copy').forEach(btn => {
        btn.addEventListener('click', async () => {
          const url = btn.getAttribute('data-url');
          try {
            await navigator.clipboard.writeText(url);
            btn.classList.add('copied');
            btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
            }, 2000);
          } catch (e) {
            // Fallback
            const input = document.createElement('input');
            input.value = url;
            document.body.appendChild(input);
            input.select();
            document.execCommand('copy');
            document.body.removeChild(input);
          }
        });
      });
    </script>

    <!-- Featured Image -->
    {post.featuredImage?.sourceUrl && (
      <figure class="post-featured-image">
        <img
          src={localizeImageUrl(post.featuredImage.sourceUrl)}
          alt={post.featuredImage.altText || plainTitle}
          width={post.featuredImage.width || 1200}
          height={post.featuredImage.height || 630}
          loading="eager"
        />
      </figure>
    )}

    <!-- AEO Direct Answer Box -->
    <DirectAnswerBox
      answer={directAnswer}
      question={plainTitle}
      author={getAuthorName(post.author)}
      specialty="Functional Medicine"
    />

    <!-- Post Content -->
    <div class="prose post-content" set:html={cleanContent} />

    <!-- Tags -->
    {post.tags?.length > 0 && (
      <footer class="post-tags">
        <span class="tags-label">Tags:</span>
        {post.tags.map((tag) => (
          <span class="tag-pill">{tag.name}</span>
        ))}
      </footer>
    )}

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="related-posts" aria-label="Related Articles">
        <h2>Related Articles</h2>
        <div class="related-grid">
          {relatedPosts.map((rp) => (
            <a href={`/blog/${rp.slug}`} class="related-card">
              {rp.featuredImage?.sourceUrl && (
                <img
                  src={localizeImageUrl(rp.featuredImage.sourceUrl)}
                  alt={stripHtml(rp.title)}
                  class="related-image"
                  loading="lazy"
                />
              )}
              <div class="related-content">
                <h3 set:html={rp.title} />
                <time datetime={rp.date}>{formatDate(rp.date)}</time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .post-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  /* Breadcrumbs */
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-1);
    color: var(--color-border);
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs [aria-current] {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Post Header */
  .post-header {
    margin-top: var(--space-6);
    margin-bottom: var(--space-8);
    position: relative;
  }

  .post-header-accent {
    width: 60px;
    height: 4px;
    border-radius: 2px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
    margin-bottom: var(--space-4);
  }

  .post-categories {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: var(--space-1) var(--space-3);
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
    transition: all var(--transition);
    box-shadow: 0 2px 6px rgba(15, 118, 110, 0.25);
  }

  .category-badge:hover {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    color: white;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(15, 118, 110, 0.3);
  }

  .category-badge svg {
    opacity: 0.8;
  }

  .post-header h1 {
    font-size: clamp(1.75rem, 1.4rem + 1.75vw, 2.75rem);
    font-weight: 800;
    line-height: 1.2;
    margin-bottom: var(--space-4);
    color: var(--color-text);
    letter-spacing: -0.01em;
  }

  /* Meta chips */
  .post-meta-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding: 4px 12px;
    background: #f8fafc;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    white-space: nowrap;
  }

  .meta-chip svg {
    flex-shrink: 0;
  }

  .meta-chip-updated {
    background: #fffbeb;
    border-color: #fde68a;
    color: #92400e;
  }

  /* Author & Share row */
  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .post-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .author-avatar {
    border-radius: 50%;
    border: 2.5px solid var(--color-primary-light);
    box-shadow: 0 2px 8px rgba(20, 184, 166, 0.15);
  }

  .author-name {
    font-weight: 700;
    color: var(--color-text);
    display: block;
    font-size: var(--text-sm);
  }

  .author-role {
    font-size: var(--text-xs);
    color: var(--color-primary);
    display: block;
    font-weight: 500;
  }

  /* Share buttons */
  .post-share {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .share-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: 500;
    margin-right: 2px;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all var(--transition);
    text-decoration: none;
  }

  .share-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .share-facebook:hover {
    background: #1877f2;
    color: white;
    border-color: #1877f2;
  }

  .share-line:hover {
    background: #06c755;
    color: white;
    border-color: #06c755;
  }

  .share-copy:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  .share-copy.copied {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  /* Featured Image */
  .post-featured-image {
    margin: 0 calc(-1 * var(--space-4)) var(--space-8);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .post-featured-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
    aspect-ratio: 16 / 9;
  }

  /* Post Content */
  .post-content {
    margin-bottom: var(--space-8);
  }

  /* Tags */
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
    margin-bottom: var(--space-12);
  }

  .tags-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .tag-pill {
    padding: var(--space-1) var(--space-3);
    background: #f1f5f9;
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  /* Related Posts */
  .related-posts {
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 2px solid var(--color-border);
  }

  .related-posts h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-6);
  }

  .related-card {
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
    color: var(--color-text);
  }

  .related-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .related-image {
    width: 100%;
    height: 140px;
    object-fit: cover;
  }

  .related-content {
    padding: var(--space-4);
  }

  .related-content h3 {
    font-size: var(--text-base);
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: var(--space-2);
  }

  .related-content time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .post-featured-image {
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
