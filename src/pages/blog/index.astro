---
export const prerender = true;
/**
 * Blog Index — /blog
 * Lists all posts with pagination.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getCategories, stripHtml, formatDate, localizeImageUrl } from '../../lib/api.js';
import { getTranslations } from '../../i18n/translations.js';

const ui = getTranslations('th');

const posts = getAllPosts();
const categories = getCategories();

const breadcrumbs = [
  { name: 'Home', url: 'https://drtim.co' },
  { name: 'Blog', url: 'https://drtim.co/blog' },
];
---

<BaseLayout
  title={ui.healthBlog}
  description={ui.blogSubtitle}
  canonicalUrl="https://drtim.co/blog"
  breadcrumbs={breadcrumbs}
>
  <main class="blog-page">
    <!-- Header -->
    <header class="blog-header">
      <h1>{ui.healthBlog}</h1>
      <p class="blog-subtitle">
        {ui.blogSubtitle}
      </p>
    </header>

    <!-- Category Filters -->
    {categories.length > 0 && (
      <nav class="category-filters" aria-label="Filter by category">
        <a href="/blog" class="filter-pill active">{ui.all}</a>
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="filter-pill">
            {cat.name}
            <span class="filter-count">{cat.count}</span>
          </a>
        ))}
      </nav>
    )}

    <!-- Posts -->
    <div class="posts-list">
      {posts.map((post, index) => (
        <article class="post-row">
          <a href={`/blog/${post.slug}`} class="post-row-link">
            {post.featuredImage?.sourceUrl && (
              <div class="post-row-image">
                <img
                  src={localizeImageUrl(post.featuredImage.sourceUrl)}
                  alt={post.featuredImage.altText || stripHtml(post.title)}
                  loading={index < 3 ? 'eager' : 'lazy'}
                />
              </div>
            )}
            <div class="post-row-body">
              <div class="post-row-meta">
                {post.categories?.length > 0 && (
                  <span class="post-row-category">{post.categories[0].name}</span>
                )}
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
              <h2 set:html={post.title} />
              <p set:html={stripHtml(post.excerpt).substring(0, 160) + '…'} />
              <span class="read-more">Read article →</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
  .blog-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-4) var(--space-16);
  }

  .blog-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .blog-header h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-3);
  }

  .blog-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 36rem;
    margin: 0 auto;
  }

  /* Category Filters */
  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: all var(--transition);
  }

  .filter-pill:hover,
  .filter-pill.active {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .filter-count {
    font-size: var(--text-xs);
    background: rgba(0, 0, 0, 0.1);
    padding: 1px 6px;
    border-radius: 999px;
  }

  .filter-pill.active .filter-count,
  .filter-pill:hover .filter-count {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Post Rows */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .post-row {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .post-row:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .post-row-link {
    display: grid;
    grid-template-columns: 240px 1fr;
    color: var(--color-text);
    text-decoration: none;
  }

  .post-row-image img {
    width: 100%;
    height: 100%;
    min-height: 180px;
    object-fit: cover;
  }

  .post-row-body {
    padding: var(--space-6);
  }

  .post-row-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .post-row-category {
    padding: 2px var(--space-2);
    background: var(--color-answer-bg);
    color: var(--color-primary);
    border-radius: 999px;
    font-weight: 600;
  }

  .post-row-body h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    margin-bottom: var(--space-2);
    line-height: 1.3;
  }

  .post-row-body p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .read-more {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
  }

  @media (max-width: 640px) {
    .post-row-link {
      grid-template-columns: 1fr;
    }

    .post-row-image img {
      height: 180px;
    }
  }
</style>
