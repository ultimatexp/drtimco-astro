---
export const prerender = true;
/**
 * Category Archive — /category/[slug]
 * Lists all posts in a given category.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getCategories,
  getCategoryBySlug,
  getPostsByCategory,
  stripHtml,
  formatDate,
  localizeImageUrl,
} from '../../lib/api.js';

export function getStaticPaths() {
  const categories = getCategories();
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const posts = getPostsByCategory(category.slug);

const breadcrumbs = [
  { name: 'Home', url: 'https://drtim.co' },
  { name: 'Blog', url: 'https://drtim.co/blog' },
  { name: category.name, url: `https://drtim.co/category/${category.slug}` },
];
---

<BaseLayout
  title={`${category.name} — Articles`}
  description={category.description || `Browse articles about ${category.name} by Dr. Tim — Functional Medicine physician at Ultramed Clinic Chonburi.`}
  canonicalUrl={`https://drtim.co/category/${category.slug}`}
  breadcrumbs={breadcrumbs}
>
  <main class="category-page">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <ol>
        {breadcrumbs.map((crumb, i) => (
          <li>
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.url}>{crumb.name}</a>
            ) : (
              <span aria-current="page">{crumb.name}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Category Header -->
    <header class="category-header">
      <span class="category-label">Category</span>
      <h1>{category.name}</h1>
      {category.description && (
        <p class="category-description">{category.description}</p>
      )}
      <p class="category-count">{posts.length} article{posts.length !== 1 ? 's' : ''}</p>
    </header>

    <!-- Post Listing -->
    {posts.length > 0 ? (
      <div class="posts-grid">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`/blog/${post.slug}`} class="post-card-link">
              {post.featuredImage?.sourceUrl && (
                <div class="post-card-image">
                  <img
                    src={localizeImageUrl(post.featuredImage.sourceUrl)}
                    alt={post.featuredImage.altText || stripHtml(post.title)}
                    loading="lazy"
                  />
                </div>
              )}
              <div class="post-card-body">
                <div class="post-card-meta">
                  <time datetime={post.date}>{formatDate(post.date)}</time>
                  {post.tags?.length > 0 && (
                    <span class="post-card-tag">{post.tags[0].name}</span>
                  )}
                </div>
                <h2 set:html={post.title} />
                <p class="post-card-excerpt" set:html={stripHtml(post.excerpt).substring(0, 120) + '…'} />
                <span class="read-more">Read article →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <p class="no-posts">No articles found in this category.</p>
    )}
  </main>
</BaseLayout>

<style>
  .category-page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-1);
    color: var(--color-border);
  }

  .breadcrumbs a { color: var(--color-text-muted); }
  .breadcrumbs a:hover { color: var(--color-primary); }
  .breadcrumbs [aria-current] { color: var(--color-text); font-weight: 500; }

  /* Category Header */
  .category-header {
    margin: var(--space-8) 0 var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-border);
  }

  .category-label {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: var(--color-primary);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 999px;
    margin-bottom: var(--space-3);
  }

  .category-header h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .category-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: var(--content-width);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .category-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: 500;
  }

  /* Post Cards */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .post-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .post-card-link {
    display: block;
    color: var(--color-text);
    text-decoration: none;
  }

  .post-card-image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    transition: transform 300ms ease;
  }

  .post-card:hover .post-card-image img {
    transform: scale(1.03);
  }

  .post-card-body {
    padding: var(--space-6);
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .post-card-tag {
    padding: 2px var(--space-2);
    background: #f1f5f9;
    border-radius: 999px;
    font-weight: 500;
  }

  .post-card-body h2 {
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: var(--space-2);
  }

  .post-card-excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .read-more {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    transition: color var(--transition);
  }

  .post-card:hover .read-more {
    color: var(--color-primary-dark);
  }

  .no-posts {
    text-align: center;
    color: var(--color-text-muted);
    padding: var(--space-12);
    font-size: var(--text-lg);
  }
</style>
