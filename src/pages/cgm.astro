    .timeline {
        position: relative;
        padding-left: 32px;
        max-width: 700px;
        margin: 0 auto;
    }

    .timeline::before {
        content: "";
        position: absolute;
        left: 8px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(180deg, var(--cgm-teal), var(--cgm-gold));
