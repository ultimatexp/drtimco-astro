<script>
    // ── Countdown Timer ──
    // Set deadline to 7 days from the user's first visit (persisted in localStorage)
    (function () {
        const STORAGE_KEY = "cgm_countdown_end";
        let endTime = localStorage.getItem(STORAGE_KEY);
        if (!endTime) {
            // 7 days from now
            endTime = Date.now() + 7 * 24 * 60 * 60 * 1000;
            localStorage.setItem(STORAGE_KEY, endTime);
        }
        endTime = parseInt(endTime);

        function pad(n) {
            return String(n).padStart(2, "0");
        }

        function updateCountdown() {
            const now = Date.now();
            let diff = Math.max(0, endTime - now);
            const d = Math.floor(diff / (1000 * 60 * 60 * 24));
            diff -= d * 1000 * 60 * 60 * 24;
            const h = Math.floor(diff / (1000 * 60 * 60));
            diff -= h * 1000 * 60 * 60;
            const m = Math.floor(diff / (1000 * 60));
            diff -= m * 1000 * 60;
            const s = Math.floor(diff / 1000);

            // Hero countdown
            const el = (id) => document.getElementById(id);
            if (el("cd-days")) el("cd-days").textContent = pad(d);
            if (el("cd-hours")) el("cd-hours").textContent = pad(h);
            if (el("cd-mins")) el("cd-mins").textContent = pad(m);
            if (el("cd-secs")) el("cd-secs").textContent = pad(s);
            // Urgency countdown
            if (el("cd2-days")) el("cd2-days").textContent = pad(d);
            if (el("cd2-hours")) el("cd2-hours").textContent = pad(h);
            if (el("cd2-mins")) el("cd2-mins").textContent = pad(m);
            if (el("cd2-secs")) el("cd2-secs").textContent = pad(s);
        }

        updateCountdown();
        setInterval(updateCountdown, 1000);
    })();

    // ── Animate stats on scroll ──
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach((entry) => {
                if (entry.isIntersecting) {
                    entry.target
                        .querySelectorAll(".stat-number[data-target]")
                        .forEach((el) => {
                            const target = parseInt(
                                /** @type {HTMLElement} */ el.dataset.target ||
                                    "0"
                            );
                            let current = 0;
                            const step = Math.ceil(target / 40);
                            const timer = setInterval(() => {
                                current += step;
                                if (current >= target) {
                                    current = target;
                                    clearInterval(timer);
                                }
                                el.textContent = current.toLocaleString();
                            }, 30);
                        });
                    observer.unobserve(entry.target);
                }
            });
        },
        { threshold: 0.3 }
    );

    document
        .querySelectorAll(".proof-stats")
        .forEach((el) => observer.observe(el));
</script>
