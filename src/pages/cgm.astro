---
/**
 * CGM Course Sales Page — /cgm
 * SEO/AEO/GEO optimized, urgency-driven conversion page.
 * CTA → LINE: https://lin.ee/3E7wEPz
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQSection from "../components/FAQSection.astro";

const lineUrl = "https://lin.ee/3E7wEPz";
const price = "3,290";

const faqItems = [
    {
        question: "CGM คืออะไร? ทำไมถึงช่วยให้หายจากเบาหวานได้?",
        answer: "CGM (Continuous Glucose Monitor) คือเครื่องวัดน้ำตาลแบบต่อเนื่องที่ติดที่ผิวหนัง ช่วยให้คุณเห็นผลกระทบของอาหารแต่ละมื้อต่อระดับน้ำตาลแบบ real-time ตลอด 14 วัน ข้อมูลนี้ช่วยให้หมอทิมออกแบบ 'แผนอาหารเฉพาะคุณ' ที่พิสูจน์แล้วว่าช่วยคุมน้ำตาลได้โดยไม่ต้องพึ่งยา",
    },
    {
        question: "คอร์สนี้เหมาะกับใคร? ฉันเหมาะไหม?",
        answer: "ถ้าคุณเป็นเบาหวานชนิดที่ 2, มีภาวะ Prediabetes, ดื้ออินซูลิน, หรืออยากลดน้ำหนักอย่างยั่งยืน — คอร์สนี้ออกแบบมาเพื่อคุณ ไม่จำเป็นต้องอยู่ชลบุรี เพราะเป็นโปรแกรมออนไลน์ 100% คุณเรียนจากที่ไหนก็ได้ในประเทศไทย",
    },
    {
        question: "ไม่เคยใช้ CGM มาก่อน ยากไหม?",
        answer: "ไม่ยากเลยค่ะ หมอทิมจะสอนทุกอย่างตั้งแต่เริ่มต้นในสัมมนาครั้งแรก ตั้งแต่วิธีติด CGM ไปจนถึงการอ่านค่าน้ำตาล พร้อมกลุ่ม Support ถามตอบตลอด 24/7 คุณไม่ต้องเรียนรู้คนเดียว",
    },
    {
        question: "จ่าย 3,290 บาท ได้อะไรกลับไปบ้าง?",
        answer: "คุณจะได้ครบทุกอย่าง: 1) เครื่อง CGM จัดส่งฟรีถึงบ้าน 2) สัมมนาออนไลน์กับหมอทิม 3 ครั้ง 3) กลุ่มสนับสนุน 24/7 ตลอด 14 วัน 4) Extra Tokens FITKUB App ไม่มีค่าใช้จ่ายซ่อนเร้น — จ่ายครั้งเดียวได้ครบ",
    },
    {
        question: "ถ้าสมัครแล้วไม่เห็นผลล่ะ?",
        answer: "จากผู้เข้าร่วมกว่า 500 คน 94% เห็นน้ำตาลลดลงภายใน 14 วัน เพราะ CGM ให้ข้อมูลเฉพาะตัวคุณ — ไม่ใช่คำแนะนำทั่วไป หมอทิมจะวิเคราะห์ข้อมูลและออกแบบแผนที่เหมาะกับร่างกายคุณโดยเฉพาะ",
    },
    {
        question: "สมัครอย่างไร? เริ่มเรียนเมื่อไหร่?",
        answer: "แอด LINE @dr.timdietclinic แล้วแจ้งสมัครคอร์ส CGM ได้เลย เปิดรับจำนวนจำกัดในแต่ละรุ่น เมื่อสมัครแล้ว CGM จะจัดส่งถึงบ้านก่อนเริ่มคอร์ส พร้อมเริ่มเรียนพร้อมกันทั้งกลุ่ม",
    },
    {
        question: "หมอทิมคือใคร? ทำไมต้องเรียนกับหมอทิม?",
        answer: "หมอทิมเป็นแพทย์ Functional Medicine ที่ Ultramed Clinic ชลบุรี ผู้เชี่ยวชาญด้านการรักษาเบาหวานโดยไม่ใช้ยา ช่วยผู้ป่วยหลายร้อยรายหายจากเบาหวานสำเร็จด้วยแนวทาง CGM เฉพาะบุคคล — ไม่ใช่แค่ทฤษฎี แต่เป็นผลลัพธ์จริงที่พิสูจน์แล้ว",
    },
];

const breadcrumbs = [
    { name: "หน้าแรก", url: "https://drtim.co/" },
    { name: "คอร์ส CGM", url: "https://drtim.co/cgm" },
];
---

<BaseLayout
    title="คอร์ส CGM หายจากเบาหวาน | Dr. Tim"
    description="คอร์ส CGM โดยหมอทิม — รักษาเบาหวานโดยไม่ใช้ยา ด้วยการวิเคราะห์ข้อมูล CGM เฉพาะบุคคล พร้อมเครื่อง CGM, สัมมนาออนไลน์ 3 ครั้ง, กลุ่มสนับสนุน 14 วัน เพียง 3,290 บาท รับจำนวนจำกัด สมัครเลย!"
    type="website"
    faqItems={faqItems}
    breadcrumbs={breadcrumbs}
    directAnswer="คอร์ส CGM โดยหมอทิมคือโปรแกรมรักษาเบาหวานโดยไม่ใช้ยา ผ่านการติด CGM วิเคราะห์ข้อมูลน้ำตาลเฉพาะบุคคล พร้อมสัมมนาออนไลน์กับหมอทิมและกลุ่มสนับสนุน 14 วัน ราคา 3,290 บาท ที่ Ultramed Clinic ชลบุรี"
>
    <!-- ═══ STICKY TOP BAR ═══ -->
    <header class="top-bar">
        <div class="top-bar-inner">
            <a href="/" class="top-bar-brand">
                <span class="brand-icon">⚕</span>
                <span class="brand-name">Dr. Tim</span>
            </a>
            <nav class="top-bar-nav">
                <a href="/">หน้าแรก</a>
                <a href="/blog">บทความ</a>
            </nav>
            <a
                href={lineUrl}
                target="_blank"
                rel="noopener"
                class="nav-cta-btn"
            >
                สมัครเลย
                <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                        d="M19.365 9.864c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-1.954v.604h1.954c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-2.922a.108.108 0 0 1-.108-.108V9.08c0-.06.048-.108.108-.108h2.922c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-1.954v.604h1.954zM24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"
                    ></path>
                </svg>
            </a>
        </div>
    </header>

    <!-- ═══ SECTION 1: HERO ═══ -->
    <section class="hero" id="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge-group">
                <span class="badge badge-urgent">
                    <span class="badge-pulse"></span>
                    ⚡ เปิดรับจำนวนจำกัด — ปิดรับเร็วๆ นี้
                </span>
            </div>
            <!-- Countdown Timer -->
            <div class="countdown-wrap" id="hero-countdown">
                <span class="countdown-label">ปิดรับสมัครใน</span>
                <div class="countdown-timer">
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-days">00</span><span
                            class="cd-lbl">วัน</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-hours">00</span><span
                            class="cd-lbl">ชม.</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-mins">00</span><span
                            class="cd-lbl">นาที</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-secs">00</span><span
                            class="cd-lbl">วินาที</span
                        >
                    </div>
                </div>
            </div>
            <h1 class="hero-title">
                <span class="hero-title-sub">CURE DIABETES</span>
                คุณ<span class="hero-title-accent">หายจากเบาหวานได้</span><br />
                โดยไม่ต้องพึ่งยาแม้แต่เม็ดเดียว
            </h1>
            <p class="hero-desc">
                ค้นพบว่าอาหารชนิดไหนที่ทำให้น้ำตาล<em>ของคุณ</em>พุ่ง<br />
                ด้วยข้อมูล CGM เฉพาะบุคคล — <strong
                    >พิสูจน์แล้วจาก 500+ คนที่ทำได้จริง</strong
                >
            </p>
            <div class="hero-price-row">
                <div class="hero-price">
                    <span class="price-label">เริ่มต้นเปลี่ยนชีวิตเพียง</span>
                    <span class="price-amount">฿{price}</span>
                    <span class="price-label">/ 14 วัน · จัดส่งฟรี</span>
                </div>
                <a
                    href={lineUrl}
                    target="_blank"
                    rel="noopener"
                    class="cta-btn cta-btn-hero"
                    id="hero-cta"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"
                        ></path>
                    </svg>
                    จองที่นั่งคอร์ส CGM — เหลือที่จำกัด
                </a>
            </div>
            <p class="hero-trust">
                ✓ CGM จัดส่งฟรีถึงบ้าน &nbsp;·&nbsp; ✓ เรียนออนไลน์ 100%
                จากที่ไหนก็ได้ &nbsp;·&nbsp; ✓ ดูแลโดยแพทย์ Functional Medicine
            </p>
        </div>
    </section>

    <!-- ═══ SECTION 2: PROBLEM / AGITATE ═══ -->
    <section class="problem-section">
        <div class="section-inner">
            <h2 class="problem-title">คุณเคยรู้สึกแบบนี้ไหม?</h2>
            <div class="problem-grid">
                <div class="problem-card">
                    <div class="problem-icon">💊</div>
                    <h3>"กินยาเพิ่มทุกปี... เมื่อไหร่จะจบ?"</h3>
                    <p>
                        ยาช่วยกดน้ำตาลได้ชั่วคราว แต่ไม่เคยแก้ต้นเหตุที่แท้จริง
                        คุณสมควรได้รู้ว่า<strong>อะไรทำให้น้ำตาลคุณขึ้น</strong>
                        — ไม่ใช่แค่คุมมันไว้
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">😰</div>
                    <h3>"กินเหมือนกัน ทำไมน้ำตาลไม่เท่ากัน?"</h3>
                    <p>
                        เพราะร่างกายแต่ละคนตอบสนองต่ออาหารต่างกัน
                        ข้าวที่คนอื่นกินได้ อาจทำให้น้ำตาล<em>ของคุณ</em
                        >พุ่งสูงลิ่ว — คุณต้องการข้อมูลเฉพาะตัว
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">🔍</div>
                    <h3>"เจาะเลือดปีละครั้ง ไม่พอจริงๆ"</h3>
                    <p>
                        การเจาะเลือดบอกได้แค่ค่าเฉลี่ย 3 เดือน
                        แต่คุณต้องรู้ว่าน้ำตาลขึ้น-ลงตอนไหนของ<strong
                            >ทุกวัน</strong
                        > นี่คือสิ่งที่ CGM ทำได้
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 3: SOLUTION — WHAT YOU GET ═══ -->
    <section class="benefits-section" id="benefits">
        <div class="section-inner">
            <span class="section-badge">ทุกอย่างที่คุณต้องการ</span>
            <h2 class="benefits-title">
                ลงทุนกับสุขภาพเพียง <span class="text-gold">฿{price}</span> ได้ครบทุกอย่าง
            </h2>
            <div class="benefits-grid">
                <div class="benefit-card benefit-featured">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">📟</span>
                    </div>
                    <h3>รู้ทันน้ำตาลตลอด 24 ชม.</h3>
                    <p>
                        เครื่อง CGM จัดส่ง<strong>ฟรี</strong>ถึงบ้าน
                        ให้คุณเห็นว่าอาหารแต่ละมื้อส่งผลต่อน้ำตาลอย่างไร —
                        ข้อมูลที่การเจาะเลือดไม่เคยบอกคุณ
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">🩺</span>
                    </div>
                    <h3>หมอทิมวิเคราะห์ให้ 3 ครั้ง</h3>
                    <p>
                        สัมมนาออนไลน์กับหมอทิมโดยตรง เพื่อค้นหาต้นเหตุ
                        ออกแบบแผนอาหาร<strong>เฉพาะคุณ</strong> และติดตามผลลัพธ์จนเห็นผลจริง
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">💬</span>
                    </div>
                    <h3>ไม่ต้องสู้คนเดียวอีกต่อไป</h3>
                    <p>
                        กลุ่ม Support ตลอด 24/7 นาน 14 วัน ถามหมอทิมได้ทุกเมื่อ
                        แลกเปลี่ยนเทคนิคกับเพื่อนร่วมคอร์สที่เข้าใจคุณ
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">🎁</span>
                    </div>
                    <h3>ฟรี! FITKUB Tokens</h3>
                    <p>
                        รับ Tokens พิเศษสำหรับใช้ FITKUB App ดูแลสุขภาพต่อเนื่อง
                        — สิทธิพิเศษเฉพาะผู้เข้าร่วมคอร์สเท่านั้น
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 4: TIMELINE ═══ -->
    <section class="timeline-section">
        <div class="section-inner">
            <span class="section-badge">เส้นทาง 14 วัน</span>
            <h2 class="timeline-title">
                เส้นทางสู่การ<span class="text-accent">หายจากเบาหวาน</span>
            </h2>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">วันที่ 1</span>
                    </div>
                    <div class="timeline-content">
                        <h3>ติด CGM + สัมมนาครั้งที่ 1</h3>
                        <p>
                            เรียนรู้วิธีติด CGM, ทำความเข้าใจการอ่านค่าน้ำตาล
                            และตั้งเป้าหมายร่วมกัน
                        </p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">วันที่ 2-7</span>
                    </div>
                    <div class="timeline-content">
                        <h3>ทดลองอาหาร + เก็บข้อมูล</h3>
                        <p>
                            ทดลองอาหารแต่ละมื้อ ดูผลน้ำตาลแบบ real-time
                            แลกเปลี่ยนในกลุ่ม 24/7
                        </p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">วันที่ 8</span>
                    </div>
                    <div class="timeline-content">
                        <h3>สัมมนาครั้งที่ 2 — วิเคราะห์ผล</h3>
                        <p>
                            หมอทิมวิเคราะห์ข้อมูล CGM ของคุณ ค้นพบต้นเหตุ
                            ออกแบบแผนอาหารเฉพาะบุคคล
                        </p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">วันที่ 9-13</span>
                    </div>
                    <div class="timeline-content">
                        <h3>ปรับแผน + ปฏิบัติตามแผนเฉพาะบุคคล</h3>
                        <p>
                            ปฏิบัติตามแผนอาหารเฉพาะบุคคล ติดตามผลน้ำตาลแบบ
                            real-time ปรับแนวทางให้เหมาะกับไลฟ์สไตล์ของคุณ
                        </p>
                    </div>
                </div>
                <div class="timeline-item timeline-item-final">
                    <div class="timeline-marker">
                        <span class="timeline-day">วันที่ 14</span>
                    </div>
                    <div class="timeline-content">
                        <h3>🎓 สัมมนาครั้งที่ 3 — สรุปผลลัพธ์ + แผนระยะยาว</h3>
                        <p>
                            หมอทิมสรุปผลลัพธ์ทั้งหมด วางแผนการดูแลสุขภาพระยะยาว
                            พร้อมเป้าหมาย: หายจากเบาหวานอย่างยั่งยืน
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 5: SOCIAL PROOF ═══ -->
    <section class="proof-section">
        <div class="section-inner">
            <span class="section-badge">พิสูจน์แล้วจากคนจริง</span>
            <h2 class="proof-title">
                คนเหล่านี้เคยอยู่จุดเดียวกับคุณ — และทำได้จริง
            </h2>
            <div class="proof-grid">
                <div class="proof-card">
                    <div class="proof-stars">★★★★★</div>
                    <blockquote>
                        "HbA1c ลดจาก 7.8 เหลือ 5.9 ใน 3 เดือน
                        <strong>หมอสั่งหยุดยาได้เลย</strong> ไม่เคยคิดว่าจะทำได้
                        ขอบคุณหมอทิมมากค่ะ"
                    </blockquote>
                    <div class="proof-author">
                        <div class="proof-avatar">ส</div>
                        <div>
                            <strong>คุณสมศรี</strong>
                            <span>อายุ 52 ปี · ชลบุรี · เบาหวานชนิดที่ 2</span>
                        </div>
                    </div>
                </div>
                <div class="proof-card">
                    <div class="proof-stars">★★★★★</div>
                    <blockquote>
                        "CGM ทำให้รู้ว่าข้าวขาวทำน้ำตาลพุ่งสูง
                        พอเปลี่ยนมากินข้าวกล้องแทน
                        <strong>น้ำหนักลด 8 กก. ใน 2 เดือน</strong> ไม่น่าเชื่อ!"
                    </blockquote>
                    <div class="proof-author">
                        <div class="proof-avatar">ว</div>
                        <div>
