        background: rgba(255, 255, 255, 0.06);
        border-color: rgba(255, 255, 255, 0.12);
        transform: translateY(-4px);
    }

    .problem-icon {
        font-size: 36px;
        margin-bottom: 16px;
    }

    .problem-card h3 {
        font-size: 18px;
        font-weight: 700;
        color: white;
        margin-bottom: 10px;
