---
export const prerender = true;
/**
 * Personal Consult — /consult
 * Private 1:1 medical consultation page.
 * CTA → LINE: https://lin.ee/3E7wEPz
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQSection from "../components/FAQSection.astro";

const lineUrl = "https://lin.ee/3E7wEPz";
const firstPrice = 2000;
const firstDuration = 60;
const followUpPrice = 800;
const followUpDuration = 30;

const faqItems = [
    {
        question: "การปรึกษาส่วนตัวคืออะไร? เหมาะกับใคร?",
        answer: "การปรึกษาส่วนตัวคือการพบหมอทิมแบบตัวต่อตัวเพื่อวิเคราะห์ปัญหาสุขภาพของคุณอย่างละเอียด เหมาะกับผู้ที่ต้องการแนวทางดูแลสุขภาพเฉพาะบุคคล อยากให้แพทย์อ่านผลเลือดอย่างเป็นระบบ หรือกำลังตัดสินใจเลือกวิธีรักษาที่เหมาะกับตนเอง",
    },
    {
        question: "ครั้งแรก 60 นาที กับครั้งถัดไป 30 นาที ต่างกันอย่างไร?",
        answer: `ครั้งแรก 60 นาที (${firstPrice.toLocaleString()} บาท) เป็นการประเมินภาพรวมสุขภาพอย่างละเอียด ทั้งประวัติ อาการ และอ่านผลเลือดทุกตัว แล้ววางแผนแนวทางดูแลที่เหมาะกับคุณ ส่วนครั้งถัดไป 30 นาที (${followUpPrice} บาท/ครั้ง) เป็นการติดตามผล ปรับแผน หรือพูดคุยประเด็นใหม่ที่เกิดขึ้น`,
    },
    {
        question: "ต้องเตรียมอะไรบ้างก่อนปรึกษา?",
        answer: "เตรียมผลเลือดล่าสุด (ถ้ามี) รายชื่อยา/อาหารเสริมที่ใช้อยู่ และคำถามที่อยากถาม ส่งให้ทีมงานล่วงหน้าทาง LINE เพื่อให้หมอทิมรีวิวก่อนนัด คุณจะได้ใช้เวลาในเซสชันอย่างคุ้มค่าที่สุด",
    },
    {
        question: "ปรึกษาออนไลน์ได้ไหม?",
        answer: "ได้ค่ะ การปรึกษาส่วนตัวเปิดให้บริการทั้งแบบพบที่ Ultramed Clinic ชลบุรี และแบบออนไลน์ผ่าน Video Call คุณอยู่ต่างจังหวัดหรือต่างประเทศก็เข้าปรึกษาได้",
    },
    {
        question: "ถามได้กี่คำถามต่อเซสชัน?",
        answer: "ถามได้ไม่จำกัดตลอดเวลานัดหมาย หมอทิมเปิดให้คุณซักถามทุกข้อสงสัยเกี่ยวกับผลเลือด อาการ ยา อาหาร และไลฟ์สไตล์ จนกว่าจะเข้าใจชัดเจน",
    },
    {
        question: "ชำระเงินอย่างไร?",
        answer: "ชำระผ่านการโอนเงินก่อนเข้านัด หรือชำระที่คลินิกในวันนัด (สำหรับเซสชัน on-site) ทีมงานจะแจ้งรายละเอียดและช่องทางหลังนัดหมายผ่าน LINE @Ultramed",
    },
    {
        question: "หากต้องการคำแนะนำต่อเนื่องในระยะยาวควรเลือกอะไร?",
        answer: "หากต้องการการดูแลใกล้ชิด ติดตามข้อมูลทุกสัปดาห์ และมีแผนเฉพาะบุคคล 12 สัปดาห์ แนะนำให้ดูโปรแกรม VIP 1:1 Coaching แต่หากต้องการเพียงปรึกษาเป็นครั้งๆ การนัดเซสชันส่วนตัวเหมาะกว่า",
    },
];

const breadcrumbs = [
    { name: "หน้าแรก", url: "https://drtim.co/" },
    { name: "ปรึกษาส่วนตัว", url: "https://drtim.co/consult" },
];
---

<BaseLayout
    title="ปรึกษาส่วนตัวกับหมอทิม | อ่านผลเลือดอย่างเป็นระบบ"
    description={`บริการปรึกษาส่วนตัวกับหมอทิม ครั้งแรก ${firstDuration} นาที ${firstPrice.toLocaleString()} บาท ครั้งถัดไป ${followUpDuration} นาที ${followUpPrice} บาท วิเคราะห์ผลเลือดอย่างเป็นระบบ เลือกแนวทางดูแลที่เหมาะกับคุณ ถามได้ไม่จำกัด`}
    canonicalUrl="https://drtim.co/consult"
    type="website"
    faqItems={faqItems}
    breadcrumbs={breadcrumbs}
    directAnswer={`บริการปรึกษาส่วนตัวกับหมอทิม ครั้งแรก ${firstDuration} นาที ${firstPrice.toLocaleString()} บาท ครั้งถัดไป ${followUpDuration} นาที ${followUpPrice} บาท วิเคราะห์ผลเลือดอย่างเป็นระบบ ออกแบบแนวทางดูแลสุขภาพเฉพาะบุคคล นัดผ่าน LINE @Ultramed`}
>
    <!-- ═══ STICKY TOP BAR ═══ -->
    <header class="top-bar">
        <div class="top-bar-inner">
            <a href="/" class="top-bar-brand">
                <span class="brand-icon">⚕</span>
                <span class="brand-name">Dr. Tim</span>
            </a>
            <nav class="top-bar-nav">
                <a href="/">หน้าแรก</a>
                <a href="/cgm">คอร์ส CGM</a>
                <a href="/diabetes-guide">หนังสือเบาหวานผอม</a>
                <a href="/vip-coaching">VIP Coaching</a>
            </nav>
        </div>
    </header>

    <!-- ═══ SECTION 1: HERO ═══ -->
    <section class="hero" id="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge-group">
                <span class="badge badge-consult">🩺 ปรึกษาส่วนตัว 1:1</span>
                <span class="badge badge-info">นัดได้ทั้งออนไลน์และที่คลินิก</span>
            </div>
            <h1 class="hero-title">
                <span class="hero-title-sub">PERSONAL CONSULTATION</span>
                ปรึกษาส่วนตัวกับ<span class="hero-title-accent">หมอทิม</span><br />
                อ่านผลเลือดและออกแบบแนวทางดูแลเฉพาะคุณ
            </h1>
            <p class="hero-desc">
                พบหมอทิมแบบตัวต่อตัว วิเคราะห์ผลเลือดอย่างเป็นระบบ<br />
                เลือกแนวทางรักษาที่เหมาะกับคุณ — <strong>ถามได้ไม่จำกัด</strong>
            </p>

            <div class="price-row">
                <div class="price-card price-card-primary">
                    <span class="price-tag">ครั้งแรก</span>
                    <div class="price-amount">
                        <span class="price-number">{firstPrice.toLocaleString()}</span>
                        <span class="price-unit">บาท</span>
                    </div>
                    <span class="price-duration">{firstDuration} นาที</span>
                    <p class="price-desc">ประเมินภาพรวม · อ่านผลเลือดทุกตัว · วางแผนแนวทาง</p>
                </div>
                <div class="price-card">
                    <span class="price-tag">ครั้งถัดไป</span>
                    <div class="price-amount">
                        <span class="price-number">{followUpPrice}</span>
                        <span class="price-unit">บาท</span>
                    </div>
                    <span class="price-duration">{followUpDuration} นาที / ครั้ง</span>
                    <p class="price-desc">ติดตามผล · ปรับแผน · ตอบคำถามต่อเนื่อง</p>
                </div>
            </div>

            <div class="hero-cta-row">
                <a
                    href={lineUrl}
                    target="_blank"
                    rel="noopener"
                    class="cta-btn cta-btn-hero"
                >
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z" />
                    </svg>
                    จองนัดปรึกษา — LINE @Ultramed
                </a>
            </div>
            <p class="hero-trust">
                ✓ ออนไลน์หรือที่คลินิก &nbsp;·&nbsp; ✓ ถามได้ไม่จำกัด &nbsp;·&nbsp; ✓ ดูแลโดยแพทย์
            </p>
        </div>
    </section>

    <!-- ═══ SECTION 2: WHAT YOU GET ═══ -->
    <section class="benefits-section" id="benefits">
        <div class="section-inner">
            <span class="section-badge">สิ่งที่คุณจะได้รับ</span>
            <h2 class="benefits-title">
                ปรึกษาส่วนตัวให้คุณ<span class="text-accent">เข้าใจร่างกายตัวเอง</span>อย่างถ่องแท้
            </h2>
            <p class="section-subtitle">
                ไม่ใช่แค่การฟังอาการแล้วสั่งยา — แต่เป็นการนั่งคุยกับแพทย์ ทบทวนข้อมูลของคุณ<br />
                แล้วออกแบบแนวทางดูแลที่เหมาะกับร่างกายและเป้าหมายของคุณจริงๆ
            </p>
            <div class="benefits-grid">
                <div class="benefit-card benefit-featured">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">🧭</span></div>
                    <h3>เลือกแนวทางที่เหมาะกับคุณ</h3>
                    <p>
                        ระหว่างแนวทางทั่วไปกับ Functional Medicine, ปรับอาหารหรือใช้ยา — หมอทิมช่วยให้คุณตัดสินใจอย่างมีข้อมูลครบถ้วน
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">🩸</span></div>
                    <h3>วิเคราะห์ผลเลือดทุกตัว</h3>
                    <p>
                        ไม่ดูเฉพาะค่าที่ "ผิดปกติ" แต่ดูภาพรวมทุก biomarker เพื่อหาความเชื่อมโยงและสาเหตุที่แท้จริง
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">📊</span></div>
                    <h3>อ่านผลแบบเป็นระบบ</h3>
                    <p>
                        ไม่ใช่แค่บอกว่า "ค่าสูง/ต่ำ" — แต่อธิบายว่าค่าแต่ละตัวสะท้อนอะไร ส่งผลต่อกันอย่างไร และควรปรับอย่างไร
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">💬</span></div>
                    <h3>ถามได้ไม่จำกัด</h3>
                    <p>
                        สงสัยเรื่องอาการ ยา อาหารเสริม อาหารการกิน หรือไลฟ์สไตล์ — ถามได้หมดในเซสชัน ไม่ต้องรีบ
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">🗺️</span></div>
                    <h3>แผนดูแลสุขภาพระยะยาว</h3>
                    <p>
                        ได้แนวทางดูแลที่ทำตามได้จริง พร้อมขั้นตอนถัดไปที่ชัดเจน — ไม่ต้องเดาเองว่า "แล้วต้องทำอะไรต่อ"
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap"><span class="benefit-icon">🎯</span></div>
                    <h3>คำแนะนำเพื่อแก้ปัญหาเฉพาะจุด</h3>
                    <p>
                        ปัญหาที่กำลังเจอ ไม่ว่าจะเรื่องน้ำตาล น้ำหนัก พลังงาน หรือฮอร์โมน — ได้แนวทางจัดการที่ออกแบบเฉพาะคุณ
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 3: PRICING DETAIL ═══ -->
    <section class="pricing-section" id="pricing">
        <div class="section-inner">
            <span class="section-badge">ค่าบริการ</span>
            <h2 class="pricing-title">โปร่งใส ตรงไปตรงมา</h2>
            <p class="section-subtitle">
                ไม่มีค่าใช้จ่ายแอบแฝง คุณจ่ายเฉพาะเวลาที่ใช้พูดคุยกับแพทย์เท่านั้น
            </p>
            <div class="pricing-grid">
                <div class="pricing-detail-card pricing-primary">
                    <div class="pricing-head">
                        <span class="pricing-tag">ครั้งแรก</span>
                        <h3>ปรึกษาครั้งแรก</h3>
                        <p class="pricing-sub">First Consultation</p>
                    </div>
                    <div class="pricing-amount-block">
                        <span class="pricing-currency">฿</span>
                        <span class="pricing-amount">{firstPrice.toLocaleString()}</span>
                        <span class="pricing-period">/ {firstDuration} นาที</span>
                    </div>
                    <ul class="pricing-features">
                        <li>ทบทวนประวัติสุขภาพและอาการ</li>
                        <li>อ่านผลเลือดทุกตัวอย่างเป็นระบบ</li>
                        <li>ช่วยตัดสินใจเลือกแนวทางรักษา</li>
                        <li>ออกแบบแผนดูแลเฉพาะบุคคล</li>
                        <li>ถามคำถามได้ไม่จำกัด</li>
                    </ul>
                    <a href={lineUrl} target="_blank" rel="noopener" class="cta-btn cta-btn-pricing">
                        จองครั้งแรก
                    </a>
                </div>
                <div class="pricing-detail-card">
                    <div class="pricing-head">
                        <span class="pricing-tag">ครั้งถัดไป</span>
                        <h3>ปรึกษาติดตามผล</h3>
                        <p class="pricing-sub">Follow-up Session</p>
                    </div>
                    <div class="pricing-amount-block">
                        <span class="pricing-currency">฿</span>
                        <span class="pricing-amount">{followUpPrice}</span>
                        <span class="pricing-period">/ {followUpDuration} นาที</span>
                    </div>
                    <ul class="pricing-features">
                        <li>ติดตามความก้าวหน้าและอาการ</li>
                        <li>ทบทวนผลเลือดใหม่ (ถ้ามี)</li>
                        <li>ปรับแผนการดูแลให้เหมาะสม</li>
                        <li>แก้ปัญหาที่เกิดขึ้นระหว่างทาง</li>
                        <li>ถามคำถามได้ไม่จำกัด</li>
                    </ul>
                    <a href={lineUrl} target="_blank" rel="noopener" class="cta-btn cta-btn-pricing cta-btn-pricing-secondary">
                        จองติดตามผล
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 4: HOW IT WORKS ═══ -->
    <section class="how-section">
        <div class="section-inner">
            <span class="section-badge">ขั้นตอน</span>
            <h2 class="how-title">นัดปรึกษาง่ายๆ <span class="text-accent">3 ขั้นตอน</span></h2>
            <div class="how-grid">
                <div class="how-step">
                    <div class="how-num">1</div>
                    <h3>ทักทาย LINE</h3>
                    <p>แอด LINE @Ultramed แจ้งความประสงค์ปรึกษาส่วนตัว ทีมงานจะส่งช่วงเวลาที่ว่างให้เลือก</p>
                </div>
                <div class="how-step">
                    <div class="how-num">2</div>
                    <h3>ส่งข้อมูลล่วงหน้า</h3>
                    <p>ส่งผลเลือดล่าสุด รายการยา/อาหารเสริม และคำถามที่อยากถาม เพื่อให้หมอทิมรีวิวก่อนนัด</p>
                </div>
                <div class="how-step">
                    <div class="how-num">3</div>
                    <h3>พบหมอทิม</h3>
                    <p>เข้าพบที่คลินิกชลบุรี หรือออนไลน์ผ่าน Video Call ตามที่นัดหมาย พร้อมรับแผนดูแลกลับไปทำ</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 5: WHO IS IT FOR ═══ -->
    <section class="for-section">
        <div class="section-inner">
            <span class="section-badge">เหมาะกับใคร</span>
            <h2 class="for-title">การปรึกษาส่วนตัวเหมาะกับคุณถ้า...</h2>
            <div class="for-grid">
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>มีผลเลือดในมือ แต่ไม่เข้าใจว่าแต่ละค่าหมายถึงอะไร และควรทำอย่างไรต่อ</p>
                </div>
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>กำลังตัดสินใจระหว่างแนวทางรักษาหลายแบบ และอยากได้ความเห็นที่สอง</p>
                </div>
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>มีคำถามเกี่ยวกับสุขภาพ ยา หรืออาหารเสริม ที่อยากได้คำตอบแบบละเอียด</p>
                </div>
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>อยากเข้าใจร่างกายตัวเองอย่างลึกซึ้ง ก่อนตัดสินใจลงทุนกับโปรแกรมระยะยาว</p>
                </div>
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>ต้องการแนวทางดูแลสุขภาพเชิงป้องกัน ก่อนที่อาการจะลุกลาม</p>
                </div>
                <div class="for-card">
                    <span class="for-check">✓</span>
                    <p>เคยไปหาหมอหลายที่แล้ว แต่ยังไม่ได้คำตอบที่ชัดเจนพอ</p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 6: FAQ ═══ -->
    <FAQSection items={faqItems} title="คำถามที่พบบ่อยเกี่ยวกับการปรึกษาส่วนตัว" />

    <!-- ═══ SECTION 7: FINAL CTA ═══ -->
    <section class="final-cta-section">
        <div class="section-inner final-cta-inner">
            <h2 class="final-cta-title">
