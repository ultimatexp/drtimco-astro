<style>
:root{--dg:#0a0f0d;--teal:#0f766e;--teal-l:#14b8a6;--gold:#f59e0b;--gold-l:#fbbf24;--surf:#111816;--card:rgba(255,255,255,.04);--brd:rgba(255,255,255,.08);--txt:#f0fdf4;--muted:rgba(255,255,255,.6);--rad:16px;--mx:1100px}
.text-accent{color:var(--teal-l)}.text-white{color:#fff}
.section-inner{max-width:var(--mx);margin:0 auto;padding:80px 24px}
.section-badge{display:inline-block;padding:6px 16px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:rgba(20,184,166,.15);color:var(--teal-l);border:1px solid rgba(20,184,166,.2);margin-bottom:16px}
.section-subtitle{font-size:16px;color:var(--muted);text-align:center;line-height:1.7;margin-bottom:48px}

/* TOP BAR */
.top-bar{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,15,13,.88);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--brd)}
.top-bar-inner{max-width:var(--mx);margin:0 auto;padding:12px 24px;display:flex;align-items:center;gap:24px}
.top-bar-brand{display:flex;align-items:center;gap:8px;color:#fff;font-weight:700;font-size:16px}
.brand-icon{font-size:20px}
.top-bar-nav{display:flex;gap:20px;margin-right:auto}
.top-bar-nav a{font-size:13px;font-weight:500;color:var(--muted);transition:color .2s}
.top-bar-nav a:hover{color:#fff}
.nav-cta-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 20px;background:#06c755;color:#fff;font-size:13px;font-weight:700;border-radius:999px;transition:all .2s}
.nav-cta-btn:hover{background:#05b04a;transform:translateY(-1px);box-shadow:0 4px 16px rgba(6,199,85,.4);color:#fff}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,#0a0f0d 0%,#0d2018 30%,#071a14 70%,#0a0f0d 100%);overflow:hidden;padding-top:80px}
.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(20,184,166,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 30%,rgba(245,158,11,.06) 0%,transparent 50%);pointer-events:none}
.hero-particles{position:absolute;inset:0;background-image:radial-gradient(1px 1px at 10% 20%,rgba(255,255,255,.15),transparent),radial-gradient(1px 1px at 30% 60%,rgba(255,255,255,.1),transparent),radial-gradient(1px 1px at 70% 40%,rgba(255,255,255,.12),transparent),radial-gradient(1px 1px at 90% 80%,rgba(255,255,255,.08),transparent);pointer-events:none;animation:twinkle 8s ease-in-out infinite alternate}
@keyframes twinkle{0%{opacity:.6}100%{opacity:1}}
.hero-content{position:relative;width:100%;max-width:var(--mx);padding:40px 24px}
.hero-grid{display:grid;grid-template-columns:1fr 380px;gap:48px;align-items:center}
.hero-badge-group{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;gap:8px;padding:8px 18px;border-radius:999px;font-size:13px;font-weight:700;letter-spacing:.03em}
.badge-new{background:rgba(20,184,166,.15);color:var(--teal-l);border:1px solid rgba(20,184,166,.3)}
.badge-hot{background:rgba(220,38,38,.12);color:#fca5a5;border:1px solid rgba(220,38,38,.25)}
.badge-pulse{width:8px;height:8px;border-radius:50%;background:#ef4444;animation:pulse-g 2s ease-in-out infinite}
@keyframes pulse-g{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(239,68,68,.4)}50%{opacity:.7;box-shadow:0 0 0 8px rgba(239,68,68,0)}}
.hero-title{font-size:clamp(1.8rem,4vw+.5rem,3.2rem);font-weight:800;line-height:1.2;color:#fff;margin-bottom:20px;letter-spacing:-.02em}
.hero-title-sub{display:block;font-size:.38em;font-weight:700;letter-spacing:.2em;color:var(--teal-l);margin-bottom:8px}
.hero-title-accent{background:linear-gradient(135deg,var(--teal-l),var(--gold-l));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-desc{font-size:17px;line-height:1.7;color:var(--muted);margin-bottom:32px}
.hero-desc strong{color:#fff}
.hero-cta-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px}
.hero-trust{font-size:13px;color:var(--muted)}
.hero-book{position:relative;display:flex;justify-content:center}
.hero-book img{max-width:100%;height:auto;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.5);animation:float 6s ease-in-out infinite}
.book-glow{position:absolute;inset:-20%;background:radial-gradient(circle,rgba(20,184,166,.15) 0%,transparent 70%);pointer-events:none;filter:blur(40px)}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

/* CTA BUTTONS */
.cta-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;border-radius:999px;font-size:17px;font-weight:800;transition:all .3s;text-decoration:none;cursor:pointer;border:none}
.cta-btn-hero,.cta-btn-final{background:#06c755;color:#fff;box-shadow:0 4px 24px rgba(6,199,85,.3);animation:cta-p 3s ease-in-out infinite}
.cta-btn-hero:hover,.cta-btn-final:hover{background:#05b04a;color:#fff;transform:translateY(-3px) scale(1.02);box-shadow:0 8px 32px rgba(6,199,85,.5)}
@keyframes cta-p{0%,100%{box-shadow:0 4px 24px rgba(6,199,85,.3),0 0 0 0 rgba(6,199,85,.3)}50%{box-shadow:0 4px 24px rgba(6,199,85,.3),0 0 0 12px rgba(6,199,85,0)}}
.cta-btn-ghost{background:transparent;color:var(--teal-l);border:2px solid rgba(20,184,166,.3);padding:14px 32px;font-size:15px}
.cta-btn-ghost:hover{background:rgba(20,184,166,.1);border-color:var(--teal-l);color:var(--teal-l);transform:translateY(-2px)}
.cta-btn-urgency{background:var(--gold);color:#0a0f0d;font-size:17px;padding:16px 36px;box-shadow:0 4px 24px rgba(245,158,11,.3)}
.cta-btn-urgency:hover{background:var(--gold-l);transform:translateY(-2px);box-shadow:0 8px 24px rgba(245,158,11,.4);color:#0a0f0d}

/* PAIN SECTION */
.pain-section{background:var(--dg);border-top:1px solid var(--brd)}
.pain-section .section-inner{padding:60px 24px}
.pain-quote-card{max-width:700px;margin:0 auto;text-align:center;background:rgba(220,38,38,.06);border:1px solid rgba(220,38,38,.15);border-radius:var(--rad);padding:48px 36px}
.pain-quote-icon{font-size:48px;margin-bottom:16px}
.pain-blockquote{font-size:clamp(1.1rem,2.5vw,1.4rem);line-height:1.7;color:var(--txt);font-style:italic;margin-bottom:20px}
.pain-blockquote strong{color:#fca5a5}
.pain-sub{color:var(--muted);font-size:15px}

/* TOFI */
.tofi-section{background:linear-gradient(180deg,var(--dg) 0%,var(--surf) 100%)}
.tofi-title{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;color:#fff;text-align:center;margin-bottom:16px}
.tofi-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.tofi-visual img{width:100%;border-radius:var(--rad);box-shadow:0 8px 32px rgba(0,0,0,.3)}
.tofi-causes{display:flex;flex-direction:column;gap:20px}
.cause-card{display:flex;gap:16px;background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:24px;transition:all .3s}
.cause-card:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.12);transform:translateX(4px)}
.cause-icon{font-size:28px;flex-shrink:0;margin-top:2px}
.cause-card h3{font-size:16px;font-weight:700;color:#fff;margin-bottom:6px}
.cause-card p{font-size:14px;color:var(--muted);line-height:1.6}

/* CONTENT / ROADMAP */
.content-section{background:var(--surf)}
.content-title{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;color:#fff;text-align:center;margin-bottom:16px}
.roadmap{display:flex;flex-direction:column;gap:32px}
.roadmap-item{display:flex;gap:24px;align-items:flex-start}
.roadmap-number{width:56px;height:56px;flex-shrink:0;background:linear-gradient(135deg,var(--teal),var(--teal-l));border-radius:50%;display:flex;align-items:center;justify-content:center;margin-top:24px}
.roadmap-number span{font-size:18px;font-weight:800;color:#fff}
.roadmap-card{flex:1;background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:32px;transition:all .3s}
.roadmap-card:hover{background:rgba(255,255,255,.06);border-color:rgba(20,184,166,.2)}
.roadmap-phase{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal-l);margin-bottom:8px}
.roadmap-card h3{font-size:18px;font-weight:700;color:#fff;margin-bottom:8px}
.roadmap-card>p{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px}
.roadmap-types{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.type-card{background:rgba(0,0,0,.3);border-radius:12px;padding:16px;border:1px solid var(--brd)}
.type-card h4{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.type-card p{font-size:12px;color:var(--muted);margin-bottom:8px}
.type-tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px}
.type-tag-caution{background:rgba(220,38,38,.15);color:#fca5a5}
.type-tag-hope{background:rgba(20,184,166,.15);color:var(--teal-l)}
.strategy-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.strategy-item{font-size:13px;color:var(--muted);line-height:1.5;display:flex;gap:8px;align-items:flex-start;background:rgba(0,0,0,.2);padding:12px;border-radius:10px}
.strategy-item strong{color:#fff}
.strategy-icon{font-size:18px;flex-shrink:0}
.engine-highlights{display:flex;flex-direction:column;gap:12px}
.engine-item{font-size:13px;color:var(--muted);line-height:1.5;background:rgba(0,0,0,.2);padding:12px 16px;border-radius:10px;border-left:3px solid var(--teal-l)}
.engine-item strong{color:#fff}
.reset-rules{display:flex;gap:12px;margin-bottom:12px}
.reset-rule{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.3);padding:12px 16px;border-radius:10px;flex:1}
.rule-num{font-size:28px;font-weight:800;color:var(--gold);line-height:1}
.reset-rule span:last-child{font-size:13px;color:var(--muted)}
.reset-bonus{font-size:14px;color:var(--gold-l);font-weight:600}

/* APP SECTION */
.app-section{background:linear-gradient(180deg,var(--surf) 0%,var(--dg) 100%)}
.app-title{font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#fff;text-align:center;margin-bottom:48px}
.app-features{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.app-card{background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:28px;text-align:center;transition:all .3s}
.app-card:hover{background:rgba(255,255,255,.06);transform:translateY(-4px)}
.app-card-featured{border-color:rgba(20,184,166,.3);background:rgba(20,184,166,.06)}
.app-icon{font-size:36px;margin-bottom:12px}
.app-card h3{font-size:16px;font-weight:700;color:#fff;margin-bottom:8px}
.app-card p{font-size:13px;color:var(--muted);line-height:1.6}

/* SOCIAL PROOF */
.proof-section{background:var(--dg);border-top:1px solid var(--brd)}
.proof-title{font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#fff;text-align:center;margin-bottom:48px}
.proof-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:48px}
.proof-card{background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:28px;transition:all .3s}
.proof-card:hover{background:rgba(255,255,255,.06);transform:translateY(-4px)}
.proof-stars{color:var(--gold);font-size:16px;margin-bottom:12px;letter-spacing:2px}
.proof-card blockquote{font-size:14px;color:var(--txt);line-height:1.7;margin-bottom:16px;font-style:italic}
.proof-card strong{color:var(--teal-l)}
.proof-author{display:flex;align-items:center;gap:12px}
.proof-avatar{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--teal),var(--teal-l));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:16px;flex-shrink:0}
.proof-author strong{font-size:14px;color:#fff;display:block}
.proof-author span{font-size:12px;color:var(--muted)}
.proof-stats{display:flex;justify-content:center;gap:48px}
.stat-item{text-align:center}
.stat-number{font-size:clamp(2rem,4vw,3rem);font-weight:800;color:#fff;display:inline}
.stat-plus{font-size:clamp(1rem,2vw,1.5rem);font-weight:700;color:var(--teal-l)}
.stat-label{display:block;font-size:13px;color:var(--muted);margin-top:4px}

/* DOCTOR */
.doctor-section{background:var(--surf);border-top:1px solid var(--brd)}
.doctor-inner{display:grid;grid-template-columns:280px 1fr;gap:48px;align-items:center}
.doctor-photo img{width:100%;border-radius:var(--rad);box-shadow:0 8px 32px rgba(0,0,0,.3)}
.doctor-name{font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#fff;margin-bottom:6px}
.doctor-title-text{font-size:15px;color:var(--teal-l);font-weight:600;margin-bottom:16px}
.doctor-desc{font-size:15px;color:var(--muted);line-height:1.7;margin-bottom:20px;font-style:italic}
.doctor-creds{display:flex;flex-wrap:wrap;gap:12px}
.cred-item{font-size:13px;color:var(--muted);background:var(--card);border:1px solid var(--brd);padding:6px 14px;border-radius:999px}

/* URGENCY */
.urgency-section{background:linear-gradient(135deg,#1a0a00 0%,#2d1600 50%,#1a0a00 100%);border-top:1px solid rgba(245,158,11,.15)}
.urgency-inner{text-align:center;display:flex;flex-direction:column;align-items:center;gap:24px;padding:60px 24px}
.urgency-title{font-size:clamp(1.3rem,3vw,2rem);font-weight:800;color:#fff}
.urgency-desc{font-size:16px;color:var(--muted);line-height:1.7}

/* FINAL CTA */
.final-cta-section{background:linear-gradient(180deg,var(--dg) 0%,#071a14 100%)}
.final-cta-inner{text-align:center;display:flex;flex-direction:column;align-items:center;gap:20px}
.final-cta-title{font-size:clamp(1.4rem,3vw,2.25rem);font-weight:800;color:#fff;line-height:1.3}
.final-cta-desc{font-size:16px;color:var(--muted)}
.final-cta-note{font-size:13px;color:var(--muted)}

/* FOOTER */
.site-footer{background:var(--dg);border-top:1px solid var(--brd)}.site-footer .section-inner{padding:24px;text-align:center}.site-footer p{font-size:13px;color:var(--muted)}.site-footer a{color:var(--teal-l)}

/* MOBILE CTA BAR */
.mobile-cta-bar{position:fixed;bottom:0;left:0;right:0;z-index:99;padding:12px 16px;background:rgba(10,15,13,.95);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-top:1px solid var(--brd);display:none}
.mobile-cta-btn{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;background:#06c755;color:#fff;font-size:16px;font-weight:700;border-radius:999px;text-decoration:none}

/* ═══ RESPONSIVE ═══ */
@media(max-width:900px){
  .hero-grid{grid-template-columns:1fr;text-align:center}
  .hero-badge-group{justify-content:center}
  .hero-cta-row{justify-content:center}
  .hero-book{order:-1;max-width:280px;margin:0 auto}
  .tofi-grid{grid-template-columns:1fr}
  .tofi-visual{max-width:400px;margin:0 auto}
  .roadmap-types{grid-template-columns:1fr}
  .strategy-grid{grid-template-columns:1fr}
  .reset-rules{flex-direction:column}
  .app-features{grid-template-columns:1fr 1fr}
  .proof-grid{grid-template-columns:1fr}
  .doctor-inner{grid-template-columns:1fr;text-align:center}
  .doctor-photo{max-width:200px;margin:0 auto}
  .doctor-creds{justify-content:center}
  .nav-cta-btn{display:none}
}
@media(max-width:640px){
  .section-inner{padding:56px 16px}
  .hero{padding-top:70px}
  .hero-content{padding:24px 16px}
  .hero-book{max-width:220px}
  .top-bar-nav{display:none}
  .app-features{grid-template-columns:1fr}
  .proof-stats{flex-direction:column;gap:24px}
  .roadmap-item{flex-direction:column;align-items:center;text-align:center}
  .roadmap-number{margin-top:0}
  .roadmap-card{padding:24px 20px}
  .engine-item{border-left:none;border-top:3px solid var(--teal-l)}
  .pain-quote-card{padding:32px 20px}
  .mobile-cta-bar{display:block}
  .site-footer .section-inner{padding-bottom:80px}
  .cta-btn{font-size:15px;padding:14px 28px}
  .countdown-hero{gap:8px}
  .cd-num{font-size:20px;min-width:40px;padding:6px 8px}
  .cd-label{font-size:9px}
  .cd-sep{font-size:16px}
  .cd-big-num{font-size:32px;min-width:54px;padding:10px 12px}
  .cd-big-label{font-size:10px}
  .cd-big-sep{font-size:24px}
}

/* COUNTDOWN — Hero */
.countdown-hero{display:flex;align-items:center;gap:12px;margin-bottom:24px}
.cd-item{display:flex;flex-direction:column;align-items:center}
.cd-num{font-size:28px;font-weight:800;color:#fff;background:rgba(20,184,166,.15);border:1px solid rgba(20,184,166,.3);border-radius:10px;min-width:52px;padding:8px 12px;text-align:center;font-variant-numeric:tabular-nums}
.cd-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:4px}
.cd-sep{font-size:24px;font-weight:700;color:var(--teal-l);padding-top:0}

/* COUNTDOWN — Urgency (big) */
.countdown-big{display:flex;align-items:center;justify-content:center;gap:16px;margin:20px 0}
.cd-big-item{display:flex;flex-direction:column;align-items:center}
.cd-big-num{font-size:clamp(2rem,5vw,3.5rem);font-weight:800;color:#fff;background:rgba(245,158,11,.12);border:1px solid rgba(245,158,11,.3);border-radius:12px;min-width:70px;padding:12px 16px;text-align:center;font-variant-numeric:tabular-nums}
.cd-big-label{font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-top:6px}
.cd-big-sep{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:700;color:var(--gold);padding-top:0}

.urgency-note{font-size:13px;color:var(--muted);margin-top:8px}

/* WHO IS THIS FOR */
.whoisfor-section{padding:20px 0;background:linear-gradient(180deg,var(--bg-dark) 0%,rgba(20,184,166,.03) 50%,var(--bg-dark) 100%)}
.whoisfor-title{font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:800;text-align:center;color:#fff;margin-bottom:8px}
.whoisfor-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:40px}
.whoisfor-col{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:16px;overflow:hidden}
.whoisfor-col-header{padding:28px 24px 20px;text-align:center}
.whoisfor-col-header h3{font-size:1.3rem;font-weight:700;color:#fff;margin:8px 0 4px}
.whoisfor-col-header p{font-size:14px;color:var(--muted);margin:0}
.whoisfor-header-icon{font-size:40px;display:block;margin-bottom:4px}
.whoisfor-header-self{background:linear-gradient(135deg,rgba(20,184,166,.12) 0%,rgba(20,184,166,.04) 100%);border-bottom:2px solid rgba(20,184,166,.2)}
.whoisfor-header-gift{background:linear-gradient(135deg,rgba(245,158,11,.12) 0%,rgba(245,158,11,.04) 100%);border-bottom:2px solid rgba(245,158,11,.2)}
.whoisfor-list{padding:16px 20px 24px}
.whoisfor-item{display:flex;gap:14px;align-items:flex-start;padding:14px 16px;border-radius:12px;margin-bottom:8px;transition:background .2s}
.whoisfor-item:hover{background:rgba(255,255,255,.04)}
.whoisfor-item:last-child{margin-bottom:0}
.whoisfor-emoji{font-size:26px;flex-shrink:0;width:36px;height:36px;display:flex;align-items:center;justify-content:center;border-radius:10px}
.whoisfor-item-self .whoisfor-emoji{background:rgba(20,184,166,.1)}
.whoisfor-item-gift .whoisfor-emoji{background:rgba(245,158,11,.1)}
.whoisfor-item strong{display:block;color:#fff;font-size:15px;font-weight:600;margin-bottom:3px}
.whoisfor-item p{font-size:13px;color:var(--muted);margin:0;line-height:1.5}
.whoisfor-cta-wrap{text-align:center;margin-top:36px}

@media(max-width:768px){
  .whoisfor-grid{grid-template-columns:1fr}
}
</style>


<script define:vars={{ launchDate }}>
  // ═══ COUNTDOWN TIMER ═══
  const LAUNCH = new Date(launchDate).getTime();
  function pad(n) { return String(n).padStart(2, '0'); }
  function updateCountdown() {
    const now = Date.now();
    const diff = Math.max(0, LAUNCH - now);
    const d = Math.floor(diff / 86400000);
    const h = Math.floor((diff % 86400000) / 3600000);
    const m = Math.floor((diff % 3600000) / 60000);
    const s = Math.floor((diff % 60000) / 1000);
    // Hero countdown
    const $dd = document.getElementById('cd-days');
    if ($dd) { $dd.textContent = pad(d); document.getElementById('cd-hours').textContent = pad(h); document.getElementById('cd-mins').textContent = pad(m); document.getElementById('cd-secs').textContent = pad(s); }
    // Urgency countdown
    const $dd2 = document.getElementById('cd2-days');
    if ($dd2) { $dd2.textContent = pad(d); document.getElementById('cd2-hours').textContent = pad(h); document.getElementById('cd2-mins').textContent = pad(m); document.getElementById('cd2-secs').textContent = pad(s); }
    if (diff <= 0) {
      document.querySelectorAll('.cta-btn-hero, .cta-btn-final, .cta-btn-urgency, .mobile-cta-btn').forEach(function(el) {
        el.textContent = '🎉 เปิดขายแล้ว! สั่งซื้อเลย';
      });
    }
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);

  // ═══ STAT COUNTER ═══
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        const nums = entry.target.querySelectorAll('.stat-number[data-target]');
        nums.forEach(function(el) {
          const target = parseInt(el.getAttribute('data-target') || '0');
          let current = 0;
          const step = Math.ceil(target / 50);
          const timer = setInterval(function() {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = current.toLocaleString();
          }, 30);
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.3 });
  const statsEl = document.querySelector('.proof-stats');
  if (statsEl) observer.observe(statsEl);

  // ═══ SCROLL REVEAL ═══
  const revealEls = document.querySelectorAll('.roadmap-item, .cause-card, .app-card, .proof-card, .whoisfor-item');
  const revealObs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry, i) {
      if (entry.isIntersecting) {
        setTimeout(function() { entry.target.classList.add('revealed'); }, i * 80);
        revealObs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  revealEls.forEach(function(el) { el.style.opacity = '0'; el.style.transform = 'translateY(24px)'; el.style.transition = 'opacity .5s ease, transform .5s ease'; revealObs.observe(el); });
  document.head.insertAdjacentHTML('beforeend', '<style>.revealed{opacity:1!important;transform:translateY(0)!important}</style>');
</script>
