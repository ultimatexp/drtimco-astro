.section-inner{max-width:var(--mx);margin:0 auto;padding:80px 24px}
.section-badge{display:inline-block;padding:6px 16px;border-radius:999px;font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:rgba(20,184,166,.15);color:var(--teal-l);border:1px solid rgba(20,184,166,.2);margin-bottom:16px}
.section-subtitle{font-size:16px;color:var(--muted);text-align:center;line-height:1.7;margin-bottom:48px}

/* TOP BAR */
.top-bar{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,15,13,.88);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid var(--brd)}
.top-bar-inner{max-width:var(--mx);margin:0 auto;padding:12px 24px;display:flex;align-items:center;gap:24px}
.top-bar-brand{display:flex;align-items:center;gap:8px;color:#fff;font-weight:700;font-size:16px}
.brand-icon{font-size:20px}
.top-bar-nav{display:flex;gap:20px;margin-right:auto}
.top-bar-nav a{font-size:13px;font-weight:500;color:var(--muted);transition:color .2s}
.top-bar-nav a:hover{color:#fff}
.nav-cta-btn{display:inline-flex;align-items:center;gap:6px;padding:8px 20px;background:#06c755;color:#fff;font-size:13px;font-weight:700;border-radius:999px;transition:all .2s}
.nav-cta-btn:hover{background:#05b04a;transform:translateY(-1px);box-shadow:0 4px 16px rgba(6,199,85,.4);color:#fff}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(160deg,#0a0f0d 0%,#0d2018 30%,#071a14 70%,#0a0f0d 100%);overflow:hidden;padding-top:80px}
.hero-overlay{position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(20,184,166,.08) 0%,transparent 60%),radial-gradient(ellipse at 80% 30%,rgba(245,158,11,.06) 0%,transparent 50%);pointer-events:none}
.hero-particles{position:absolute;inset:0;background-image:radial-gradient(1px 1px at 10% 20%,rgba(255,255,255,.15),transparent),radial-gradient(1px 1px at 30% 60%,rgba(255,255,255,.1),transparent),radial-gradient(1px 1px at 70% 40%,rgba(255,255,255,.12),transparent),radial-gradient(1px 1px at 90% 80%,rgba(255,255,255,.08),transparent);pointer-events:none;animation:twinkle 8s ease-in-out infinite alternate}
@keyframes twinkle{0%{opacity:.6}100%{opacity:1}}
.hero-content{position:relative;width:100%;max-width:var(--mx);padding:40px 24px}
.hero-grid{display:grid;grid-template-columns:1fr 380px;gap:48px;align-items:center}
.hero-badge-group{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap}
.badge{display:inline-flex;align-items:center;gap:8px;padding:8px 18px;border-radius:999px;font-size:13px;font-weight:700;letter-spacing:.03em}
.badge-new{background:rgba(20,184,166,.15);color:var(--teal-l);border:1px solid rgba(20,184,166,.3)}
.badge-hot{background:rgba(220,38,38,.12);color:#fca5a5;border:1px solid rgba(220,38,38,.25)}
.badge-pulse{width:8px;height:8px;border-radius:50%;background:#ef4444;animation:pulse-g 2s ease-in-out infinite}
@keyframes pulse-g{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(239,68,68,.4)}50%{opacity:.7;box-shadow:0 0 0 8px rgba(239,68,68,0)}}
.hero-title{font-size:clamp(1.8rem,4vw+.5rem,3.2rem);font-weight:800;line-height:1.2;color:#fff;margin-bottom:20px;letter-spacing:-.02em}
.hero-title-sub{display:block;font-size:.38em;font-weight:700;letter-spacing:.2em;color:var(--teal-l);margin-bottom:8px}
.hero-title-accent{background:linear-gradient(135deg,var(--teal-l),var(--gold-l));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-desc{font-size:17px;line-height:1.7;color:var(--muted);margin-bottom:32px}
.hero-desc strong{color:#fff}
.hero-cta-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:16px}
.hero-trust{font-size:13px;color:var(--muted)}
.hero-book{position:relative;display:flex;justify-content:center}
.hero-book img{max-width:100%;height:auto;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.5);animation:float 6s ease-in-out infinite}
.book-glow{position:absolute;inset:-20%;background:radial-gradient(circle,rgba(20,184,166,.15) 0%,transparent 70%);pointer-events:none;filter:blur(40px)}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

/* BOOK LAUNCH EVENT BANNER */
.event-launch-section{
  position:relative;
  overflow:hidden;
  padding:80px 24px;
  background:
    radial-gradient(circle at 16% 18%,rgba(255,190,111,.34),transparent 26%),
    linear-gradient(135deg,#fff6e8 0%,#f6d19d 50%,#db7742 100%);
  color:#321c12;
}
.event-launch-shell{
  position:relative;
  max-width:var(--mx);
  margin:0 auto;
  overflow:hidden;
  border:1px solid rgba(255,255,255,.58);
  border-radius:34px;
  background:linear-gradient(120deg,rgba(255,250,242,.94),rgba(255,236,207,.78) 50%,rgba(233,120,40,.22));
  box-shadow:0 24px 80px rgba(124,61,20,.18);
}
.event-launch-grid{
  position:relative;
  z-index:2;
  display:grid;
  grid-template-columns:minmax(0,1fr) minmax(330px,430px);
  gap:44px;
  align-items:center;
  padding:clamp(28px,5vw,58px);
}
.event-orb,.event-line{position:absolute;pointer-events:none}
.event-orb{border-radius:999px;animation:event-float 12s ease-in-out infinite}
.event-orb-one{width:420px;height:420px;right:-180px;top:-150px;background:radial-gradient(circle,rgba(233,120,40,.32),transparent 68%)}
.event-orb-two{width:300px;height:300px;left:-150px;bottom:-130px;background:radial-gradient(circle,rgba(223,127,100,.28),transparent 68%);animation-delay:-4s}
.event-line{opacity:.32;border-color:rgba(97,50,24,.2)}
.event-line-one{width:190px;height:190px;right:10%;top:12%;border-top:1px solid;border-right:1px solid;border-radius:0 110px 0 0}
.event-line-two{width:130px;height:130px;left:6%;bottom:10%;border-bottom:1px solid;border-left:1px solid;border-radius:0 0 0 80px}
.event-logo-row{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:28px}
.event-logo-pill{display:inline-flex;align-items:center;gap:10px;min-height:42px;padding:8px 14px;border:1px solid rgba(97,50,24,.16);border-radius:999px;background:rgba(255,255,255,.64);color:#6d4632;font-size:13px;font-weight:800}
.event-logo-pill img{width:28px;height:28px;border-radius:999px;object-fit:cover}
.event-eyebrow{display:inline-flex;align-items:center;gap:10px;margin:0 0 14px;color:#c65318;font-size:14px;font-weight:900;letter-spacing:.1em;text-transform:uppercase}
.event-eyebrow:before{content:"";width:42px;height:1px;background:currentColor}
.event-title{max-width:720px;margin:0;color:#321c12;font-family:Georgia,"Times New Roman",serif;font-size:clamp(2rem,4.2vw,4rem);font-weight:700;line-height:1.08;letter-spacing:-.045em}
.event-title span{display:block;color:#c65318}
.event-subtitle{margin:18px 0 0;color:#6d4632;font-size:clamp(1rem,2vw,1.28rem);font-weight:900}
.event-description{max-width:620px;margin:12px 0 0;color:rgba(50,28,18,.78);font-size:16px;line-height:1.75}
.event-meta{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:24px}
.event-meta-card{display:flex;gap:12px;align-items:flex-start;padding:14px;border:1px solid rgba(97,50,24,.14);border-radius:18px;background:rgba(255,255,255,.62);box-shadow:0 10px 30px rgba(97,50,24,.08)}
.event-meta-icon{display:grid;width:34px;height:34px;flex:0 0 auto;place-items:center;border-radius:999px;background:#fff0dc;color:#c65318;font-weight:900}
.event-meta-card strong,.event-meta-card span{display:block}
.event-meta-card strong{color:#321c12;font-size:15px}
.event-meta-card span{margin-top:2px;color:#6d4632;font-size:13px;font-weight:800}
.event-map-link{display:inline-block;margin-top:2px;color:#c65318;font-size:13px;font-weight:900;text-decoration:underline;text-underline-offset:3px}
.event-map-link:hover{color:#321c12}
.event-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:26px}
.event-btn{display:inline-flex;min-height:52px;align-items:center;justify-content:center;border-radius:999px;font-size:16px;font-weight:900;transition:transform .18s ease,box-shadow .18s ease,background .18s ease}
.event-btn:hover{transform:translateY(-3px)}
.event-btn-primary{padding:16px 24px;background:linear-gradient(135deg,#e97828,#c65318);color:#fff;box-shadow:0 14px 34px rgba(198,83,24,.3)}
.event-btn-secondary{padding:15px 22px;border:1px solid rgba(97,50,24,.22);background:rgba(255,255,255,.54);color:#321c12}
.event-visual{position:relative}
.event-doctor-card{position:relative;display:grid;align-items:end;min-height:520px;overflow:hidden;border:1px solid rgba(255,255,255,.6);border-radius:38px;background:radial-gradient(circle at 50% 30%,rgba(255,255,255,.82),transparent 28%),linear-gradient(160deg,#ffe3b4 0%,#f1a45e 56%,#c95525 100%);box-shadow:0 18px 50px rgba(89,42,15,.16)}
.event-doctor-card:before{position:absolute;inset:9%;border:1px solid rgba(255,255,255,.36);border-radius:999px 999px 34px 34px;content:""}
.event-doctor-card img{position:relative;z-index:2;width:min(84%,420px);margin:0 auto;filter:drop-shadow(0 24px 34px rgba(79,35,12,.22))}
.event-doctor-placeholder{position:absolute;inset:18% 12% 28%;z-index:1;display:grid;place-items:center;border:1px solid rgba(255,255,255,.42);border-radius:999px 999px 34px 34px;color:rgba(50,28,18,.45);text-align:center}
.event-doctor-placeholder span{display:block;font-family:Georgia,"Times New Roman",serif;font-size:clamp(2.4rem,5vw,4.2rem);font-weight:700}
.event-doctor-placeholder small{display:block;margin-top:4px;font-size:11px;font-weight:900;letter-spacing:.14em;text-transform:uppercase}
.event-poster-label{position:absolute;right:12px;top:12px;z-index:4;padding:9px 11px;border-radius:999px;background:rgba(255,255,255,.55);color:rgba(50,28,18,.64);font-size:11px;font-weight:900;letter-spacing:.08em}
.event-book-badge{position:absolute;left:-4px;top:18%;z-index:5;padding:12px 16px;border-radius:999px;background:#321c12;color:#fff8ec;box-shadow:0 18px 40px rgba(50,28,18,.22);font-size:14px;font-weight:900}
.event-floating-card{position:absolute;right:28px;bottom:28px;z-index:5;width:min(78%,270px);padding:18px;border:1px solid rgba(255,255,255,.7);border-radius:22px;background:rgba(255,250,242,.92);box-shadow:0 18px 50px rgba(92,39,12,.18);animation:event-card-drift 6.8s ease-in-out infinite}
.event-floating-card small{display:block;color:#c65318;font-size:11px;font-weight:900;letter-spacing:.11em}
.event-floating-card strong{display:block;margin-top:6px;color:#321c12;font-family:Georgia,"Times New Roman",serif;font-size:24px;line-height:1.16}
.event-reveal{opacity:0;transform:translateY(20px);animation:event-rise .72s ease forwards}
.event-reveal:nth-child(2){animation-delay:.08s}.event-reveal:nth-child(3){animation-delay:.16s}.event-reveal:nth-child(4){animation-delay:.24s}.event-reveal:nth-child(5){animation-delay:.32s}.event-reveal:nth-child(6){animation-delay:.4s}
@keyframes event-rise{to{opacity:1;transform:translateY(0)}}
@keyframes event-float{0%,100%{transform:translate3d(0,0,0) scale(1)}50%{transform:translate3d(-18px,18px,0) scale(1.04)}}
@keyframes event-card-drift{0%,100%{transform:translate3d(0,0,0)}50%{transform:translate3d(-8px,-12px,0)}}


/* MALI METABOLIC SCREENING PACKAGE BANNER */
.event-package-banner {
  position: relative;
  z-index: 3;
  margin: 0 clamp(16px, 4vw, 44px) clamp(24px, 5vw, 44px);
  padding: clamp(20px, 4vw, 36px);
  border-top: 1px dashed rgba(97,50,24,0.25);
  background: rgba(255, 255, 255, 0.45);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 24px;
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 16px 40px rgba(97,50,24,0.06);
}
.event-package-header {
  text-align: center;
  margin-bottom: 28px;
}
.event-package-tag {
  display: inline-block;
  padding: 4px 12px;
  background: #c65318;
  color: #fff;
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.1em;
  border-radius: 99px;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.event-package-title {
  margin: 0;
  font-family: Georgia, "Times New Roman", serif;
  font-size: clamp(1.35rem, 2.5vw, 1.68rem);
  font-weight: 700;
  color: #321c12;
  letter-spacing: -0.02em;
}
.event-package-subtitle {
  margin: 6px 0 0;
  font-size: 15px;
  color: #6d4632;
  font-weight: 800;
}
.event-package-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  margin-bottom: 28px;
}
.event-package-col {
  display: flex;
  flex-direction: column;
}
.event-package-col-title {
  font-size: 14px;
  font-weight: 900;
  color: #321c12;
  margin-bottom: 12px;
  border-bottom: 2px solid rgba(97,50,24,0.12);
  padding-bottom: 6px;
}
.event-package-list {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.event-package-list li {
  position: relative;
  padding-left: 24px;
  font-size: 14px;
  line-height: 1.6;
  color: rgba(50,28,18,0.85);
}
.event-package-list li::before {
  content: "✓";
  position: absolute;
  left: 0;
  top: 0;
  color: #c65318;
  font-weight: 900;
  font-size: 15px;
}
.event-package-list-gift li::before {
  content: "★";
  color: #e97828;
}
.event-package-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
  border-top: 1px solid rgba(97,50,24,0.12);
  padding-top: 24px;
  flex-wrap: wrap;
}
.event-package-price {
  display: flex;
  flex-direction: column;
}
.price-label {
  font-size: 12px;
  color: #6d4632;
  font-weight: 800;
  text-transform: uppercase;
}
.price-value {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 38px;
  font-weight: 800;
  color: #c65318;
  line-height: 1;
  margin-top: 4px;
}
.price-unit {
  font-size: 18px;
  font-weight: 700;
  color: #321c12;
}
.event-package-btn {
  min-height: 48px !important;
  font-size: 15px !important;
  padding: 12px 32px !important;
}

@media(max-width: 768px) {
  .event-package-body {
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .event-package-footer {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
}

/* CTA BUTTONS */
.cta-btn{display:inline-flex;align-items:center;gap:10px;padding:16px 36px;border-radius:999px;font-size:17px;font-weight:800;transition:all .3s;text-decoration:none;cursor:pointer;border:none}
.cta-btn-hero,.cta-btn-final{background:#06c755;color:#fff;box-shadow:0 4px 24px rgba(6,199,85,.3);animation:cta-p 3s ease-in-out infinite}
.cta-btn-hero:hover,.cta-btn-final:hover{background:#05b04a;color:#fff;transform:translateY(-3px) scale(1.02);box-shadow:0 8px 32px rgba(6,199,85,.5)}
@keyframes cta-p{0%,100%{box-shadow:0 4px 24px rgba(6,199,85,.3),0 0 0 0 rgba(6,199,85,.3)}50%{box-shadow:0 4px 24px rgba(6,199,85,.3),0 0 0 12px rgba(6,199,85,0)}}
.cta-btn-ghost{background:transparent;color:var(--teal-l);border:2px solid rgba(20,184,166,.3);padding:14px 32px;font-size:15px}
.cta-btn-ghost:hover{background:rgba(20,184,166,.1);border-color:var(--teal-l);color:var(--teal-l);transform:translateY(-2px)}
.cta-btn-urgency{background:var(--gold);color:#0a0f0d;font-size:17px;padding:16px 36px;box-shadow:0 4px 24px rgba(245,158,11,.3)}
.cta-btn-urgency:hover{background:var(--gold-l);transform:translateY(-2px);box-shadow:0 8px 24px rgba(245,158,11,.4);color:#0a0f0d}

/* PAIN SECTION */
.pain-section{background:var(--dg);border-top:1px solid var(--brd)}
.pain-section .section-inner{padding:60px 24px}
.pain-quote-card{max-width:700px;margin:0 auto;text-align:center;background:rgba(220,38,38,.06);border:1px solid rgba(220,38,38,.15);border-radius:var(--rad);padding:48px 36px}
.pain-quote-icon{font-size:48px;margin-bottom:16px}
.pain-blockquote{font-size:clamp(1.1rem,2.5vw,1.4rem);line-height:1.7;color:var(--txt);font-style:italic;margin-bottom:20px}
.pain-blockquote strong{color:#fca5a5}
.pain-sub{color:var(--muted);font-size:15px}

/* TOFI */
.tofi-section{background:linear-gradient(180deg,var(--dg) 0%,var(--surf) 100%)}
.tofi-title{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;color:#fff;text-align:center;margin-bottom:16px}
.tofi-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
.tofi-visual img{width:100%;border-radius:var(--rad);box-shadow:0 8px 32px rgba(0,0,0,.3)}
.tofi-causes{display:flex;flex-direction:column;gap:20px}
.cause-card{display:flex;gap:16px;background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:24px;transition:all .3s}
.cause-card:hover{background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.12);transform:translateX(4px)}
.cause-icon{font-size:28px;flex-shrink:0;margin-top:2px}
.cause-card h3{font-size:16px;font-weight:700;color:#fff;margin-bottom:6px}
.cause-card p{font-size:14px;color:var(--muted);line-height:1.6}

/* CONTENT / ROADMAP */
.content-section{background:var(--surf)}
.content-title{font-size:clamp(1.5rem,3vw,2.5rem);font-weight:800;color:#fff;text-align:center;margin-bottom:16px}
.roadmap{display:flex;flex-direction:column;gap:32px}
.roadmap-item{display:flex;gap:24px;align-items:flex-start}
.roadmap-number{width:56px;height:56px;flex-shrink:0;background:linear-gradient(135deg,var(--teal),var(--teal-l));border-radius:50%;display:flex;align-items:center;justify-content:center;margin-top:24px}
.roadmap-number span{font-size:18px;font-weight:800;color:#fff}
.roadmap-card{flex:1;background:var(--card);border:1px solid var(--brd);border-radius:var(--rad);padding:32px;transition:all .3s}
.roadmap-card:hover{background:rgba(255,255,255,.06);border-color:rgba(20,184,166,.2)}
.roadmap-phase{display:inline-block;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--teal-l);margin-bottom:8px}
.roadmap-card h3{font-size:18px;font-weight:700;color:#fff;margin-bottom:8px}
.roadmap-card>p{font-size:14px;color:var(--muted);line-height:1.6;margin-bottom:16px}
.roadmap-types{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.type-card{background:rgba(0,0,0,.3);border-radius:12px;padding:16px;border:1px solid var(--brd)}
.type-card h4{font-size:14px;font-weight:700;color:#fff;margin-bottom:4px}
.type-card p{font-size:12px;color:var(--muted);margin-bottom:8px}
.type-tag{display:inline-block;font-size:11px;font-weight:700;padding:3px 10px;border-radius:999px}
.type-tag-caution{background:rgba(220,38,38,.15);color:#fca5a5}
.type-tag-hope{background:rgba(20,184,166,.15);color:var(--teal-l)}
.strategy-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.strategy-item{font-size:13px;color:var(--muted);line-height:1.5;display:flex;gap:8px;align-items:flex-start;background:rgba(0,0,0,.2);padding:12px;border-radius:10px}
.strategy-item strong{color:#fff}
.strategy-icon{font-size:18px;flex-shrink:0}
.engine-highlights{display:flex;flex-direction:column;gap:12px}
.engine-item{font-size:13px;color:var(--muted);line-height:1.5;background:rgba(0,0,0,.2);padding:12px 16px;border-radius:10px;border-left:3px solid var(--teal-l)}
.engine-item strong{color:#fff}
.reset-rules{display:flex;gap:12px;margin-bottom:12px}
.reset-rule{display:flex;align-items:center;gap:10px;background:rgba(0,0,0,.3);padding:12px 16px;border-radius:10px;flex:1}
.rule-num{font-size:28px;font-weight:800;color:var(--gold);line-height:1}
.reset-rule span:last-child{font-size:13px;color:var(--muted)}
.reset-bonus{font-size:14px;color:var(--gold-l);font-weight:600}

/* APP SECTION */
.app-section{background:linear-gradient(180deg,var(--surf) 0%,var(--dg) 100%)}
.app-title{font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:#fff;text-align:center;margin-bottom:48px}
.app-features{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
