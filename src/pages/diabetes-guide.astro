---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQSection from "../components/FAQSection.astro";

const buyUrl = "https://www.fitkub.com/order/d6c2c53b-a627-4cc1-bb14-5fa3c0338bbe";
const launchDate = "2026-06-20T00:00:00+07:00";

const faqItems = [
  { question: "คู่มือนี้เหมาะกับใคร?", answer: "เหมาะกับคนที่มีรูปร่างผอมหรือน้ำหนักปกติ แต่ได้รับการวินิจฉัยว่าเป็นเบาหวาน หรือมีภาวะก่อนเบาหวาน (Prediabetes) รวมถึงคนที่สงสัยว่าตัวเองอาจมีภาวะ TOFI (ผอมนอก อ้วนใน)" },
  { question: "คู่มือนี้ต่างจากหนังสือเบาหวานทั่วไปอย่างไร?", answer: "หนังสือเบาหวานส่วนใหญ่เน้นให้ 'ลดน้ำหนัก' ซึ่งใช้ไม่ได้กับคนผอม คู่มือนี้ออกแบบเฉพาะสำหรับเบาหวานผอม เน้นแก้ปัญหาที่ต้นเหตุ ได้แก่ ไขมันซ่อนในท้อง กล้ามเนื้อน้อย และดื้ออินซูลินที่ซ่อนอยู่" },
  { question: "FITKUB App คืออะไร? ต้องจ่ายเพิ่มไหม?", answer: "FITKUB คือแอปผู้ช่วยดิจิทัลที่ผสานกับคู่มือ มี AI Coach, ระบบบันทึกอาหาร, และวิเคราะห์ผลเลือด ดาวน์โหลดฟรี โดยมีฟีเจอร์พื้นฐานให้ใช้งานได้ทันที" },
  { question: "ต้องมีความรู้ทางการแพทย์ก่อนไหม?", answer: "ไม่ต้องเลย คู่มือเขียนด้วยภาษาง่ายๆ เข้าใจได้ทันที พร้อมรูปภาพประกอบ และ Checklist ที่ทำตามได้ทีละขั้นตอน" },
  { question: "อ่านแล้วต้องหยุดยาเบาหวานเองไหม?", answer: "ห้ามหยุดยาเอง คู่มือนี้ให้ความรู้เพื่อให้คุณเข้าใจร่างกายตัวเอง และนำไปพูดคุยกับแพทย์ประจำตัวเพื่อปรับแผนการรักษาอย่างปลอดภัย" },
  { question: "ซื้อแล้วได้รับคู่มืออย่างไร?", answer: "สั่งซื้อผ่านหน้าออเดอร์ Fitkub แล้วรับคู่มือฉบับดิจิทัล (PDF) + สิทธิ์เข้าถึง FITKUB App ทันที หรือเลือกรับเป็นหนังสือเล่มจัดส่งถึงบ้าน" },
];

const breadcrumbs = [
  { name: "หน้าแรก", url: "https://drtim.co/" },
  { name: "คู่มือพิชิตเบาหวานผอม", url: "https://drtim.co/diabetes-guide" },
];
---

<BaseLayout
  title="คู่มือพิชิตเบาหวาน: สำหรับเบาหวานผอม | Dr. Tim"
  description="คู่มือฉบับใหม่สำหรับคนผอมที่เป็นเบาหวาน ปัญหา TOFI ดื้ออินซูลินซ่อน แผนกู้คืนระบบเผาผลาญ สร้างกล้ามเนื้อพิชิตน้ำตาล พร้อม FITKUB AI Coach โดย Dr. Tim"
  ogImage="https://drtim.co/images/diabetes-guide/ChatGPT%20Image%20Apr%2024%2C%202026%2C%2008_20_15%20PM.png"
  type="website"
  faqItems={faqItems}
  breadcrumbs={breadcrumbs}
  directAnswer="คู่มือพิชิตเบาหวานสำหรับเบาหวานผอม เปิดเผยปัญหา TOFI (ผอมนอก อ้วนใน) และแผนกู้คืนระบบเผาผลาญที่ออกแบบเฉพาะสำหรับคนผอมที่เป็นเบาหวาน พร้อม FITKUB AI Coach ติดตามผลแม่นยำ"
>
  <!-- ═══ STICKY TOP BAR ═══ -->
  <header class="top-bar">
    <div class="top-bar-inner">
      <a href="/" class="top-bar-brand">
        <span class="brand-icon">⚕</span>
        <span class="brand-name">Dr. Tim</span>
      </a>
      <nav class="top-bar-nav">
        <a href="/">หน้าแรก</a>
        <a href="/cgm">คอร์ส CGM</a>
        <a href="/vip-coaching">VIP Coaching</a>
        <a href="/consult">ปรึกษาส่วนตัว</a>
        <a href="/diabetes-guide">หนังสือเบาหวานผอม</a>
      </nav>
      <a href={buyUrl} target="_blank" rel="noopener" class="nav-cta-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"></path></svg>
        สั่งจอง 459 บาท
      </a>
    </div>
  </header>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <div class="hero-particles"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="hero-badge-group">
            <span class="badge badge-new">📘 Pre-Order ราคา 459 บาท (จาก 545 บาท)</span>
            <span class="badge badge-hot">
              <span class="badge-pulse"></span>
              ⏰ เปิดขายอย่างเป็นทางการ 20 มิ.ย. 2026
            </span>
          </div>
          <!-- COUNTDOWN TIMER -->
          <div class="countdown-hero" id="hero-countdown">
            <div class="cd-item"><span class="cd-num" id="cd-days">--</span><span class="cd-label">วัน</span></div>
            <div class="cd-sep">:</div>
            <div class="cd-item"><span class="cd-num" id="cd-hours">--</span><span class="cd-label">ชั่วโมง</span></div>
            <div class="cd-sep">:</div>
            <div class="cd-item"><span class="cd-num" id="cd-mins">--</span><span class="cd-label">นาที</span></div>
            <div class="cd-sep">:</div>
            <div class="cd-item"><span class="cd-num" id="cd-secs">--</span><span class="cd-label">วินาที</span></div>
          </div>
          <h1 class="hero-title">
            <span class="hero-title-sub">DIABETES CONQUEST GUIDE</span>
            คู่มือพิชิต<span class="hero-title-accent">เบาหวาน</span><br/>
            สำหรับ "เบาหวานผอม"
          </h1>
          <p class="hero-desc">
            เปิดเผยความจริงที่ไม่มีใครเคยบอกคุณ —<br/>
            ทำไมคนผอมถึงเป็นเบาหวาน? และจะ<strong>รักษาให้หายขาด</strong>ได้อย่างไร<br/>
            พร้อม <strong>FITKUB AI Coach</strong> ผู้ช่วยดิจิทัลส่วนตัว
          </p>
          <div class="hero-cta-row">
            <a href={buyUrl} target="_blank" rel="noopener" class="cta-btn cta-btn-hero" id="hero-cta">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"></path></svg>
              🛒 สั่งจอง 459 บาท
            </a>
            <a href="#content-preview" class="cta-btn cta-btn-ghost">ดูเนื้อหาภายใน ↓</a>
          </div>
          <p class="hero-trust">✓ ราคาปกติ 545 บาท &nbsp;·&nbsp; ✓ Pre-Order 459 บาท (ลด 15%) &nbsp;·&nbsp; ✓ เขียนโดยแพทย์</p>
        </div>
        <div class="hero-book">
          <div class="book-glow"></div>
          <img src="/images/diabetes-guide/ChatGPT%20Image%20Apr%2024%2C%202026%2C%2008_20_15%20PM.png" alt="คู่มือพิชิตเบาหวาน สำหรับเบาหวานผอม" width="400" height="500" loading="eager"/>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ BOOK LAUNCH EVENT BANNER ═══ -->
  <section class="event-launch-section" aria-labelledby="event-launch-title">
    <div class="event-launch-shell">
      <span class="event-orb event-orb-one" aria-hidden="true"></span>
      <span class="event-orb event-orb-two" aria-hidden="true"></span>
      <span class="event-line event-line-one" aria-hidden="true"></span>
      <span class="event-line event-line-two" aria-hidden="true"></span>

      <div class="event-launch-grid">
        <div class="event-launch-copy">
          <div class="event-logo-row event-reveal">
            <span class="event-logo-pill">
              <img src="/images/logo-mali-care.png" alt="โลโก้ มะลิแคร์" onerror="this.style.display='none'" />
              <span>Mali Care</span>
            </span>
            <span class="event-logo-pill">
              <img src="/images/logo-partner.jpg" alt="โลโก้พาร์ทเนอร์" onerror="this.style.display='none'" />
              <span>Dr. Tim</span>
            </span>
          </div>

          <p class="event-eyebrow event-reveal">งานสุขภาพและเปิดตัวหนังสือ</p>
          <h2 id="event-launch-title" class="event-title event-reveal">
            งานเปิดตัวหนังสือ
            <span>“คู่มือพิชิตเบาหวานสำหรับเบาหวานผอม”</span>
          </h2>
          <p class="event-subtitle event-reveal">โดยหมอทิม ร่วมกับ มะลิแคร์</p>
          <p class="event-description event-reveal">
            เปิดตัวหนังสือ พร้อมบรรยายเรื่องระบบเผาผลาญ แนะนำบริการของมะลิแคร์ และช่วงถาม-ตอบ
          </p>

          <div class="event-meta event-reveal">
            <div class="event-meta-card">
              <span class="event-meta-icon">20</span>
              <div>
                <strong>20 มิถุนายน 2569</strong>
                <span>09:00 - 12:00 น.</span>
              </div>
            </div>
            <div class="event-meta-card">
              <span class="event-meta-icon">📍</span>
              <div>
                <strong>สถานที่จัดงาน</strong>
                <a class="event-map-link" href="https://maps.app.goo.gl/nbf8SDiAreCwPTzP8" target="_blank" rel="noopener">
                  มะลิแคร์
                </a>
              </div>
            </div>
          </div>

          <div class="event-actions event-reveal">
            <a class="event-btn event-btn-primary" href="#final-cta">ลงทะเบียนเข้าร่วมงาน</a>
            <a class="event-btn event-btn-secondary" href="https://maps.app.goo.gl/nbf8SDiAreCwPTzP8" target="_blank" rel="noopener">
              ดูแผนที่
            </a>
          </div>
        </div>

        <div class="event-visual event-reveal" aria-label="พื้นที่รูปหมอทิม">
          <div class="event-doctor-card">
            <span class="event-poster-label">4:5 EVENT POSTER</span>
            <span class="event-book-badge">เปิดตัวหนังสือ</span>
            <div class="event-doctor-placeholder" aria-hidden="true">
              <span>Dr. Tim</span>
              <small>Doctor Image</small>
            </div>
            <img src="/images/drtim.png" alt="หมอทิม" loading="lazy" onerror="this.style.display='none'" />
            <div class="event-floating-card">
              <small>ราคาพิเศษ</small>
              <strong>410 บาท</strong>
            </div>
          </div>
      </div>

      <!-- ═══ MALI METABOLIC SCREENING BANNER ═══ -->
      <div class="event-package-banner event-reveal">
        <div class="event-package-header">
          <span class="event-package-tag">MALI CARE SPECIAL PACKAGE</span>
          <h3 class="event-package-title">Package MALI METABOLIC SCREENING</h3>
          <p class="event-package-subtitle">คัดกรองภาวะดื้ออินซูลิน เบาหวาน และไขมันเบื้องต้น</p>
        </div>
        
        <div class="event-package-body">
          <div class="event-package-col">
            <div class="event-package-col-title">🧪 รายการตรวจวิเคราะห์ (Laboratory Tests)</div>
            <ul class="event-package-list">
              <li><strong>Fasting Insulin</strong> (ตรวจระดับอินซูลินเพื่อวิเคราะห์ภาวะดื้ออินซูลินซ่อนเร้น)</li>
              <li><strong>HbA1c</strong> (ตรวจค่าน้ำตาลสะสมเฉลี่ยสะท้อนพฤติกรรมย้อนหลัง 3 เดือน)</li>
              <li><strong>Lipid Profile</strong> (ตรวจคอเลสเตอรอล ไตรกลีเซอไรด์ HDL และ LDL แบบละเอียด)</li>
            </ul>
          </div>
          
          <div class="event-package-col">
            <div class="event-package-col-title">🎁 สิทธิ์พิเศษเพิ่มเติม (Additional Privileges)</div>
            <ul class="event-package-list event-package-list-gift">
              <li>รับฟังการบรรยายเรื่องระบบเผาผลาญและเบาหวานโดยแพทย์ผู้เชี่ยวชาญ</li>
              <li>คำแนะนำการอ่านแปลผลเลือดเบื้องต้น (Basic Lab Interpretation)</li>
              <li>คำแนะนำแนวทางการดูแลโภชนาการอาหารและพฤติกรรมสุขภาพเบื้องต้น</li>
              <li>ตรวจวิเคราะห์องค์ประกอบร่างกายอย่างละเอียด (Body Composition Analysis)</li>
            </ul>
          </div>
        </div>
        
        <div class="event-package-footer">
          <div class="event-package-price">
            <span class="price-label">ค่าบริการแพ็กเกจคัดกรองพิเศษเพียง</span>
            <strong class="price-value">990 <span class="price-unit">บาท</span></strong>
          </div>
          <a href="#final-cta" class="event-btn event-btn-primary event-package-btn">
            จองสิทธิ์รับบริการตรวจคัดกรอง
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PAIN POINT ═══ -->
  <section class="pain-section">
    <div class="section-inner">
      <div class="pain-quote-card">
        <div class="pain-quote-icon">❓</div>
        <blockquote class="pain-blockquote">
          "ฉันก็ผอม ไม่ได้อ้วน กินคลีน ออกกำลังกายสม่ำเสมอ<br/>
          แต่ทำไมผลเลือดถึงบอกว่าฉันเป็น<strong>เบาหวาน</strong>?"
        </blockquote>
        <p class="pain-sub">ถ้าประโยคนี้คือสิ่งที่คุณกำลังคิด... คู่มือเล่มนี้เขียนขึ้นเพื่อคุณ</p>
      </div>
    </div>
  </section>

  <!-- ═══ TOFI PROBLEM ═══ -->
  <section class="tofi-section" id="tofi">
    <div class="section-inner">
      <span class="section-badge">🎯 ปัญหาที่ไม่มีใครเคยบอกคุณ</span>
      <h2 class="tofi-title">TOFI: <span class="text-accent">ผอมนอก อ้วนใน</span></h2>
      <p class="section-subtitle">การรักษาเบาหวานแบบเดิมที่เน้นให้ "ลดน้ำหนัก" ใช้ไม่ได้ผลกับคุณ<br/>เพราะปัญหาที่แท้จริง คือ <strong class="text-white">"ภาวะดื้ออินซูลินที่ซ่อนอยู่"</strong></p>
      <div class="tofi-grid">
        <div class="tofi-visual">
          <img src="/images/diabetes-guide/tofi-concept.png" alt="TOFI — ผอมนอก อ้วนใน: Visceral Fat ไขมันซ่อนในช่องท้อง" width="500" height="500" loading="lazy"/>
        </div>
        <div class="tofi-causes">
          <div class="cause-card">
            <div class="cause-icon">🔴</div>
            <div>
              <h3>ไขมันในช่องท้อง (Visceral Fat)</h3>
              <p>ไขมันอันตรายที่มองไม่เห็นจากภายนอก เป็น "โรงงานผลิตสารอักเสบ" ที่ทำให้ร่างกายดื้ออินซูลิน</p>
            </div>
          </div>
          <div class="cause-card">
            <div class="cause-icon">💪</div>
            <div>
              <h3>กล้ามเนื้อหายไป (Sarcopenia)</h3>
              <p>กล้ามเนื้อคือ "อ่างเก็บน้ำตาล" ที่ใหญ่ที่สุด เมื่อกล้ามน้อยลง น้ำตาลจึงล้นเข้าสู่กระแสเลือด</p>
            </div>
          </div>
          <div class="cause-card">
            <div class="cause-icon">💊</div>
            <div>
              <h3>ยาที่ทำร้ายตับอ่อน</h3>
              <p>ยากลุ่ม Sulfonylurea เปรียบเสมือนการ "เฆี่ยน" ตับอ่อนที่กำลังจะตาย ทำให้เซลล์เสียหายถาวร</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHO IS THIS FOR ═══ -->
  <section class="whoisfor-section">
    <div class="section-inner">
      <span class="section-badge">เหมาะกับใคร?</span>
      <h2 class="whoisfor-title">คู่มือนี้เหมาะกับ<span class="text-accent">คุณ</span> — และคนที่คุณ<span class="hero-title-accent">ห่วงใย</span></h2>
      <p class="section-subtitle">ไม่ว่าจะซื้อให้ตัวเอง หรือซื้อฝากคนที่คุณรัก คู่มือนี้ออกแบบมาเพื่อทุกคนที่กำลังต่อสู้กับเบาหวานแบบ "ผอม"</p>

      <div class="whoisfor-grid">
        <!-- ซื้อให้ตัวเอง -->
        <div class="whoisfor-col">
          <div class="whoisfor-col-header whoisfor-header-self">
            <span class="whoisfor-header-icon">🙋</span>
            <h3>ซื้อให้ตัวเอง</h3>
            <p>ถ้าคุณมีอาการเหล่านี้...</p>
          </div>
          <div class="whoisfor-list">
            <div class="whoisfor-item whoisfor-item-self">
              <span class="whoisfor-emoji">🔬</span>
              <div>
                <strong>ได้รับวินิจฉัยว่าเป็นเบาหวาน</strong>
                <p>ทั้งที่น้ำหนักปกติหรือผอม ไม่เข้าใจว่าทำไม</p>
              </div>
            </div>
            <div class="whoisfor-item whoisfor-item-self">
              <span class="whoisfor-emoji">⚠️</span>
              <div>
                <strong>ภาวะก่อนเบาหวาน (Prediabetes)</strong>
                <p>HbA1c 5.7-6.4% หรือน้ำตาลเริ่มสูง อยากหยุดก่อนสาย</p>
              </div>
            </div>
            <div class="whoisfor-item whoisfor-item-self">
              <span class="whoisfor-emoji">🍽️</span>
              <div>
