---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";

const lineUrl = "https://lin.ee/LwEtisp";
const promptpayNumber = "087-748-4066";
const productPrice = 499;
const originalPrice = 990;
const discountPercent = Math.round((1 - productPrice / originalPrice) * 100);

const breadcrumbs = [
  { name: "หน้าแรก", url: "https://drtim.co/" },
  { name: "คู่มือพิชิตเบาหวานผอม", url: "https://drtim.co/diabetes-guide" },
  { name: "ชำระเงิน", url: "https://drtim.co/diabetes-guide/checkout" },
];
---

<BaseLayout
  title="ชำระเงิน — คู่มือพิชิตเบาหวานผอม | Dr. Tim"
  description="ชำระเงินสั่งซื้อคู่มือพิชิตเบาหวานสำหรับเบาหวานผอม โดย Dr. Tim ผ่าน PromptPay QR Code"
  type="website"
  breadcrumbs={breadcrumbs}
>

<!-- ═══ CHECKOUT PAGE ═══ -->
<div class="checkout-page">
  <!-- HEADER -->
  <header class="ck-header">
    <div class="ck-header-inner">
      <a href="/diabetes-guide" class="ck-back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
        <span>กลับ</span>
      </a>
      <div class="ck-logo">
        <span class="ck-logo-icon">⚕</span>
        <span class="ck-logo-text">Dr. Tim</span>
      </div>
      <div class="ck-secure">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
        <span>ปลอดภัย</span>
      </div>
    </div>
  </header>

  <!-- PROGRESS STEPS -->
  <div class="ck-progress">
    <div class="ck-progress-inner">
      <div class="ck-step done" id="step-ind-1">
        <div class="ck-step-circle">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <span>เลือกสินค้า</span>
      </div>
      <div class="ck-step-line done-line" id="step-line-1"></div>
      <div class="ck-step active" id="step-ind-2">
        <div class="ck-step-circle">2</div>
        <span>ข้อมูลจัดส่ง</span>
      </div>
      <div class="ck-step-line" id="step-line-2"></div>
      <div class="ck-step" id="step-ind-3">
        <div class="ck-step-circle">3</div>
        <span>ชำระเงิน</span>
      </div>
      <div class="ck-step-line" id="step-line-3"></div>
      <div class="ck-step" id="step-ind-4">
        <div class="ck-step-circle">4</div>
        <span>ยืนยันสลิป</span>
      </div>
    </div>
  </div>

  <!-- MAIN CONTENT -->
  <main class="ck-main">
    <div class="ck-grid">

      <!-- LEFT: ORDER SUMMARY -->
      <div class="ck-left">
        <div class="ck-card ck-order-card">
          <h2 class="ck-card-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
            สรุปคำสั่งซื้อ
          </h2>

          <!-- Product Item -->
          <div class="ck-product">
            <div class="ck-product-img">
              <img src="/images/about/drtim.webp" alt="คู่มือพิชิตเบาหวานผอม" width="90" height="120" loading="eager"/>
              <span class="ck-product-badge">E-Book + App</span>
            </div>
            <div class="ck-product-info">
              <h3>คู่มือพิชิตเบาหวาน:<br/>สำหรับ "เบาหวานผอม"</h3>
              <p class="ck-product-author">โดย หมอทิม — Functional Medicine</p>
              <div class="ck-product-includes">
                <span>📕 คู่มือ PDF 120+ หน้า</span>
                <span>📱 FITKUB AI Coach Access</span>
                <span>🎁 Bonus: Food Sequencing Guide</span>
              </div>
            </div>
          </div>

          <!-- Pricing -->
          <div class="ck-pricing">
            <div class="ck-price-row">
              <span>ราคาปกติ</span>
              <span class="ck-price-original">฿{originalPrice.toLocaleString()}</span>
            </div>
            <div class="ck-price-row ck-discount-row">
              <span>🎉 ส่วนลด Early Bird (-{discountPercent}%)</span>
              <span class="ck-price-discount">-฿{(originalPrice - productPrice).toLocaleString()}</span>
            </div>
            <div class="ck-price-divider"></div>
            <div class="ck-price-row ck-total-row">
              <span>ยอดชำระทั้งหมด</span>
              <span class="ck-price-total">฿{productPrice.toLocaleString()}</span>
            </div>
          </div>
        </div>

        <!-- WHAT YOU GET -->
        <div class="ck-card ck-includes-card">
          <h3 class="ck-card-title-sm">✨ สิ่งที่คุณจะได้รับ</h3>
          <ul class="ck-includes-list">
            <li>
              <span class="ck-check">✓</span>
              <div>
                <strong>คู่มือ PDF ฉบับสมบูรณ์</strong>
                <span>120+ หน้า พร้อม Checklist ทำตามได้ทันที</span>
              </div>
            </li>
            <li>
              <span class="ck-check">✓</span>
              <div>
                <strong>FITKUB AI Coach 30 วัน</strong>
                <span>ผู้ช่วย AI วิเคราะห์อาหาร + ผลเลือด</span>
              </div>
            </li>
            <li>
              <span class="ck-check">✓</span>
              <div>
                <strong>Food Sequencing Guide</strong>
                <span>เคล็ดลับกินถูกลำดับ ลดน้ำตาลพุ่ง</span>
              </div>
            </li>
            <li>
              <span class="ck-check">✓</span>
              <div>
                <strong>อัพเดทเนื้อหาฟรีตลอดชีพ</strong>
                <span>รับ Version ใหม่โดยไม่ต้องจ่ายเพิ่ม</span>
              </div>
            </li>
          </ul>
        </div>

        <!-- TRUST SIGNALS -->
        <div class="ck-trust-row">
          <div class="ck-trust-item">
            <span class="ck-trust-icon">🔒</span>
            <span>ชำระเงินปลอดภัย</span>
          </div>
          <div class="ck-trust-item">
            <span class="ck-trust-icon">⚡</span>
            <span>ได้รับทันทีหลังยืนยัน</span>
          </div>
          <div class="ck-trust-item">
            <span class="ck-trust-icon">🛡️</span>
            <span>รับประกันคืนเงิน 7 วัน</span>
          </div>
        </div>
      </div>

      <!-- CENTER: CUSTOMER INFO FORM (Step 2) -->
      <div class="ck-right" id="ck-step-info">
        <div class="ck-card ck-form-card">
          <h2 class="ck-card-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            ข้อมูลสำหรับจัดส่ง
          </h2>

          <form id="ck-customer-form" novalidate>
            <!-- Full Name -->
            <div class="ck-field">
              <label class="ck-label" for="ck-name">
                <span class="ck-label-text">ชื่อ-นามสกุล</span>
                <span class="ck-required">*</span>
              </label>
              <div class="ck-input-wrap">
                <svg class="ck-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <input type="text" id="ck-name" name="name" placeholder="เช่น สมชาย ใจดี" required autocomplete="name" />
              </div>
              <span class="ck-error" id="err-name">กรุณากรอกชื่อ-นามสกุล</span>
            </div>

            <!-- Phone -->
            <div class="ck-field">
              <label class="ck-label" for="ck-phone">
                <span class="ck-label-text">เบอร์โทรศัพท์</span>
                <span class="ck-required">*</span>
              </label>
              <div class="ck-input-wrap">
                <svg class="ck-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                <input type="tel" id="ck-phone" name="phone" placeholder="08x-xxx-xxxx" required autocomplete="tel" />
              </div>
              <span class="ck-error" id="err-phone">กรุณากรอกเบอร์โทรศัพท์</span>
            </div>

            <!-- LINE ID (optional) -->
            <div class="ck-field">
              <label class="ck-label" for="ck-line">
                <span class="ck-label-text">LINE ID</span>
                <span class="ck-optional">(ถ้ามี)</span>
              </label>
              <div class="ck-input-wrap">
                <svg class="ck-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"></path></svg>
                <input type="text" id="ck-line" name="line_id" placeholder="@line_id" autocomplete="off" />
              </div>
            </div>

            <!-- Email (optional) -->
            <div class="ck-field">
              <label class="ck-label" for="ck-email">
                <span class="ck-label-text">อีเมล</span>
                <span class="ck-optional">(สำหรับส่งคู่มือ PDF)</span>
              </label>
              <div class="ck-input-wrap">
                <svg class="ck-input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <input type="email" id="ck-email" name="email" placeholder="your@email.com" autocomplete="email" />
              </div>
            </div>

            <!-- Address -->
            <div class="ck-field">
              <label class="ck-label" for="ck-address">
                <span class="ck-label-text">ที่อยู่จัดส่ง</span>
                <span class="ck-required">*</span>
              </label>
              <div class="ck-input-wrap ck-input-wrap-textarea">
                <svg class="ck-input-icon ck-input-icon-top" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <textarea id="ck-address" name="address" rows="3" placeholder="บ้านเลขที่ ซอย ถนน ตำบล อำเภอ จังหวัด รหัสไปรษณีย์" required></textarea>
              </div>
              <span class="ck-error" id="err-address">กรุณากรอกที่อยู่จัดส่ง</span>
            </div>

            <!-- Note -->
            <div class="ck-field">
              <label class="ck-label" for="ck-note">
                <span class="ck-label-text">หมายเหตุเพิ่มเติม</span>
                <span class="ck-optional">(ถ้ามี)</span>
              </label>
              <div class="ck-input-wrap ck-input-wrap-textarea">
                <svg class="ck-input-icon ck-input-icon-top" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                <textarea id="ck-note" name="note" rows="2" placeholder="เช่น ต้องการใบเสร็จ / ฝากถึงคนรับ"></textarea>
              </div>
            </div>

            <!-- Submit to next step -->
            <button type="submit" class="ck-next-btn" id="ck-next-step">
              ดำเนินการชำระเงิน →
            </button>
            <p class="ck-form-privacy">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
              ข้อมูลของคุณปลอดภัย เราใช้เพื่อการจัดส่งเท่านั้น
            </p>
          </form>
        </div>
      </div>

      <!-- RIGHT: PAYMENT (Step 3 — hidden initially) -->
      <div class="ck-right ck-step-hidden" id="ck-step-payment">
        <div class="ck-card ck-payment-card">
          <h2 class="ck-card-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            ช่องทางชำระเงิน
          </h2>

          <!-- Payment Tab -->
          <div class="ck-payment-tabs">
            <button class="ck-tab active" id="tab-qr">
              <span class="ck-tab-icon">📱</span>
              QR PromptPay
            </button>
            <button class="ck-tab" id="tab-transfer">
              <span class="ck-tab-icon">🏦</span>
              โอนเงิน
            </button>
          </div>

          <!-- QR Content -->
          <div class="ck-tab-content active" id="content-qr">
            <div class="ck-qr-wrapper">
              <div class="ck-qr-amount">
                <span class="ck-qr-amount-label">ยอดชำระ</span>
                <span class="ck-qr-amount-value">฿{productPrice.toLocaleString()}</span>
              </div>
              <div class="ck-qr-code">
                <img src="/images/checkout/promptpay-qr.png" alt="PromptPay QR Code — สแกนเพื่อชำระเงิน" width="280" height="280" loading="eager"/>
                <div class="ck-qr-glow"></div>
              </div>
              <div class="ck-qr-info">
                <div class="ck-promptpay-badge">
                  <span class="ck-pp-logo">พร้อมเพย์</span>
                  <span class="ck-pp-text">PromptPay</span>
                </div>
                <p class="ck-qr-number">เบอร์: <strong>{promptpayNumber}</strong></p>
                <p class="ck-qr-name">ชื่อบัญชี: <strong>Dr. Tim Clinic</strong></p>
              </div>
            </div>

            <div class="ck-qr-steps">
              <div class="ck-qr-step">
                <div class="ck-qr-step-num">1</div>
                <div>
                  <strong>เปิดแอปธนาคาร</strong>
                  <span>เลือก "สแกน QR" หรือ "จ่ายเงิน"</span>
                </div>
              </div>
              <div class="ck-qr-step">
                <div class="ck-qr-step-num">2</div>
                <div>
                  <strong>สแกน QR Code ด้านบน</strong>
                  <span>ระบุจำนวน ฿{productPrice.toLocaleString()} แล้วยืนยัน</span>
                </div>
              </div>
              <div class="ck-qr-step">
                <div class="ck-qr-step-num">3</div>
                <div>
                  <strong>ส่งสลิปยืนยันผ่าน LINE</strong>
                  <span>รับคู่มือ + สิทธิ์เข้าถึง App ภายใน 5 นาที</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Transfer Content -->
          <div class="ck-tab-content" id="content-transfer">
            <div class="ck-transfer-info">
              <div class="ck-bank-card">
                <div class="ck-bank-logo">🟣</div>
                <div class="ck-bank-details">
                  <span class="ck-bank-name">ธนาคารไทยพาณิชย์ (SCB)</span>
                  <span class="ck-bank-account">xxx-x-xxxxx-x</span>
                  <span class="ck-bank-holder">ชื่อบัญชี: Dr. Tim Clinic</span>
                </div>
                <button class="ck-copy-btn" id="copy-account" aria-label="คัดลอกเลขบัญชี">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                  คัดลอก
                </button>
              </div>

              <div class="ck-transfer-amount">
                <span>กรุณาโอนจำนวน</span>
                <span class="ck-transfer-total">฿{productPrice.toLocaleString()}</span>
              </div>

              <div class="ck-transfer-note">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                <span>หลังโอนเสร็จ ส่งสลิปผ่าน LINE เพื่อรับคู่มือทันที</span>
              </div>
            </div>
          </div>

          <!-- CTA: Send Slip -->
          <a href={lineUrl} target="_blank" rel="noopener" class="ck-submit-btn" id="ck-submit">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"></path></svg>
            📤 ส่งสลิปยืนยันผ่าน LINE
          </a>
          <p class="ck-submit-note">แอด LINE <strong>@drtim</strong> แล้วส่งรูปสลิป — รับคู่มือภายใน 5 นาที</p>
        </div>

        <!-- GUARANTEE -->
        <div class="ck-card ck-guarantee-card">
          <div class="ck-guarantee-icon">🛡️</div>
          <h3 class="ck-guarantee-title">รับประกันคืนเงิน 7 วัน</h3>
          <p class="ck-guarantee-desc">หากอ่านแล้วไม่พึงพอใจ สามารถขอคืนเงินเต็มจำนวนภายใน 7 วันหลังซื้อ โดยไม่ต้องระบุเหตุผล</p>
        </div>

        <!-- SOCIAL PROOF MINI -->
        <div class="ck-card ck-social-card">
          <div class="ck-social-row">
            <div class="ck-avatars">
              <span class="ck-mini-avatar" style="background:#14b8a6">ก</span>
              <span class="ck-mini-avatar" style="background:#f59e0b">ว</span>
              <span class="ck-mini-avatar" style="background:#8b5cf6">ส</span>
              <span class="ck-mini-avatar" style="background:#ec4899">น</span>
            </div>
            <div class="ck-social-text">
              <strong>1,200+ คน</strong> ลงทะเบียนรอแล้ว
              <span class="ck-social-live">
                <span class="ck-pulse"></span>
                <span id="ck-live-count">3</span> คนกำลังดูหน้านี้
              </span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </main>

  <!-- MOBILE STICKY CTA -->
  <div class="ck-mobile-sticky">
    <div class="ck-mobile-sticky-price">
      <span class="ck-ms-original">฿{originalPrice.toLocaleString()}</span>
      <span class="ck-ms-total">฿{productPrice.toLocaleString()}</span>
    </div>
    <a href={lineUrl} target="_blank" rel="noopener" class="ck-mobile-sticky-btn">
