  color: var(--ck-gold-l);
  margin-bottom: 8px;
}
.ck-guarantee-desc {
  font-size: 13px;
  color: var(--ck-muted);
  line-height: 1.7;
}

/* SOCIAL CARD */
.ck-social-card { padding: 20px 24px; }
.ck-social-row {
  display: flex;
  align-items: center;
  gap: 14px;
}
.ck-avatars {
  display: flex;
}
.ck-mini-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 13px;
  font-weight: 700;
  margin-right: -8px;
  border: 2px solid var(--ck-bg);
}
.ck-social-text {
  font-size: 13px;
  color: var(--ck-muted);
}
.ck-social-text strong { color: #fff; }
.ck-social-live {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 4px;
  font-size: 12px;
  color: var(--ck-teal-l);
}
.ck-pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--ck-teal-l);
  animation: livePulse 2s ease-in-out infinite;
}
@keyframes livePulse {
  0%,100% { opacity: 1; box-shadow: 0 0 0 0 rgba(20,184,166,.5); }
  50% { opacity: .6; box-shadow: 0 0 0 6px rgba(20,184,166,0); }
}

/* MOBILE STICKY */
.ck-mobile-sticky {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  display: none;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: rgba(6,11,9,.96);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid var(--ck-brd);
}
.ck-ms-original {
  font-size: 13px;
  color: rgba(255,255,255,.35);
  text-decoration: line-through;
  display: block;
}
.ck-ms-total {
  font-size: 20px;
  font-weight: 800;
  color: #fff;
}
.ck-mobile-sticky-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: var(--ck-green);
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  border-radius: 999px;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba(6,199,85,.3);
}

/* FOOTER */
.ck-footer {
  border-top: 1px solid var(--ck-brd);
  padding: 20px 24px;
  text-align: center;
}
.ck-footer p {
  font-size: 12px;
  color: var(--ck-muted);
  max-width: var(--ck-mx);
  margin: 0 auto;
}
.ck-footer a { color: var(--ck-teal-l); }

/* ═══ RESPONSIVE ═══ */
@media (max-width: 900px) {
  .ck-grid {
    grid-template-columns: 1fr;
  }
  .ck-left { order: 2; }
  .ck-right { order: 1; }
}
@media (max-width: 640px) {
  .ck-main { padding: 20px 12px 100px; }
  .ck-card { padding: 20px 16px; }
  .ck-product { flex-direction: column; align-items: center; text-align: center; }
  .ck-product-info h3 { font-size: 15px; }
  .ck-product-includes { align-items: center; }
  .ck-trust-row { flex-direction: row; gap: 8px; }
  .ck-trust-item { padding: 12px 6px; font-size: 10px; }
  .ck-trust-icon { font-size: 16px; }
  .ck-qr-code img { width: 220px; height: 220px; }
  .ck-qr-amount-value { font-size: 26px; }
  .ck-submit-btn { font-size: 16px; padding: 16px 20px; }
  .ck-mobile-sticky { display: flex; }
  .ck-footer { padding-bottom: 80px; }
  .ck-step-line { width: 20px; }
  .ck-step span { font-size: 9px; }
  .ck-step-circle { width: 26px; height: 26px; font-size: 11px; }
  .ck-bank-card { flex-wrap: wrap; }
  .ck-copy-btn { width: 100%; justify-content: center; margin-top: 8px; }
  .ck-input-wrap input, .ck-input-wrap textarea { font-size: 16px; }
  .ck-next-btn { font-size: 16px; padding: 16px 20px; }
}
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {

    // ═══ STEP MANAGEMENT ═══
    var stepInfo = document.getElementById('ck-step-info');
    var stepPayment = document.getElementById('ck-step-payment');
    var form = document.getElementById('ck-customer-form');
    var checkSvg = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';

    function updateProgressBar(currentStep) {
      for (var i = 1; i <= 4; i++) {
        var ind = document.getElementById('step-ind-' + i);
        var line = document.getElementById('step-line-' + i);
        if (!ind) continue;
        ind.classList.remove('done', 'active');
        if (i < currentStep) {
          ind.classList.add('done');
          ind.querySelector('.ck-step-circle').innerHTML = checkSvg;
        } else if (i === currentStep) {
          ind.classList.add('active');
          ind.querySelector('.ck-step-circle').textContent = String(i);
        } else {
          ind.querySelector('.ck-step-circle').textContent = String(i);
        }
        if (line) {
          if (i < currentStep) {
            line.classList.add('done-line');
          } else {
            line.classList.remove('done-line');
          }
        }
      }
    }

    // ═══ FORM VALIDATION ═══
    function validateForm() {
      var valid = true;
      var nameVal = document.getElementById('ck-name').value.trim();
      var phoneVal = document.getElementById('ck-phone').value.trim();
      var addrVal = document.getElementById('ck-address').value.trim();

      // Name
      var nameInput = document.getElementById('ck-name');
      var errName = document.getElementById('err-name');
      if (!nameVal) {
        nameInput.classList.add('ck-input-error');
        nameInput.classList.remove('ck-input-valid');
        errName.classList.add('visible');
        valid = false;
      } else {
        nameInput.classList.remove('ck-input-error');
        nameInput.classList.add('ck-input-valid');
        errName.classList.remove('visible');
      }

      // Phone
      var phoneInput = document.getElementById('ck-phone');
      var errPhone = document.getElementById('err-phone');
      var phoneClean = phoneVal.replace(/[\s\-]/g, '');
      if (!phoneClean || phoneClean.length < 9) {
        phoneInput.classList.add('ck-input-error');
        phoneInput.classList.remove('ck-input-valid');
        errPhone.classList.add('visible');
        if (phoneClean.length > 0 && phoneClean.length < 9) {
          errPhone.textContent = 'เบอร์โทรศัพท์ต้องมีอย่างน้อย 9 หลัก';
        } else {
          errPhone.textContent = 'กรุณากรอกเบอร์โทรศัพท์';
        }
        valid = false;
      } else {
        phoneInput.classList.remove('ck-input-error');
        phoneInput.classList.add('ck-input-valid');
        errPhone.classList.remove('visible');
      }

      // Address
      var addrInput = document.getElementById('ck-address');
      var errAddr = document.getElementById('err-address');
      if (!addrVal) {
        addrInput.classList.add('ck-input-error');
        addrInput.classList.remove('ck-input-valid');
        errAddr.classList.add('visible');
        valid = false;
      } else {
        addrInput.classList.remove('ck-input-error');
        addrInput.classList.add('ck-input-valid');
        errAddr.classList.remove('visible');
      }

      return valid;
    }

    // Inline validation on blur
    ['ck-name', 'ck-phone', 'ck-address'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) {
        el.addEventListener('blur', function() {
          if (el.value.trim()) {
            el.classList.remove('ck-input-error');
            el.classList.add('ck-input-valid');
            var errEl = document.getElementById('err-' + id.replace('ck-', ''));
            if (errEl) errEl.classList.remove('visible');
          }
        });
      }
    });

    // ═══ FORM SUBMIT → SHOW PAYMENT ═══
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        if (!validateForm()) {
          // Scroll to first error
          var firstErr = form.querySelector('.ck-input-error');
          if (firstErr) firstErr.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }

        // Build customer summary for payment step
        var nameVal = document.getElementById('ck-name').value.trim();
        var phoneVal = document.getElementById('ck-phone').value.trim();
        var lineVal = document.getElementById('ck-line').value.trim();
        var emailVal = document.getElementById('ck-email').value.trim();
        var addrVal = document.getElementById('ck-address').value.trim();

        var summaryHTML = '<div class="ck-customer-summary">';
        summaryHTML += '<div class="ck-cust-row"><span class="ck-cust-label">👤 ชื่อ</span><span class="ck-cust-value">' + nameVal + '</span></div>';
        summaryHTML += '<div class="ck-cust-row"><span class="ck-cust-label">📞 เบอร์</span><span class="ck-cust-value">' + phoneVal + '</span></div>';
        if (lineVal) summaryHTML += '<div class="ck-cust-row"><span class="ck-cust-label">💬 LINE</span><span class="ck-cust-value">' + lineVal + '</span></div>';
        if (emailVal) summaryHTML += '<div class="ck-cust-row"><span class="ck-cust-label">✉️ อีเมล</span><span class="ck-cust-value">' + emailVal + '</span></div>';
        summaryHTML += '<div class="ck-cust-row"><span class="ck-cust-label">📍 ที่อยู่</span><span class="ck-cust-value">' + addrVal + '</span></div>';
        summaryHTML += '</div>';
        summaryHTML += '<button type="button" class="ck-edit-info" id="ck-edit-info">✏️ แก้ไขข้อมูล</button>';

        // Inject summary before payment card title
        var paymentCard = stepPayment.querySelector('.ck-payment-card');
        var existingSummary = paymentCard.querySelector('.ck-customer-summary');
        var existingEdit = paymentCard.querySelector('.ck-edit-info');
        if (existingSummary) existingSummary.remove();
        if (existingEdit) existingEdit.remove();
        var titleEl = paymentCard.querySelector('.ck-card-title');
        titleEl.insertAdjacentHTML('afterend', summaryHTML);

        // Edit button handler
        document.getElementById('ck-edit-info').addEventListener('click', function() {
          goToStep2();
        });

        // Transition to step 3
        stepInfo.classList.add('ck-step-hidden');
        stepPayment.classList.remove('ck-step-hidden');
        updateProgressBar(3);
        window.scrollTo({ top: 0, behavior: 'smooth' });

        // Re-run entrance animation on payment cards
        var payCards = stepPayment.querySelectorAll('.ck-card');
        payCards.forEach(function(card, i) {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          card.style.transition = 'opacity .5s ease, transform .5s ease';
          setTimeout(function() {
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          }, 100 + i * 80);
        });
      });
    }

    function goToStep2() {
      stepPayment.classList.add('ck-step-hidden');
      stepInfo.classList.remove('ck-step-hidden');
      updateProgressBar(2);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ═══ TAB SWITCHING ═══
    var tabQr = document.getElementById('tab-qr');
    var tabTransfer = document.getElementById('tab-transfer');
    var contentQr = document.getElementById('content-qr');
    var contentTransfer = document.getElementById('content-transfer');

    if (tabQr && tabTransfer && contentQr && contentTransfer) {
      tabQr.addEventListener('click', function() {
        tabQr.classList.add('active');
        tabTransfer.classList.remove('active');
        contentQr.classList.add('active');
        contentTransfer.classList.remove('active');
      });

      tabTransfer.addEventListener('click', function() {
        tabTransfer.classList.add('active');
        tabQr.classList.remove('active');
        contentTransfer.classList.add('active');
        contentQr.classList.remove('active');
      });
    }

    // ═══ COPY ACCOUNT NUMBER ═══
    var copyBtn = document.getElementById('copy-account');
    if (copyBtn) {
      copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText('xxx-x-xxxxx-x').then(function() {
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> คัดลอกแล้ว!';
          copyBtn.style.background = 'rgba(20,184,166,.25)';
          setTimeout(function() {
            copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> คัดลอก';
            copyBtn.style.background = 'rgba(20,184,166,.1)';
          }, 2000);
        });
      });
    }

    // ═══ LIVE VIEWER COUNT (Social Proof) ═══
    var liveCount = document.getElementById('ck-live-count');
    if (liveCount) {
      setInterval(function() {
        var n = Math.floor(Math.random() * 5) + 2;
        liveCount.textContent = String(n);
      }, 8000);
    }

    // ═══ ENTRANCE ANIMATIONS ═══
    var cards = document.querySelectorAll('#ck-step-info .ck-card, .ck-trust-row, .ck-order-card, .ck-includes-card');
    cards.forEach(function(card, i) {
      card.style.opacity = '0';
      card.style.transform = 'translateY(20px)';
      card.style.transition = 'opacity .5s ease, transform .5s ease';
      setTimeout(function() {
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
      }, 100 + i * 80);
    });
  });
</script>
