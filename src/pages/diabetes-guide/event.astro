---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";

const buyUrl = "https://www.fitkub.com/order/d6c2c53b-a627-4cc1-bb14-5fa3c0338bbe";

const breadcrumbs = [
  { name: "หน้าแรก", url: "https://drtim.co/" },
  { name: "คู่มือพิชิตเบาหวานผอม", url: "https://drtim.co/diabetes-guide" },
  { name: "งานเปิดตัวหนังสือและคัดกรองสุขภาพ", url: "https://drtim.co/diabetes-guide/event" },
];
---

<BaseLayout
  title="งานเปิดตัวหนังสือ & แพ็กเกจตรวจสุขภาพ | คู่มือพิชิตเบาหวานสำหรับคนผอม"
  description="งานเปิดตัวหนังสือและแพ็กเกจคัดกรองภาวะดื้ออินซูลิน เบาหวาน ไขมัน ราคาพิเศษ 990 บาท โดยหมอทิม ร่วมกับ มะลิแคร์"
  type="website"
  breadcrumbs={breadcrumbs}
>
  <!-- ═══ STICKY TOP BAR ═══ -->
  <header class="top-bar">
    <div class="top-bar-inner">
      <a href="/" class="top-bar-brand">
        <span class="brand-icon">⚕</span>
        <span class="brand-name">Dr. Tim</span>
      </a>
      <nav class="top-bar-nav">
        <a href="/">หน้าแรก</a>
        <a href="/cgm">คอร์ส CGM</a>
        <a href="/vip-coaching">VIP Coaching</a>
        <a href="/consult">ปรึกษาส่วนตัว</a>
        <a href="/diabetes-guide">หนังสือเบาหวานผอม</a>
      </nav>
      <a href={buyUrl} target="_blank" rel="noopener" class="nav-cta-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"></path></svg>
        สั่งจอง 459 บาท
      </a>
    </div>
  </header>

  <!-- ═══ DEDICATED EVENT CONTAINER ═══ -->
  <div class="event-page-container">
    <section class="event-launch-section" aria-labelledby="event-launch-title">
      <div class="event-launch-shell">
        <span class="event-orb event-orb-one" aria-hidden="true"></span>
        <span class="event-orb event-orb-two" aria-hidden="true"></span>
        <span class="event-line event-line-one" aria-hidden="true"></span>
        <span class="event-line event-line-two" aria-hidden="true"></span>

        <div class="event-launch-grid">
          <div class="event-launch-copy">
            <div class="event-logo-row event-reveal">
              <span class="event-logo-pill">
                <img src="/images/logo-mali-care.png" alt="โลโก้ มะลิแคร์" onerror="this.style.display='none'" />
                <span>Mali Care</span>
              </span>
              <span class="event-logo-pill">
                <img src="/images/logo-partner.jpg" alt="โลโก้พาร์ทเนอร์" onerror="this.style.display='none'" />
                <span>Dr. Tim</span>
              </span>
            </div>

            <p class="event-eyebrow event-reveal">งานสุขภาพและเปิดตัวหนังสือ</p>
            <h1 id="event-launch-title" class="event-title event-reveal">
              งานเปิดตัวหนังสือ
              <span>“คู่มือพิชิตเบาหวานสำหรับเบาหวานผอม”</span>
            </h1>
            <p class="event-subtitle event-reveal">โดยหมอทิม ร่วมกับ มะลิแคร์</p>
            <p class="event-description event-reveal">
              ขอเชิญร่วมงานเปิดตัวหนังสือฉบับพิเศษ พร้อมรับฟังการบรรยายเรื่องระบบเผาผลาญและการดูแลรักษาสุขภาพ แนะนำนวัตกรรมจากมะลิแคร์ พร้อมกิจกรรมพิเศษและช่วงถาม-ตอบ (Q&A) ร่วมพูดคุยเจาะลึกปัญหาสุขภาพกับหมอทิมอย่างใกล้ชิด
            </p>

            <div class="event-meta event-reveal">
              <div class="event-meta-card">
                <span class="event-meta-icon">20</span>
                <div>
                  <strong>20 มิถุนายน 2569</strong>
                  <span>09:00 - 12:00 น.</span>
                </div>
              </div>
              <div class="event-meta-card">
                <span class="event-meta-icon">📍</span>
                <div>
                  <strong>สถานที่จัดงาน</strong>
                  <a class="event-map-link" href="https://maps.app.goo.gl/nbf8SDiAreCwPTzP8" target="_blank" rel="noopener">
                    มะลิแคร์ นนทบุรี
                  </a>
                </div>
              </div>
            </div>

            <div class="event-actions event-reveal">
              <a class="event-btn event-btn-primary" href={buyUrl} target="_blank" rel="noopener">ลงทะเบียนเข้าร่วมงาน</a>
              <a class="event-btn event-btn-secondary" href="https://maps.app.goo.gl/nbf8SDiAreCwPTzP8" target="_blank" rel="noopener">
                ดูแผนที่เดินทาง
              </a>
            </div>
          </div>

          <div class="event-visual event-reveal" aria-label="พื้นที่รูปหมอทิม">
            <div class="event-doctor-card">
              <span class="event-poster-label">4:5 EVENT POSTER</span>
              <span class="event-book-badge">เปิดตัวหนังสือ</span>
              <div class="event-doctor-placeholder" aria-hidden="true">
                <span>Dr. Tim</span>
                <small>Doctor Image</small>
              </div>
              <img src="/images/drtim.png" alt="หมอทิม" loading="lazy" onerror="this.style.display='none'" />
              <div class="event-floating-card">
                <small>ราคาพิเศษภายในงาน</small>
                <strong>410 บาท</strong>
              </div>
            </div>
          </div>
        </div>

        <!-- ═══ MALI METABOLIC SCREENING BANNER ═══ -->
        <div class="event-reveal" style="text-align: center; margin: 40px auto; padding: 0 20px;">
          <a href="/diabetes-guide/package" class="event-btn event-btn-secondary" style="background: rgba(255,255,255,0.8); border: 2px solid #c65318; color: #c65318; font-weight: 700; padding: 14px 32px; border-radius: 16px; font-size: 16px;">
            🔍 ดูรายละเอียดแพ็กเกจ MALI METABOLIC SCREENING (990 บาท)
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- ═══ FOOTER ═══ -->
  <footer class="site-footer">
    <div class="section-inner">
      <p>© {new Date().getFullYear()} Dr. Tim — Ultramed Clinic, ชลบุรี | <a href="/">drtim.co</a> | <a href="/privacy-policy">นโยบายความเป็นส่วนตัว</a></p>
    </div>
  </footer>
</BaseLayout>

<style>
  :root {
    --dg: #0a0f0d;
    --teal: #0f766e;
    --teal-l: #14b8a6;
    --gold: #f59e0b;
    --gold-l: #fbbf24;
    --surf: #111816;
    --card: rgba(255, 255, 255, 0.04);
    --brd: rgba(255, 255, 255, 0.08);
    --txt: #f0fdf4;
    --muted: rgba(255, 255, 255, 0.6);
    --rad: 16px;
    --mx: 1100px;
  }

  .event-page-container {
    background: var(--dg);
    min-height: 100vh;
    padding-top: 100px;
    padding-bottom: 60px;
  }

  /* TOP BAR */
  .top-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(10, 15, 13, 0.88);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--brd);
  }
  .top-bar-inner {
    max-width: var(--mx);
    margin: 0 auto;
    padding: 12px 24px;
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .top-bar-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #fff;
    font-weight: 700;
    font-size: 16px;
  }
  .brand-icon {
    font-size: 20px;
  }
  .top-bar-nav {
    display: flex;
    gap: 20px;
    margin-right: auto;
  }
  .top-bar-nav a {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.2s;
  }
  .top-bar-nav a:hover {
    color: #fff;
  }
  .nav-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 20px;
    background: #06c755;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    border-radius: 999px;
    transition: all 0.2s;
  }
  .nav-cta-btn:hover {
    background: #05b04a;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(6, 199, 85, 0.4);
    color: #fff;
  }

  /* BOOK LAUNCH EVENT BANNER */
  .event-launch-section {
    position: relative;
    overflow: hidden;
    padding: 20px 24px;
    color: #321c12;
  }
  .event-launch-shell {
    position: relative;
    max-width: var(--mx);
    margin: 0 auto;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 34px;
    background: linear-gradient(120deg, rgba(255, 250, 242, 0.94), rgba(255, 236, 207, 0.78) 50%, rgba(233, 120, 40, 0.22));
    box-shadow: 0 24px 80px rgba(124, 61, 20, 0.18);
  }
  .event-launch-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(330px, 430px);
    gap: 44px;
    align-items: center;
    padding: clamp(28px, 5vw, 58px);
  }
  .event-orb, .event-line {
    position: absolute;
    pointer-events: none;
  }
  .event-orb {
    border-radius: 999px;
    animation: event-float 12s ease-in-out infinite;
  }
  .event-orb-one {
    width: 420px;
    height: 420px;
    right: -180px;
    top: -150px;
    background: radial-gradient(circle, rgba(233, 120, 40, 0.32), transparent 68%);
  }
  .event-orb-two {
    width: 300px;
    height: 300px;
    left: -150px;
    bottom: -130px;
    background: radial-gradient(circle, rgba(223, 127, 100, 0.28), transparent 68%);
    animation-delay: -4s;
  }
  .event-line {
    opacity: 0.32;
    border-color: rgba(97, 50, 24, 0.2);
  }
  .event-line-one {
    width: 190px;
    height: 190px;
    right: 10%;
    top: 12%;
    border-top: 1px solid;
    border-right: 1px solid;
    border-radius: 0 110px 0 0;
  }
  .event-line-two {
    width: 130px;
    height: 130px;
    left: 6%;
    bottom: 10%;
    border-bottom: 1px solid;
    border-left: 1px solid;
    border-radius: 0 0 0 80px;
  }
  .event-logo-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 28px;
  }
  .event-logo-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 8px 14px;
    border: 1px solid rgba(97, 50, 24, 0.16);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.64);
    color: #6d4632;
    font-size: 13px;
    font-weight: 800;
  }
  .event-logo-pill img {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    object-fit: cover;
  }
  .event-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 14px;
    color: #c65318;
    font-size: 14px;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .event-eyebrow:before {
    content: "";
    width: 42px;
    height: 1px;
    background: currentColor;
  }
  .event-title {
    max-width: 720px;
    margin: 0;
    color: #321c12;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 4.2vw, 3.8rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.045em;
  }
  .event-title span {
    display: block;
    color: #c65318;
  }
  .event-subtitle {
    margin: 18px 0 0;
    color: #6d4632;
    font-size: clamp(1rem, 2vw, 1.28rem);
    font-weight: 900;
  }
  .event-description {
    max-width: 620px;
    margin: 12px 0 0;
    color: rgba(50, 28, 18, 0.78);
    font-size: 16px;
    line-height: 1.75;
  }
  .event-meta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 24px;
  }
  .event-meta-card {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    padding: 14px;
    border: 1px solid rgba(97, 50, 24, 0.14);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.62);
    box-shadow: 0 10px 30px rgba(97, 50, 24, 0.08);
  }
  .event-meta-icon {
    display: grid;
    width: 34px;
    height: 34px;
    flex: 0 0 auto;
    place-items: center;
    border-radius: 999px;
    background: #fff0dc;
    color: #c65318;
    font-weight: 900;
  }
  .event-meta-card strong, .event-meta-card span {
    display: block;
  }
  .event-meta-card strong {
    color: #321c12;
    font-size: 15px;
  }
  .event-meta-card span {
    margin-top: 2px;
    color: #6d4632;
    font-size: 13px;
    font-weight: 800;
  }
  .event-map-link {
    display: inline-block;
    margin-top: 2px;
    color: #c65318;
    font-size: 13px;
    font-weight: 900;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .event-map-link:hover {
    color: #321c12;
  }
  .event-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 26px;
  }
  .event-btn {
    display: inline-flex;
    min-height: 52px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 16px;
    font-weight: 900;
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }
  .event-btn:hover {
    transform: translateY(-3px);
  }
  .event-btn-primary {
    padding: 16px 24px;
    background: linear-gradient(135deg, #e97828, #c65318);
    color: #fff;
    box-shadow: 0 14px 34px rgba(198, 83, 24, 0.3);
  }
  .event-btn-secondary {
    padding: 15px 22px;
    border: 1px solid rgba(97, 50, 24, 0.22);
    background: rgba(255, 255, 255, 0.54);
    color: #321c12;
  }
  .event-visual {
    position: relative;
  }
  .event-doctor-card {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 520px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 38px;
    background: radial-gradient(circle at 50% 30%, rgba(255, 255, 255, 0.82), transparent 28%), linear-gradient(160deg, #ffe3b4 0%, #f1a45e 56%, #c95525 100%);
    box-shadow: 0 18px 50px rgba(89, 42, 15, 0.16);
  }
  .event-doctor-card:before {
    position: absolute;
    inset: 9%;
    border: 1px solid rgba(255, 255, 255, 0.36);
    border-radius: 999px 999px 34px 34px;
    content: "";
  }
  .event-doctor-card img {
    position: relative;
    z-index: 2;
    width: min(84%, 420px);
    max-height: 88%;
    margin: auto;
    object-fit: contain;
    filter: drop-shadow(0 24px 34px rgba(79, 35, 12, 0.22));
  }
  .event-doctor-placeholder {
    position: absolute;
    inset: 18% 12% 28%;
    z-index: 1;
    display: grid;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px 999px 34px 34px;
    color: rgba(50, 28, 18, 0.45);
    text-align: center;
  }
  .event-doctor-placeholder span {
    display: block;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    font-weight: 700;
  }
  .event-doctor-placeholder small {
    display: block;
    margin-top: 4px;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .event-poster-label {
    position: absolute;
    right: 12px;
    top: 12px;
    z-index: 4;
    padding: 9px 11px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    color: rgba(50, 28, 18, 0.64);
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.08em;
  }
  .event-book-badge {
    position: absolute;
    left: -4px;
    top: 18%;
    z-index: 5;
    padding: 12px 16px;
    border-radius: 999px;
    background: #321c12;
    color: #fff8ec;
    box-shadow: 0 18px 40px rgba(50, 28, 18, 0.22);
    font-size: 14px;
    font-weight: 900;
  }
  .event-floating-card {
    position: absolute;
    right: 28px;
    bottom: 28px;
    z-index: 5;
    width: min(78%, 270px);
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 22px;
    background: rgba(255, 250, 242, 0.92);
    box-shadow: 0 18px 50px rgba(92, 39, 12, 0.18);
    animation: event-card-drift 6.8s ease-in-out infinite;
  }
  .event-floating-card small {
    display: block;
    color: #c65318;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.11em;
  }
  .event-floating-card strong {
    display: block;
    margin-top: 6px;
    color: #321c12;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 24px;
    line-height: 1.16;
  }
  .event-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: event-rise 0.72s ease forwards;
  }
  .event-reveal:nth-child(2) {
    animation-delay: 0.08s;
  }
  .event-reveal:nth-child(3) {
    animation-delay: 0.16s;
  }
  .event-reveal:nth-child(4) {
    animation-delay: 0.24s;
  }
  .event-reveal:nth-child(5) {
    animation-delay: 0.32s;
  }
  .event-reveal:nth-child(6) {
    animation-delay: 0.4s;
  }
  @keyframes event-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes event-float {
    0%, 100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(-18px, 18px, 0) scale(1.04);
    }
  }
  @keyframes event-card-drift {
    0%, 100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-8px, -12px, 0);
    }
  }

  /* MALI METABOLIC SCREENING PACKAGE BANNER */
  .event-package-banner {
    position: relative;
    z-index: 3;
    margin: 0 clamp(16px, 4vw, 44px) clamp(24px, 5vw, 44px);
    padding: clamp(20px, 4vw, 36px);
    border-top: 1px dashed rgba(97, 50, 24, 0.25);
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: 0 16px 40px rgba(97, 50, 24, 0.06);
  }
  .event-package-header {
    text-align: center;
    margin-bottom: 28px;
  }
  .event-package-tag {
    display: inline-block;
    padding: 4px 12px;
    background: #c65318;
    color: #fff;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: 0.1em;
    border-radius: 99px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .event-package-title {
    margin: 0;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.35rem, 2.5vw, 1.68rem);
    font-weight: 700;
    color: #321c12;
    letter-spacing: -0.02em;
  }
  .event-package-subtitle {
    margin: 6px 0 0;
    font-size: 15px;
    color: #6d4632;
    font-weight: 800;
  }
  .event-package-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 28px;
  }
  .event-package-col {
    display: flex;
    flex-direction: column;
  }
  .event-package-col-title {
    font-size: 14px;
    font-weight: 900;
    color: #321c12;
    margin-bottom: 12px;
    border-bottom: 2px solid rgba(97, 50, 24, 0.12);
    padding-bottom: 6px;
  }
  .event-package-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
