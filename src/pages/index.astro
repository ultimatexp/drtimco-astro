---
/**
 * Homepage — drtim.co
 * Premium blog homepage with editorial layout.
 *
 * Design patterns from Refero research:
 * - Hero featured post with image overlay (Typeform/Craft pattern)
 * - Horizontal category pills (The Leap/Monarch pattern)
 * - Editorial 1+2 grid for featured posts (Unsplash pattern)
 * - 3-column card grid for latest (Duolingo/Grammarly pattern)
 * - Clean typography with Inter font (Craft/Fibery pattern)
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import DirectAnswerBox from "../components/DirectAnswerBox.astro";
import SearchModal from "../components/SearchModal.astro";
import FAQSection from "../components/FAQSection.astro";
import { getTranslations } from "../i18n/translations.js";
import {
  getAllPosts,
  getCategories,
  getPostCount,
  stripHtml,
  formatDate,
  localizeImageUrl,
  getAuthorName,
} from "../lib/api.js";

const ui = getTranslations("th");

const allPosts = getAllPosts();
const categories = getCategories();
const totalPosts = getPostCount();

// Split posts into sections
const heroPost = allPosts[0];
const editorPicks = allPosts.slice(1, 3);
const latestPosts = allPosts.slice(3, 9);
const morePosts = allPosts.slice(9, 15);

// ── FAQ items for AEO (Answer Engine Optimization) ──
// Targets: การรักษาเบาหวาน โดยไม่ใช้ยา, การใช้ CGM, Functional Medicine
const faqItems = [
  {
    question: "Functional Medicine คืออะไร? ต่างจากการรักษาแบบทั่วไปอย่างไร?",
    answer:
      "Functional Medicine คือแนวทางการแพทย์ที่มุ่งค้นหาสาเหตุรากของโรค (Root-Cause) แทนการรักษาแค่อาการ โดยวิเคราะห์ระบบเมตาบอลิก ฮอร์โมน และสารอาหารอย่างครอบคลุม เพื่อออกแบบแผนการรักษาเฉพาะบุคคล ต่างจากการแพทย์แบบทั่วไปที่เน้นรักษาอาการด้วยยาเป็นหลัก",
  },
  {
    question: "การรักษาเบาหวานโดยไม่ใช้ยา ทำได้จริงหรือ?",
    answer:
      "การรักษาเบาหวานโดยไม่ใช้ยาสามารถทำได้จริงในผู้ป่วยเบาหวานชนิดที่ 2 ระยะเริ่มต้น ด้วยการปรับอาหาร ออกกำลังกาย ควบคุมน้ำหนัก และติดตามน้ำตาลด้วย CGM อย่างใกล้ชิด หมอทิมใช้แนวทาง Functional Medicine วิเคราะห์สาเหตุของภาวะดื้ออินซูลินและออกแบบแผนรักษาเฉพาะบุคคล ช่วยให้ผู้ป่วยหลายรายลดยาหรือหยุดยาได้สำเร็จ",
  },
  {
    question: "CGM (Continuous Glucose Monitor) คืออะไร? มีประโยชน์อย่างไร?",
    answer:
      "CGM คือเครื่องวัดน้ำตาลแบบต่อเนื่อง ติดที่ผิวหนังเพื่อวัดระดับน้ำตาลตลอด 24 ชั่วโมง ช่วยให้เห็นผลกระทบของอาหารแต่ละมื้อต่อน้ำตาลในเลือดแบบ real-time ทำให้แพทย์และผู้ป่วยปรับแผนอาหารและการออกกำลังกายได้อย่างแม่นยำ เป็นเครื่องมือสำคัญในการรักษาเบาหวานแบบไม่ใช้ยา",
  },
  {
    question: "ใครเหมาะกับการใช้ CGM ติดตามน้ำตาล?",
    answer:
      "การใช้ CGM เหมาะกับผู้ป่วยเบาหวานชนิดที่ 2, ผู้ที่มีภาวะ prediabetes หรือดื้ออินซูลิน, ผู้ที่ต้องการลดน้ำหนักอย่างมีประสิทธิภาพ และผู้ที่สนใจ biohacking เพื่อสุขภาพเชิงป้องกัน หมอทิมแนะนำ CGM เป็นส่วนหนึ่งของแผนการรักษาเบาหวานโดยไม่ใช้ยาที่ Ultramed Clinic ชลบุรี",
  },
  {
    question: "Metabolic Health คืออะไร? ทำไมถึงสำคัญ?",
    answer:
      "Metabolic Health คือสุขภาพเชิงเมตาบอลิก หมายถึงความสามารถของร่างกายในการควบคุมน้ำตาล ไขมัน ความดัน และน้ำหนักให้อยู่ในเกณฑ์ปกติ ผู้ที่มี metabolic health ไม่ดีเสี่ยงต่อเบาหวาน โรคหัวใจ และโรคเรื้อรังอื่นๆ การตรวจเลือดและใช้ CGM ช่วยประเมินและปรับปรุง metabolic health ได้อย่างมีประสิทธิภาพ",
  },
  {
    question: "ภาวะดื้ออินซูลิน (Insulin Resistance) รักษาได้อย่างไร?",
    answer:
      "ภาวะดื้ออินซูลินรักษาได้ด้วยการปรับอาหารแบบ low-carb หรือ time-restricted eating ร่วมกับการออกกำลังกายแบบ resistance training ติดตามผลด้วย CGM และตรวจเลือดสม่ำเสมอ หมอทิมใช้แนวทาง Functional Medicine วิเคราะห์สาเหตุเชิงลึก ช่วยให้ผู้ป่วยฟื้นฟูความไวต่ออินซูลินโดยไม่ต้องพึ่งยา",
  },
  {
    question: "Ultramed Clinic อยู่ที่ไหน? นัดพบแพทย์อย่างไร?",
    answer:
      'Ultramed Clinic ตั้งอยู่ที่จังหวัดชลบุรี ประเทศไทย ให้บริการด้าน Functional Medicine โดยหมอทิม สามารถนัดพบแพทย์ผ่านทาง LINE Official (@dr.timdietclinic) หรือ Facebook Page "Dr. Tim Diet Clinic" เปิดให้บริการทั้งนัดพบตัวและปรึกษาออนไลน์ (Telemedicine)',
  },
  {
    question:
      "การตรวจเลือดแบบ Functional Medicine ต่างจากตรวจเลือดทั่วไปอย่างไร?",
    answer:
      "การตรวจเลือดแบบ Functional Medicine ครอบคลุมมากกว่าการตรวจทั่วไป โดยวิเคราะห์ biomarkers เชิงลึก เช่น insulin, HbA1c, HOMA-IR, thyroid panel, vitamin D, B12, ferritin และ inflammation markers เพื่อค้นหาความผิดปกติตั้งแต่ระยะเริ่มต้น ก่อนที่จะพัฒนาเป็นโรคเรื้อรัง",
  },
];
---

<BaseLayout
  title={ui.siteTitle}
  description={ui.siteDescription}
  type="website"
  faqItems={faqItems}
>
  <!-- ═══ FIXED TOP BAR ═══ -->
  <header class="top-bar">
    <div class="top-bar-inner">
      <a href="/" class="top-bar-brand">
        <span class="brand-icon">⚕</span>
        <span class="brand-name">Dr. Tim</span>
      </a>
      <nav class="top-bar-nav">
        <a href="/blog">{ui.blog}</a>
        <a href="/">{ui.home}</a>
        <div class="nav-dropdown">
          <button class="nav-dropdown-trigger" type="button">
            บริการ
            <svg
              class="nav-dropdown-arrow"
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              ><path
                d="M6 9l6 6 6-6"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
          <div class="nav-dropdown-menu">
            <a href="/cgm" class="dropdown-item">
              <span class="dropdown-icon">📟</span>
              <div>
                <strong>คอร์ส CGM</strong>
                <span>รักษาเบาหวานด้วย CGM · 14 วัน</span>
              </div>
            </a>
            <a href="/vip-coaching" class="dropdown-item dropdown-item-vip">
              <span class="dropdown-icon">💎</span>
              <div>
                <strong>VIP 1:1 Coaching</strong>
                <span>ดูแลตัวต่อตัว 12 สัปดาห์</span>
              </div>
            </a>
          </div>
        </div>
      </nav>
      <div class="top-bar-social">
        <a
          href="https://www.facebook.com/dr.timdietclinic/"
          target="_blank"
          rel="noopener"
          aria-label="Facebook"
          class="social-icon"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.youtube.com/@dr.timdietclinic"
          target="_blank"
          rel="noopener"
          aria-label="YouTube"
          class="social-icon"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path>
          </svg>
        </a>
        <a
          href="https://www.instagram.com/dr.timdietclinic/"
          target="_blank"
          rel="noopener"
          aria-label="Instagram"
          class="social-icon"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
            ></path>
          </svg>
        </a>
        <a
          href="https://lin.ee/LwEtisp"
          target="_blank"
          rel="noopener"
          aria-label="LINE"
          class="social-icon"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
            ><path
              d="M19.365 9.864c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-1.954v.604h1.954c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-2.922a.108.108 0 0 1-.108-.108V9.08c0-.06.048-.108.108-.108h2.922c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108h-1.954v.604h1.954zm-4.553 2.756a.108.108 0 0 1-.09.048h-.852a.108.108 0 0 1-.092-.052l-1.544-2.088v1.932c0 .06-.048.108-.108.108h-.86a.108.108 0 0 1-.108-.108V9.08c0-.06.048-.108.108-.108h.86a.108.108 0 0 1 .09.048l1.544 2.088V9.08c0-.06.048-.108.108-.108h.86c.06 0 .108.048.108.108v2.844c0 .06-.048.108-.108.108h-.86a.104.104 0 0 1-.016-.004zM9.473 12.62h-.86a.108.108 0 0 1-.108-.108V9.08c0-.06.048-.108.108-.108h.86c.06 0 .108.048.108.108v3.432c0 .06-.048.108-.108.108zm-1.837 0h-2.92a.108.108 0 0 1-.108-.108V9.08c0-.06.048-.108.107-.108h.86c.06 0 .108.048.108.108v2.572h1.953c.058 0 .104.048.104.108v.86c0 .06-.046.108-.104.108zM24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"
            ></path>
          </svg>
        </a>
      </div>
      <SearchModal />
    </div>
  </header>

  <!-- ═══ HERO FEATURED POST ═══ -->
  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-badge">
          <span class="badge-dot"></span>
          {ui.latestArticle}
        </span>
        <h1 class="hero-title" set:html={heroPost.title}></h1>
        <p class="hero-excerpt">
          {stripHtml(heroPost.excerpt).substring(0, 180)}…
        </p>
        <div class="hero-meta">
          {
            heroPost.author?.avatar && (
              <img
                src={heroPost.author.avatar}
                alt={heroPost.author.name}
                class="hero-avatar"
                width="32"
                height="32"
              />
            )
          }
          <span class="hero-author">{getAuthorName(heroPost.author)}</span>
          <span class="hero-separator">·</span>
          <time datetime={heroPost.date}>{formatDate(heroPost.date)}</time>
        </div>
        <a href={`/blog/${heroPost.slug}`} class="hero-cta">
          {ui.readArticle}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path
              d="M3 8h10m0 0L9 4m4 4L9 12"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </a>
      </div>
      <div class="hero-image-wrapper">
        {
          heroPost.featuredImage?.sourceUrl ? (
            <a href={`/blog/${heroPost.slug}`} class="hero-image-link">
              <img
                src={localizeImageUrl(heroPost.featuredImage.sourceUrl)}
                alt={
                  heroPost.featuredImage.altText || stripHtml(heroPost.title)
                }
                class="hero-image"
                loading="eager"
                fetchpriority="high"
                width="1024"
                height="683"
              />
            </a>
          ) : (
            <div class="hero-image-placeholder">
              <svg
                width="64"
                height="64"
                viewBox="0 0 24 24"
                fill="none"
                opacity="0.3"
              >
                <path
                  d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"
                  stroke="currentColor"
                  stroke-width="1.5"
                />
                <circle cx="8.5" cy="8.5" r="1.5" fill="currentColor" />
                <path
                  d="m21 15-5-5L5 21"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                />
              </svg>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <!-- ═══ CATEGORY PILLS ═══ -->
  {
    categories.length > 0 && (
      <section class="categories-section">
        <div class="categories-inner">
          <nav class="category-pills" aria-label="Browse topics">
            <a href="/blog" class="pill pill-active">
              {ui.allArticles}
            </a>
            {categories.slice(0, 12).map((cat) => (
              <a href={`/category/${cat.slug}`} class="pill">
                {cat.name}
                <span class="pill-count">{cat.count}</span>
              </a>
            ))}
          </nav>
        </div>
      </section>
    )
  }

  <!-- ═══ AEO DIRECT ANSWER (hidden visually, for crawlers) ═══ -->
  <section class="container aeo-section">
    <DirectAnswerBox
      question={ui.whoIsDrTim}
      answer={ui.drTimAnswer}
      author="Dr. Tim"
      specialty="Functional Medicine"
    />
  </section>

  <!-- ═══ EDITOR'S PICKS — 2-col editorial grid ═══ -->
  {
    editorPicks.length > 0 && (
      <section class="container section-picks">
        <div class="section-header">
          <h2 class="section-title">{ui.editorsPicks}</h2>
          <a href="/blog" class="section-link">
            {ui.viewAll}
          </a>
        </div>
        <div class="picks-grid">
          {editorPicks.map((post) => (
            <article class="pick-card">
              <a href={`/blog/${post.slug}`} class="pick-link">
                {post.featuredImage?.sourceUrl && (
                  <div class="pick-image">
                    <img
                      src={localizeImageUrl(post.featuredImage.sourceUrl)}
                      alt={post.featuredImage.altText || stripHtml(post.title)}
                      loading="lazy"
                    />
                  </div>
                )}
                <div class="pick-body">
                  {post.categories?.[0] && (
                    <span class="pick-category">{post.categories[0].name}</span>
                  )}
                  <h3 set:html={post.title} />
                  <p class="pick-excerpt">
                    {stripHtml(post.excerpt).substring(0, 100)}…
                  </p>
                  <div class="pick-meta">
                    <time datetime={post.date}>{formatDate(post.date)}</time>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </section>
    )
  }

  <!-- ═══ LATEST ARTICLES — 3-col card grid ═══ -->
  <section class="container section-latest">
    <div class="section-header">
      <h2 class="section-title">{ui.latestArticles}</h2>
      <a href="/blog" class="section-link">{ui.browseAll}</a>
    </div>
    <div class="articles-grid">
      {
        latestPosts.map((post, i) => (
          <article class="article-card">
            <a href={`/blog/${post.slug}`} class="article-link">
              {post.featuredImage?.sourceUrl && (
                <div class="article-image">
                  <img
                    src={localizeImageUrl(post.featuredImage.sourceUrl)}
                    alt={post.featuredImage.altText || stripHtml(post.title)}
                    loading="lazy"
                  />
                  {post.categories?.[0] && (
                    <span class="article-badge">{post.categories[0].name}</span>
                  )}
                </div>
              )}
              <div class="article-body">
                <h3 set:html={post.title} />
                <p class="article-excerpt">
                  {stripHtml(post.excerpt).substring(0, 90)}…
                </p>
                <div class="article-meta">
                  <time datetime={post.date}>{formatDate(post.date)}</time>
                  <span class="article-read">{ui.read}</span>
                </div>
              </div>
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ═══ MORE ARTICLES — Compact list ═══ -->
  {
    morePosts.length > 0 && (
      <section class="container section-more">
        <div class="section-header">
          <h2 class="section-title">{ui.moreToExplore}</h2>
        </div>
        <div class="more-list">
          {morePosts.map((post) => (
            <a href={`/blog/${post.slug}`} class="more-item">
              <div class="more-content">
                {post.categories?.[0] && (
                  <span class="more-category">{post.categories[0].name}</span>
                )}
                <h3 set:html={post.title} />
                <time datetime={post.date}>{formatDate(post.date)}</time>
              </div>
              {post.featuredImage?.sourceUrl && (
                <img
                  src={localizeImageUrl(post.featuredImage.sourceUrl)}
                  alt={stripHtml(post.title)}
                  class="more-thumb"
                  loading="lazy"
                />
              )}
            </a>
          ))}
        </div>
        <div class="section-cta">
          <a href="/blog" class="btn-browse">
            {ui.viewAllArticles} {totalPosts}+
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3 8h10m0 0L9 4m4 4L9 12"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
