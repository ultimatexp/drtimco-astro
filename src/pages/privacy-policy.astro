---
export const prerender = true;
/**
 * Privacy Policy Page — /privacy-policy
 * Thai PDPA-compliant privacy policy for Dr. Tim's medical website.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const lastUpdated = '10 มีนาคม 2568';
---

<BaseLayout
  title="นโยบายความเป็นส่วนตัว"
  description="นโยบายความเป็นส่วนตัวและการคุ้มครองข้อมูลส่วนบุคคล (PDPA) ของ Dr. Tim — Functional Medicine"
  canonicalUrl="https://drtim.co/privacy-policy"
>
  <div class="policy-page">
    <div class="policy-header">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <ol>
          <li><a href="/">หน้าแรก</a></li>
          <li><span aria-current="page">นโยบายความเป็นส่วนตัว</span></li>
        </ol>
      </nav>
      <h1>นโยบายความเป็นส่วนตัว</h1>
      <p class="policy-subtitle">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        การคุ้มครองข้อมูลส่วนบุคคลตาม พ.ร.บ. คุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562 (PDPA)
      </p>
      <p class="policy-updated">อัปเดตล่าสุด: {lastUpdated}</p>
    </div>

    <div class="policy-content">
      <!-- Section 1 -->
      <section class="policy-section">
        <h2>1. บทนำ</h2>
        <p>
          เว็บไซต์ <strong>drtim.co</strong> ("เว็บไซต์") ดำเนินการโดย Dr. Tim — Functional Medicine
          เราให้ความสำคัญกับการคุ้มครองข้อมูลส่วนบุคคลของท่าน และปฏิบัติตามพระราชบัญญัติคุ้มครองข้อมูลส่วนบุคคล พ.ศ. 2562
          (Personal Data Protection Act: PDPA) อย่างเคร่งครัด
        </p>
        <p>
          นโยบายฉบับนี้อธิบายถึงวิธีการที่เราเก็บรวบรวม ใช้ เปิดเผย และปกป้องข้อมูลส่วนบุคคลของท่าน
          เมื่อท่านเข้าใช้งานเว็บไซต์ของเรา
        </p>
      </section>

      <!-- Section 2 -->
      <section class="policy-section">
        <h2>2. ข้อมูลที่เราเก็บรวบรวม</h2>
        <p>เราอาจเก็บรวบรวมข้อมูลส่วนบุคคลของท่านดังต่อไปนี้:</p>

        <h3>2.1 ข้อมูลที่ท่านให้โดยตรง</h3>
        <ul>
          <li>ชื่อ-นามสกุล, อีเมล, หมายเลขโทรศัพท์ (เมื่อท่านติดต่อเราหรือนัดหมาย)</li>
          <li>ข้อมูลที่ท่านส่งผ่านแบบฟอร์มติดต่อ</li>
          <li>ข้อมูลการสนทนาผ่าน LINE Official Account</li>
        </ul>

        <h3>2.2 ข้อมูลที่เก็บรวบรวมอัตโนมัติ</h3>
        <ul>
          <li>ที่อยู่ IP Address</li>
          <li>ประเภทเบราว์เซอร์และอุปกรณ์</li>
          <li>หน้าเว็บที่เข้าชมและระยะเวลาการเข้าชม</li>
          <li>ข้อมูลคุกกี้ (Cookie) และเทคโนโลยีที่คล้ายคลึง</li>
          <li>ข้อมูลจาก Google Analytics (ข้อมูลเชิงสถิติที่ไม่ระบุตัวตน)</li>
        </ul>
      </section>

      <!-- Section 3 -->
      <section class="policy-section">
        <h2>3. วัตถุประสงค์ในการใช้ข้อมูล</h2>
        <p>เราใช้ข้อมูลส่วนบุคคลของท่านเพื่อวัตถุประสงค์ดังต่อไปนี้:</p>
        <ul>
          <li><strong>การให้บริการ:</strong> เพื่อตอบข้อซักถาม นัดหมาย และให้ข้อมูลด้านสุขภาพ</li>
          <li><strong>การพัฒนาเว็บไซต์:</strong> เพื่อวิเคราะห์การใช้งานและปรับปรุงประสบการณ์ผู้ใช้</li>
          <li><strong>การสื่อสาร:</strong> เพื่อส่งข้อมูลข่าวสารด้านสุขภาพที่เป็นประโยชน์ (เฉพาะเมื่อได้รับความยินยอม)</li>
          <li><strong>การปฏิบัติตามกฎหมาย:</strong> เพื่อปฏิบัติตามข้อกำหนดทางกฎหมายที่เกี่ยวข้อง</li>
        </ul>
      </section>

      <!-- Section 4 -->
      <section class="policy-section">
        <h2>4. การใช้คุกกี้ (Cookies)</h2>
        <p>เว็บไซต์ของเราใช้คุกกี้ดังนี้:</p>

        <div class="cookie-table-wrapper">
          <table class="cookie-table">
            <thead>
              <tr>
                <th>ประเภท</th>
                <th>วัตถุประสงค์</th>
                <th>ความจำเป็น</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>คุกกี้ที่จำเป็น</strong></td>
                <td>ทำให้เว็บไซต์ทำงานได้อย่างถูกต้อง เช่น การจดจำการยินยอม PDPA</td>
                <td><span class="badge badge-required">จำเป็น</span></td>
              </tr>
              <tr>
                <td><strong>คุกกี้วิเคราะห์</strong></td>
                <td>วิเคราะห์การใช้งานเว็บไซต์ผ่าน Google Analytics เพื่อปรับปรุงเนื้อหา</td>
                <td><span class="badge badge-optional">ไม่บังคับ</span></td>
              </tr>
            </tbody>
          </table>
        </div>

        <p>
          ท่านสามารถตั้งค่าเบราว์เซอร์เพื่อปฏิเสธคุกกี้ทั้งหมดหรือบางส่วนได้
          อย่างไรก็ตาม การปิดคุกกี้อาจส่งผลให้บางฟีเจอร์ของเว็บไซต์ไม่สามารถทำงานได้ครบถ้วน
        </p>
      </section>

      <!-- Section 5 -->
      <section class="policy-section">
        <h2>5. การเปิดเผยข้อมูล</h2>
        <p>เราจะ <strong>ไม่</strong> ขาย แลกเปลี่ยน หรือเปิดเผยข้อมูลส่วนบุคคลของท่านให้แก่บุคคลภายนอก ยกเว้นในกรณีดังต่อไปนี้:</p>
        <ul>
          <li>เมื่อได้รับความยินยอมจากท่าน</li>
          <li>เมื่อเป็นการปฏิบัติตามกฎหมายหรือคำสั่งศาล</li>
          <li>ผู้ให้บริการที่เราใช้ในการดำเนินงาน (เช่น Google Analytics, LINE) ซึ่งมีข้อตกลงการรักษาความลับ</li>
        </ul>
      </section>

      <!-- Section 6 -->
      <section class="policy-section">
        <h2>6. การรักษาความปลอดภัย</h2>
        <p>
          เราใช้มาตรการรักษาความปลอดภัยที่เหมาะสมเพื่อปกป้องข้อมูลส่วนบุคคลของท่าน รวมถึง:
        </p>
        <ul>
          <li>การเข้ารหัสข้อมูลด้วย SSL/TLS (HTTPS)</li>
          <li>การจำกัดการเข้าถึงข้อมูลเฉพาะบุคลากรที่ได้รับอนุญาต</li>
          <li>การทบทวนมาตรการรักษาความปลอดภัยอย่างสม่ำเสมอ</li>
        </ul>
      </section>

      <!-- Section 7 -->
      <section class="policy-section">
        <h2>7. ระยะเวลาการเก็บรักษาข้อมูล</h2>
        <p>
          เราจะเก็บรักษาข้อมูลส่วนบุคคลของท่านเท่าที่จำเป็นตามวัตถุประสงค์ที่ระบุไว้
          หรือตามที่กฎหมายกำหนด เมื่อหมดความจำเป็น เราจะลบหรือทำให้ข้อมูลไม่สามารถระบุตัวบุคคลได้
        </p>
      </section>

      <!-- Section 8 -->
      <section class="policy-section">
        <h2>8. สิทธิของเจ้าของข้อมูล</h2>
        <p>ภายใต้ พ.ร.บ. คุ้มครองข้อมูลส่วนบุคคล ท่านมีสิทธิดังต่อไปนี้:</p>

        <div class="rights-grid">
          <div class="right-card">
            <div class="right-icon">📋</div>
            <h4>สิทธิในการเข้าถึง</h4>
            <p>ขอดูข้อมูลส่วนบุคคลของท่านที่เราเก็บรวบรวมไว้</p>
          </div>
          <div class="right-card">
            <div class="right-icon">✏️</div>
            <h4>สิทธิในการแก้ไข</h4>
            <p>ขอแก้ไขข้อมูลส่วนบุคคลที่ไม่ถูกต้องหรือไม่สมบูรณ์</p>
          </div>
          <div class="right-card">
            <div class="right-icon">🗑️</div>
            <h4>สิทธิในการลบ</h4>
            <p>ขอให้ลบข้อมูลส่วนบุคคลของท่านออกจากระบบ</p>
          </div>
          <div class="right-card">
            <div class="right-icon">⏸️</div>
            <h4>สิทธิในการระงับ</h4>
            <p>ขอให้ระงับการใช้ข้อมูลส่วนบุคคลของท่านชั่วคราว</p>
          </div>
          <div class="right-card">
            <div class="right-icon">📤</div>
            <h4>สิทธิในการโอนย้าย</h4>
            <p>ขอรับข้อมูลในรูปแบบที่สามารถอ่านได้ด้วยเครื่อง</p>
          </div>
          <div class="right-card">
            <div class="right-icon">🚫</div>
            <h4>สิทธิในการคัดค้าน</h4>
            <p>คัดค้านการเก็บรวบรวมหรือใช้ข้อมูลส่วนบุคคลของท่าน</p>
          </div>
        </div>

        <p class="rights-note">
          หากท่านต้องการใช้สิทธิใดๆ ข้างต้น สามารถติดต่อเราได้ตามช่องทางด้านล่าง
          เราจะดำเนินการตามคำขอภายใน 30 วัน
        </p>
      </section>

      <!-- Section 9 -->
      <section class="policy-section">
        <h2>9. การเปลี่ยนแปลงนโยบาย</h2>
        <p>
          เราอาจปรับปรุงนโยบายความเป็นส่วนตัวเป็นครั้งคราว
          การเปลี่ยนแปลงจะมีผลเมื่อเผยแพร่บนเว็บไซต์
          เราแนะนำให้ท่านตรวจสอบนโยบายนี้เป็นประจำ
        </p>
      </section>

      <!-- Section 10 -->
      <section class="policy-section contact-section">
        <h2>10. ช่องทางติดต่อ</h2>
        <p>หากท่านมีคำถามเกี่ยวกับนโยบายความเป็นส่วนตัว หรือต้องการใช้สิทธิตาม PDPA สามารถติดต่อเราได้ที่:</p>

        <div class="contact-card">
          <div class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            <div>
              <strong>Dr. Tim — Functional Medicine</strong>
              <span>Ultramed Clinic Chonburi</span>
            </div>
          </div>
          <div class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <div>
              <strong>เว็บไซต์:</strong>
              <a href="https://drtim.co">drtim.co</a>
            </div>
          </div>
          <div class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
            <div>
              <strong>LINE:</strong>
              <a href="https://lin.ee/LwEtisp">@dr.timdietclinic</a>
            </div>
          </div>
          <div class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
            <div>
              <strong>Facebook:</strong>
              <a href="https://www.facebook.com/dr.timdietclinic/">dr.timdietclinic</a>
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .policy-page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) var(--space-16);
  }

  /* Breadcrumbs */
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .breadcrumbs li:not(:last-child)::after {
    content: '›';
    margin-left: var(--space-1);
    color: var(--color-border);
  }

  .breadcrumbs a {
    color: var(--color-text-muted);
    transition: color var(--transition);
  }

  .breadcrumbs a:hover {
    color: var(--color-primary);
  }

  .breadcrumbs [aria-current] {
    color: var(--color-text);
    font-weight: 500;
  }

  /* Header */
  .policy-header {
    margin-bottom: var(--space-12);
  }

  .policy-header h1 {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .policy-subtitle {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: var(--space-2);
  }

  .policy-updated {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Content Sections */
  .policy-section {
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .policy-section:last-child {
    border-bottom: none;
  }

  .policy-section h2 {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .policy-section h3 {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
  }

  .policy-section p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .policy-section ul {
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
  }

  .policy-section li {
    font-size: var(--text-base);
    line-height: 1.8;
    margin-bottom: var(--space-2);
    color: var(--color-text);
  }

  /* Cookie Table */
  .cookie-table-wrapper {
    overflow-x: auto;
    margin: var(--space-4) 0 var(--space-6);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
  }

  .cookie-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .cookie-table th {
    background: #f8fafc;
    padding: var(--space-3) var(--space-4);
    text-align: left;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  .cookie-table td {
    padding: var(--space-3) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    line-height: 1.6;
  }

  .cookie-table tr:last-child td {
    border-bottom: none;
  }

  .badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: var(--text-xs);
    font-weight: 600;
    white-space: nowrap;
  }

  .badge-required {
    background: #dcfce7;
    color: #166534;
  }

  .badge-optional {
    background: #fef9c3;
    color: #854d0e;
  }

  /* Rights Grid */
  .rights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-4);
    margin: var(--space-6) 0;
  }

  .right-card {
    padding: var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .right-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .right-icon {
    font-size: 1.5rem;
    margin-bottom: var(--space-2);
  }

  .right-card h4 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .right-card p {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .rights-note {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--color-answer-bg);
    border: 1px solid var(--color-answer-border);
    border-radius: var(--radius);
    font-size: var(--text-sm) !important;
    color: var(--color-primary-dark) !important;
  }

  /* Contact Card */
  .contact-card {
    margin-top: var(--space-4);
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
