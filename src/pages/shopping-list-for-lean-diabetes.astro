---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { name: "หน้าแรก", url: "https://drtim.co/" },
  {
    name: "เช็คลิสต์ไปตลาดสำหรับเบาหวานผอม",
    url: "https://drtim.co/shopping-list-for-lean-diabetes",
  },
];
---

<BaseLayout
  title="เช็คลิสต์ไปตลาดสำหรับเบาหวานผอม"
  description="หน้าเช็กลิสต์ไปตลาดแบบโต้ตอบได้สำหรับผู้มีภาวะเบาหวานผอม (Lean Diabetes) เรียงตามลำดับการกิน: ฐานพีระมิด ผัก คาร์บเชิงซ้อน ผลไม้ GI ต่ำ และรายการที่ควรเลี่ยง"
  canonicalUrl="https://drtim.co/shopping-list-for-lean-diabetes"
  type="website"
  breadcrumbs={breadcrumbs}
  directAnswer="เช็กลิสต์นี้ช่วยวางแผนซื้อวัตถุดิบสำหรับเบาหวานผอมโดยเรียงจากอาหารที่ควรกินเป็นหลักไปจนถึงรายการที่ควรเลี่ยง ผู้ใช้สามารถติ๊กสินค้าแต่ละรายการ ติดตามความคืบหน้า และรีเซ็ตรายการได้ในหน้าเดียว"
>
  <section class="shopping-page container">
    <header class="shopping-header">
      <p class="eyebrow">Shopping List</p>
      <h1>🛒 เช็คลิสต์ไปตลาด (เรียงตามลำดับการกิน)</h1>
      <p class="subtitle">
        เลือกจากคอลัมน์ซ้ายให้เต็มก่อน แล้วค่อยพิจารณาคอลัมน์ถัดไป
      </p>
    </header>

    <div class="toolbar">
      <div class="stats" role="status" aria-live="polite">
        <span id="checkedCount">0</span>/<span id="totalCount">0</span> รายการที่เลือกแล้ว
      </div>
      <div class="toolbar-actions">
        <button id="exportA4Pdf" class="export-btn" type="button">
          Export A4 PDF
        </button>
        <button id="resetChecklist" class="reset-btn" type="button">
          รีเซ็ตทั้งหมด
        </button>
      </div>
    </div>

    <div class="grid" id="shoppingChecklist">
      <article class="column primary" data-category="base">
