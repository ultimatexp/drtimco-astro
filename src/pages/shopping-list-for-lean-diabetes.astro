  <script is:inline>
    (() => {
      const STORAGE_KEY = "drtim-lean-diabetes-shopping-list-v1";
      const checkboxes = Array.from(
        document.querySelectorAll('input[type="checkbox"][data-item-id]'),
      );
      const checkedCountEl = document.getElementById("checkedCount");
      const totalCountEl = document.getElementById("totalCount");
      const resetBtn = document.getElementById("resetChecklist");
      const exportBtn = document.getElementById("exportA4Pdf");

      const getCurrentState = () => {
        const state = {};
        checkboxes.forEach((cb) => {
          state[cb.dataset.itemId] = cb.checked;
        });
        return state;
      };

      const applyState = (state) => {
        checkboxes.forEach((cb) => {
          cb.checked = Boolean(state?.[cb.dataset.itemId]);
        });
      };

      const updateStats = () => {
        const checked = checkboxes.filter((cb) => cb.checked).length;
        if (checkedCountEl) checkedCountEl.textContent = String(checked);
        if (totalCountEl) totalCountEl.textContent = String(checkboxes.length);
      };

      const saveState = () => {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(getCurrentState()));
      };

      const loadState = () => {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          if (!raw) return;
          applyState(JSON.parse(raw));
        } catch (err) {
          console.warn("Cannot restore shopping checklist state", err);
        }
      };

      loadState();
      updateStats();

      checkboxes.forEach((cb) => {
        cb.addEventListener("change", () => {
          saveState();
          updateStats();
        });
      });

      resetBtn?.addEventListener("click", () => {
        checkboxes.forEach((cb) => {
          cb.checked = false;
        });
        saveState();
        updateStats();
      });

      const escapeHtml = (value) =>
        value
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");

      const buildPrintableHtml = () => {
        const sections = [];
        let selectedCount = 0;
        document
          .querySelectorAll("#shoppingChecklist .column, .seasoning")
          .forEach((section) => {
            const titleEl = section.querySelector("h2");
            const title = titleEl?.textContent?.trim() || "";
            if (!title) return;

            const items = Array.from(section.querySelectorAll("li label"))
              .map((label) => {
                const checkbox = label.querySelector('input[type="checkbox"]');
                const checked = Boolean(checkbox?.checked);
                if (!checked) return "";
                selectedCount += 1;
                const text = label.textContent?.trim() || "";
                return `<li><span class="tick">✓</span><span>${escapeHtml(text)}</span></li>`;
              })
              .filter(Boolean);

            if (items.length === 0) return;

            sections.push(`
              <section class="print-section">
                <h2>${escapeHtml(title)}</h2>
                <ul>${items.join("")}</ul>
              </section>
            `);
          });

        const now = new Date().toLocaleString("th-TH", {
          dateStyle: "medium",
          timeStyle: "short",
        });

        const emptyState =
          selectedCount === 0
            ? `<section class="empty-state">
                 <h2>ยังไม่มีรายการที่เลือก</h2>
                 <p>กรุณาติ๊กอย่างน้อย 1 รายการในเช็กลิสต์ แล้วกด Export A4 PDF อีกครั้ง</p>
               </section>`
            : "";

        return `<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <title>Shopping Checklist - Lean Diabetes</title>
    <style>
      @page {
        size: A4;
        margin: 16mm;
      }
      :root {
        --ink: #0f172a;
        --muted: #475569;
        --line: #dbe4f0;
        --brand: #0f766e;
        --brand-soft: #e6fffb;
        --card: #ffffff;
      }
      body {
        font-family: "Inter", "Noto Sans Thai", system-ui, sans-serif;
        color: var(--ink);
        margin: 0;
        line-height: 1.45;
        background: linear-gradient(180deg, #f8fafc 0%, #ffffff 20%);
        padding: 2mm;
      }
      .head {
        border: 1px solid var(--line);
        background: linear-gradient(130deg, var(--brand-soft), #ffffff 55%);
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 14px;
      }
      h1 {
        margin: 0 0 4px 0;
        font-size: 22px;
        letter-spacing: -0.01em;
      }
      .meta {
        margin: 0;
        color: var(--muted);
        font-size: 12px;
      }
      .summary {
        margin-top: 10px;
        display: inline-flex;
        border: 1px solid #99f6e4;
        background: #f0fdfa;
        color: #115e59;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        font-weight: 700;
      }
      .grid {
        columns: 2;
        column-gap: 16px;
      }
      .print-section {
        break-inside: avoid;
        margin-bottom: 12px;
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 10px 10px 8px;
        background: var(--card);
        box-shadow: 0 3px 10px rgba(15, 23, 42, 0.04);
      }
      h2 {
        font-size: 14px;
        margin: 0 0 7px 0;
        color: var(--brand);
      }
      ul {
        margin: 0;
        padding-left: 0;
        list-style: none;
      }
      li {
        font-size: 12px;
        margin-bottom: 4px;
        display: grid;
        grid-template-columns: 14px 1fr;
        gap: 6px;
        align-items: start;
      }
      .tick {
        color: var(--brand);
        font-weight: 800;
      }
      .empty-state {
        border: 1px dashed #cbd5e1;
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        background: #f8fafc;
      }
      .empty-state h2 {
        color: #334155;
        margin-bottom: 4px;
      }
      .empty-state p {
        margin: 0;
        color: #64748b;
        font-size: 12px;
      }
      .tips {
        margin-top: 12px;
        font-size: 11px;
        color: #334155;
        border-top: 1px solid var(--line);
        padding-top: 8px;
      }
    </style>
  </head>
  <body>
    <header class="head">
      <h1>🛒 เช็คลิสต์ไปตลาด (Lean Diabetes)</h1>
      <p class="meta">สร้างเมื่อ: ${escapeHtml(now)}</p>
      <p class="meta">Export เฉพาะรายการที่ติ๊กแล้ว • พร้อมพิมพ์ A4</p>
      <p class="summary">รายการที่เลือกทั้งหมด: ${selectedCount}</p>
    </header>
    <main class="grid">
      ${selectedCount > 0 ? sections.join("") : emptyState}
    </main>
    <p class="tips">💡 เลือกจากคอลัมน์ซ้ายให้เต็มก่อน • คาร์บกินช่วงที่ต้องใช้พลังงาน • พยายามเลี่ยงของหวานและแปรรูป</p>
  </body>
</html>`;
      };

      exportBtn?.addEventListener("click", () => {
        const popup = window.open("about:blank", "_blank");
        if (!popup) {
          window.alert("เบราว์เซอร์บล็อก popup กรุณาอนุญาต popup แล้วลองใหม่");
          return;
        }
        popup.document.open();
        popup.document.write(buildPrintableHtml());
        popup.document.close();
        window.setTimeout(() => {
          popup.focus();
          popup.print();
        }, 250);
      });
    })();
  </script>

  <style>
