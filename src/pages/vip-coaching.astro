<style>
    :root {
        --cgm-dark: #0a0f0d;
        --cgm-teal: #0f766e;
        --cgm-teal-light: #14b8a6;
        --cgm-gold: #f59e0b;
        --cgm-gold-light: #fbbf24;
        --cgm-surface: #111816;
        --cgm-card: rgba(255, 255, 255, 0.04);
        --cgm-border: rgba(255, 255, 255, 0.08);
        --cgm-text: #f0fdf4;
        --cgm-text-muted: rgba(255, 255, 255, 0.6);
        --cgm-radius: 16px;
        --cgm-max: 1100px;
    }
    .text-accent {
        color: var(--cgm-teal-light);
    }
    .text-gold {
        color: var(--cgm-gold);
    }
    .section-inner {
        max-width: var(--cgm-max);
        margin: 0 auto;
        padding: 80px 24px;
    }
    .section-badge {
        display: inline-block;
        padding: 6px 16px;
        border-radius: 999px;
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: rgba(20, 184, 166, 0.15);
        color: var(--cgm-teal-light);
        border: 1px solid rgba(20, 184, 166, 0.2);
        margin-bottom: 16px;
    }
    .section-subtitle {
        font-size: 16px;
        color: var(--cgm-text-muted);
        text-align: center;
        line-height: 1.7;
        margin-bottom: 48px;
    }
    /* TOP BAR */
    .top-bar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 100;
        background: rgba(10, 15, 13, 0.85);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid var(--cgm-border);
    }
    .top-bar-inner {
        max-width: var(--cgm-max);
        margin: 0 auto;
        padding: 12px 24px;
        display: flex;
        align-items: center;
        gap: 24px;
    }
    .top-bar-brand {
        display: flex;
        align-items: center;
        gap: 8px;
        color: white;
        font-weight: 700;
        font-size: 16px;
    }
    .brand-icon {
        font-size: 20px;
    }
    .top-bar-nav {
        display: flex;
        gap: 20px;
        margin-right: auto;
    }
    .top-bar-nav a {
        font-size: 13px;
        font-weight: 500;
        color: var(--cgm-text-muted);
        transition: color 200ms;
    }
    .top-bar-nav a:hover {
        color: white;
    }
    .nav-cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 20px;
        background: #06c755;
        color: white;
        font-size: 13px;
        font-weight: 700;
        border-radius: 999px;
        transition: all 200ms;
    }
    .nav-cta-btn:hover {
        background: #05b04a;
        transform: translateY(-1px);
        box-shadow: 0 4px 16px rgba(6, 199, 85, 0.4);
        color: white;
    }
    /* HERO */
    .hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(
            160deg,
            #0a0f0d 0%,
            #0d2018 30%,
            #071a14 70%,
            #0a0f0d 100%
        );
        overflow: hidden;
        padding-top: 60px;
    }
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(
                ellipse at 20% 50%,
                rgba(20, 184, 166, 0.08) 0%,
                transparent 60%
            ),
            radial-gradient(
                ellipse at 80% 20%,
                rgba(245, 158, 11, 0.06) 0%,
                transparent 50%
            );
        pointer-events: none;
    }
    .hero-content {
        position: relative;
        text-align: center;
        padding: 60px 24px;
        max-width: 800px;
    }
    .hero-badge-group {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 32px;
        flex-wrap: wrap;
    }
    .badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.03em;
    }
    .badge-vip {
        background: rgba(245, 158, 11, 0.15);
        color: var(--cgm-gold-light);
        border: 1px solid rgba(245, 158, 11, 0.3);
    }
    .badge-urgent {
        background: rgba(220, 38, 38, 0.12);
        color: #fca5a5;
        border: 1px solid rgba(220, 38, 38, 0.25);
    }
    .badge-pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ef4444;
        animation: pulse-glow 2s ease-in-out infinite;
    }
    @keyframes pulse-glow {
        0%,
        100% {
            opacity: 1;
            box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4);
        }
        50% {
            opacity: 0.7;
            box-shadow: 0 0 0 8px rgba(239, 68, 68, 0);
        }
    }
    .hero-title {
        font-size: clamp(2rem, 5vw + 0.5rem, 3.5rem);
        font-weight: 800;
        line-height: 1.2;
        color: white;
        margin-bottom: 24px;
        letter-spacing: -0.02em;
    }
    .hero-title-sub {
        display: block;
        font-size: 0.4em;
        font-weight: 700;
        letter-spacing: 0.2em;
        color: var(--cgm-teal-light);
        margin-bottom: 8px;
    }
    .hero-title-accent {
        background: linear-gradient(
            135deg,
            var(--cgm-teal-light),
            var(--cgm-gold-light)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .hero-desc {
        font-size: 18px;
        line-height: 1.7;
        color: var(--cgm-text-muted);
        margin-bottom: 40px;
    }
    .hero-desc strong {
        color: white;
    }
    .hero-price-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 24px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }
    .hero-trust {
        font-size: 13px;
        color: var(--cgm-text-muted);
        margin-top: 16px;
    }
    /* CTA */
    .cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 18px 40px;
        border-radius: 999px;
        font-size: 18px;
        font-weight: 800;
        transition: all 300ms ease;
        text-decoration: none;
        cursor: pointer;
        border: none;
    }
    .cta-btn-hero,
    .cta-btn-final {
        background: #06c755;
        color: white;
        box-shadow: 0 4px 24px rgba(6, 199, 85, 0.3),
            0 0 0 0 rgba(6, 199, 85, 0.3);
        animation: cta-pulse 3s ease-in-out infinite;
    }
    .cta-btn-hero:hover,
    .cta-btn-final:hover {
        background: #05b04a;
        color: white;
        transform: translateY(-3px) scale(1.02);
        box-shadow: 0 8px 32px rgba(6, 199, 85, 0.5);
    }
    @keyframes cta-pulse {
        0%,
        100% {
            box-shadow: 0 4px 24px rgba(6, 199, 85, 0.3),
                0 0 0 0 rgba(6, 199, 85, 0.3);
        }
        50% {
            box-shadow: 0 4px 24px rgba(6, 199, 85, 0.3),
                0 0 0 12px rgba(6, 199, 85, 0);
        }
    }
    .cta-btn-urgency {
        background: var(--cgm-gold);
        color: #0a0f0d;
        font-size: 16px;
        padding: 16px 36px;
        white-space: nowrap;
    }
    .cta-btn-urgency:hover {
        background: var(--cgm-gold-light);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(245, 158, 11, 0.4);
        color: #0a0f0d;
    }
    /* PROBLEM */
    .problem-section {
        background: var(--cgm-dark);
        border-top: 1px solid var(--cgm-border);
    }
    .problem-title {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 800;
        color: white;
        text-align: center;
        margin-bottom: 48px;
    }
    .problem-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    .problem-card {
        background: var(--cgm-card);
        border: 1px solid var(--cgm-border);
        border-radius: var(--cgm-radius);
        padding: 36px 28px;
        transition: all 300ms ease;
