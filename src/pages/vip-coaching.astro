---
export const prerender = true;
/**
 * VIP 1:1 Coaching Sales Page — /vip-coaching
 * SEO/AEO/GEO optimized, premium urgency-driven conversion page.
 * CTA → LINE: https://lin.ee/3E7wEPz
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQSection from "../components/FAQSection.astro";

const lineUrl = "https://lin.ee/3E7wEPz";

const faqItems = [
    {
        question: "CGM เจ็บไหม? ติดยากไหม?",
        answer: "ไม่เจ็บเลยค่ะ เข็มเล็กมากติดที่ต้นแขน ใช้ได้ 14 วัน กันน้ำได้ อาบน้ำ ออกกำลังกายได้ปกติ หมอทิมจะสอนวิธีติดในเซสชันแรกแบบตัวต่อตัว",
    },
    {
        question: "หยุดยาเบาหวานได้จริงไหม?",
        answer: "จากเคสจริงกว่า 500 ราย 94% สามารถลดยาลงได้ภายใน 12 สัปดาห์ โดยหมอทิมจะประสานกับแพทย์ประจำตัวของคุณเพื่อปรับยาอย่างปลอดภัย ไม่มีการหยุดยาเองโดยพลการ",
    },
    {
        question: "อยู่ต่างจังหวัดเรียนได้ไหม?",
        answer: "ได้เลยค่ะ ทุกเซสชันเป็นออนไลน์ 100% ผ่าน Video Call เครื่อง CGM จัดส่งฟรีถึงบ้านทั่วประเทศ คุณอยู่ที่ไหนก็เริ่มโปรแกรมได้ทันที",
    },
    {
        question: "ต่างจากคอร์ส CGM ปกติอย่างไร?",
        answer: "คอร์ส CGM ปกติเป็นกลุ่ม 14 วัน แต่ VIP Coaching คือตัวต่อตัวกับหมอทิม 12 สัปดาห์เต็ม วิเคราะห์ Data ทุกสัปดาห์ ปรับแผนให้คุณคนเดียว และมี LINE ส่วนตัวถึงหมอทิมโดยตรง — ผลลัพธ์ลึกกว่าและยั่งยืนกว่า",
    },
    {
        question: "ทำไมรับแค่ 3 ท่านต่อรุ่น?",
        answer: "เพราะหมอทิมต้องการวิเคราะห์ Data CGM ของคุณอย่างละเอียดทุกสัปดาห์ รวมถึงดูแลด้านโภชนาการ ไลฟ์สไตล์ และยาแบบตัวต่อตัว คุณภาพระดับนี้ทำได้สูงสุด 3 ท่านต่อรุ่นเท่านั้น",
    },
    {
        question: "ราคาเท่าไหร่? จ่ายอย่างไร?",
        answer: "ราคาแจ้งเฉพาะผู้ที่ผ่านการคัดกรองเบื้องต้น เนื่องจากเป็นโปรแกรมดูแลระดับพรีเมียมที่ออกแบบเฉพาะบุคคล กรุณาแอด LINE @Ultramed เพื่อพูดคุยรายละเอียดและรับการคัดกรอง",
    },
    {
        question: "ต้องเตรียมตัวอย่างไรก่อนเริ่ม?",
        answer: "แค่มีผลเลือดล่าสุด (FBS, HbA1c) และรายชื่อยาที่กินอยู่ หมอทิมจะรีวิวทุกอย่างในเซสชันแรก แล้วออกแบบแผน 12 สัปดาห์เฉพาะคุณ",
    },
];

const breadcrumbs = [
    { name: "หน้าแรก", url: "https://drtim.co/" },
    { name: "VIP Coaching", url: "https://drtim.co/vip-coaching" },
];
---

<BaseLayout
    title="1:1 VIP Coaching เบาหวานสงบแบบไม่ใช้ยา | Dr. Tim"
    description="โปรแกรม 1:1 VIP Coaching 12 สัปดาห์ โดยหมอทิม — รักษาเบาหวานแบบตัวต่อตัวโดยไม่ใช้ยา ด้วย CGM + Functional Medicine รับเพียง 3 ท่านต่อรุ่น ฟรีเครื่อง CGM สมัครผ่าน LINE @Ultramed"
    type="website"
    faqItems={faqItems}
    breadcrumbs={breadcrumbs}
    directAnswer="โปรแกรม 1:1 VIP Coaching โดยหมอทิม คือการดูแลเบาหวานแบบตัวต่อตัว 12 สัปดาห์ ด้วย CGM และ Functional Medicine เพื่อให้เบาหวานสงบโดยไม่พึ่งยา รับเพียง 3 ท่านต่อรุ่น ที่ Ultramed Clinic ชลบุรี"
>
    <!-- ═══ STICKY TOP BAR ═══ -->
    <header class="top-bar">
        <div class="top-bar-inner">
            <a href="/" class="top-bar-brand">
                <span class="brand-icon">⚕</span>
                <span class="brand-name">Dr. Tim</span>
            </a>
            <nav class="top-bar-nav">
                <a href="/">หน้าแรก</a>
                <a href="/cgm">คอร์ส CGM</a>
                <a href="#hero">VIP Coaching</a>
            </nav>
        </div>
    </header>

    <!-- ═══ SECTION 1: HERO ═══ -->
    <section class="hero" id="hero">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-badge-group">
                <span class="badge badge-vip">💎 VIP 1:1 COACHING</span>
                <span class="badge badge-urgent">
                    <span class="badge-pulse"></span>
                    ⚡ เหลือเพียง 3 ที่นั่งสุดท้าย
                </span>
            </div>
            <!-- Countdown Timer -->
            <div class="countdown-wrap" id="hero-countdown">
                <span class="countdown-label">ปิดรับสมัครใน</span>
                <div class="countdown-timer">
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-days">00</span><span
                            class="cd-lbl">วัน</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-hours">00</span><span
                            class="cd-lbl">ชม.</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-mins">00</span><span
                            class="cd-lbl">นาที</span
                        >
                    </div>
                    <span class="cd-sep">:</span>
                    <div class="countdown-unit">
                        <span class="cd-num" id="cd-secs">00</span><span
                            class="cd-lbl">วินาที</span
                        >
                    </div>
                </div>
            </div>
            <h1 class="hero-title">
                <span class="hero-title-sub">DIABETES REMISSION</span>
                เบาหวาน<span class="hero-title-accent">สงบได้</span><br />
                โดยไม่ต้องพึ่งยาแม้แต่เม็ดเดียว
            </h1>
            <p class="hero-desc">
                โปรแกรม 12 สัปดาห์ ดูแลตัวต่อตัวกับหมอทิม<br />
                ด้วย CGM + Functional Medicine — <strong
                    >พิสูจน์แล้วจาก 500+ เคสจริง</strong
                >
            </p>
            <div class="hero-price-row">
                <a
                    href={lineUrl}
                    target="_blank"
                    rel="noopener"
                    class="cta-btn cta-btn-hero"
                    id="hero-cta"
                >
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        ><path
                            d="M24 10.5C24 4.701 18.627 0 12 0S0 4.701 0 10.5c0 5.19 4.604 9.537 10.824 10.362.42.092.992.28 1.137.641.13.328.085.84.042 1.17l-.184 1.107c-.056.328-.26 1.284 1.124.7 1.384-.584 7.466-4.396 10.184-7.525C25.18 14.703 24 12.727 24 10.5z"
                        ></path>
                    </svg>
                    สมัครคัดกรอง VIP — เหลือ 3 ที่นั่ง
                </a>
            </div>
            <p class="hero-trust">
                ✓ ฟรี เครื่อง CGM &nbsp;·&nbsp; ✓ ออนไลน์ 100% จากที่ไหนก็ได้
                &nbsp;·&nbsp; ✓ ดูแลตัวต่อตัวโดยแพทย์
            </p>
        </div>
    </section>

    <!-- ═══ SECTION 2: PROBLEM / AGITATE ═══ -->
    <section class="problem-section">
        <div class="section-inner">
            <h2 class="problem-title">คุณเคยรู้สึกแบบนี้ไหม?</h2>
            <div class="problem-grid">
                <div class="problem-card">
                    <div class="problem-icon">💊</div>
                    <h3>"ยาเพิ่มทุกปี... ไม่มีวันจบ"</h3>
                    <p>
                        เริ่มจากเม็ดเดียว ตอนนี้กินสามตัว แต่น้ำตาลก็ยังไม่นิ่ง
                        — คุณสมควรรู้ว่า<strong>ทำไม</strong> ไม่ใช่แค่เพิ่มยาไปเรื่อยๆ
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">😰</div>
                    <h3>"กลัวไตพัง... กลัวตาบอด"</h3>
                    <p>
                        ทุกครั้งที่ไปหาหมอ คุณได้ยินแต่คำเตือน —
                        แต่ไม่เคยมีใครบอกว่าจะ<strong>แก้ที่ต้นเหตุ</strong
                        >ได้อย่างไร
                    </p>
                </div>
                <div class="problem-card">
                    <div class="problem-icon">🔄</div>
                    <h3>"ลองมาหมดแล้ว... ไม่เวิร์ค"</h3>
                    <p>
                        คุมอาหาร ออกกำลัง กินสมุนไพร — แต่ลองผิดลองถูกไม่มีแผน
                        ผลลัพธ์จึงไม่ยั่งยืน เพราะคุณ<strong
                            >ไม่มีข้อมูลเฉพาะตัว</strong
                        >
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 3: SOLUTION ═══ -->
    <section class="benefits-section" id="solution">
        <div class="section-inner">
            <span class="section-badge">ทางออกที่พิสูจน์แล้ว</span>
            <h2 class="benefits-title">
                โปรแกรม 12 สัปดาห์ที่ออกแบบมาเพื่อ<span class="text-accent"
                    >คุณคนเดียว</span
                >
            </h2>
            <p class="section-subtitle">
                หมอทิมใช้ CGM เป็น "เข็มทิศอัจฉริยะ"
                ให้คุณเห็นผลกระทบของอาหารแต่ละมื้อ<br />
                แบบ Real-time แล้ววิเคราะห์ Data ออกแบบแผนเฉพาะคุณทุกสัปดาห์
            </p>
            <div class="benefits-grid">
                <div class="benefit-card benefit-featured">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">📟</span>
                    </div>
                    <h3>ฟรี! เครื่อง CGM</h3>
                    <p>
                        จัดส่งถึงบ้าน ติดตามน้ำตาลตลอด 24 ชม. —
                        ข้อมูลที่การเจาะเลือดไม่เคยบอกคุณ
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">🩺</span>
                    </div>
                    <h3>1:1 กับหมอทิมทุกสัปดาห์</h3>
                    <p>
                        Video Call ส่วนตัว วิเคราะห์ Data ปรับแผนให้<strong
                            >เหมาะกับร่างกายคุณ</strong
                        >โดยเฉพาะ
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">💬</span>
                    </div>
                    <h3>LINE ส่วนตัวถึงหมอทิม</h3>
                    <p>
                        ไม่ต้องรอนัดหมอ สงสัยอะไรถามได้ตลอด —
                        เหมือนมีหมอส่วนตัวดูแลคุณ 24/7
                    </p>
                </div>
                <div class="benefit-card">
                    <div class="benefit-icon-wrap">
                        <span class="benefit-icon">📋</span>
                    </div>
                    <h3>แผนโภชนาการเฉพาะบุคคล</h3>
                    <p>
                        ไม่ใช่สูตรสำเร็จรูป แต่เป็นแผนที่ออกแบบจาก Data CGM ของ<em
                            >คุณ</em
                        >จริงๆ
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 4: VIP vs GROUP COMPARISON ═══ -->
    <section class="compare-section">
        <div class="section-inner">
            <span class="section-badge">💎 ทำไมต้อง VIP?</span>
            <h2 class="compare-title">ต่างจากคอร์สกลุ่มอย่างไร?</h2>
            <div class="compare-table-wrap">
                <table class="compare-table">
                    <thead>
                        <tr>
                            <th></th>
                            <th>คอร์ส CGM ปกติ</th>
                            <th class="compare-vip">💎 VIP 1:1 Coaching</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td>ระยะเวลา</td><td>14 วัน</td><td
                                class="compare-vip"
                                ><strong>12 สัปดาห์</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>รูปแบบ</td><td>กลุ่ม 20-30 คน</td><td
                                class="compare-vip"
                                ><strong>ตัวต่อตัว</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>สัมมนากับหมอทิม</td><td>3 ครั้ง (กลุ่ม)</td><td
                                class="compare-vip"
                                ><strong>12 ครั้ง (ส่วนตัว)</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>วิเคราะห์ Data</td><td>ภาพรวมกลุ่ม</td><td
                                class="compare-vip"
                                ><strong>รายนาที เฉพาะคุณ</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>LINE ถึงหมอทิม</td><td>ผ่านกลุ่ม</td><td
                                class="compare-vip"
                                ><strong>ส่วนตัว 24/7</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>การปรับยา</td><td>—</td><td class="compare-vip"
                                ><strong>ประสานแพทย์ประจำตัว</strong>
                            </td>
                        </tr>
                        <tr
                            ><td>เครื่อง CGM</td><td>1 เครื่อง</td><td
                                class="compare-vip"
                                ><strong>ฟรี 1 เครื่อง + ติดตามต่อเนื่อง</strong
                                >
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 5: 12-WEEK ROADMAP ═══ -->
    <section class="timeline-section">
        <div class="section-inner">
            <span class="section-badge">เส้นทาง 12 สัปดาห์</span>
            <h2 class="timeline-title">
                3 เฟสสู่<span class="text-accent">เบาหวานสงบ</span>
            </h2>
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">เฟส 1</span><span
                            class="timeline-range">สัปดาห์ 1-4</span
                        >
                    </div>
                    <div class="timeline-content">
                        <h3>🔍 ค้นหาต้นเหตุ — Discovery Phase</h3>
                        <p>
                            ติด CGM + เก็บข้อมูลอาหารทุกมื้อ
                            หมอทิมวิเคราะห์ว่าอาหารชนิดไหนทำให้น้ำตาล<em
                                >ของคุณ</em
                            >พุ่ง แล้ววางแผนอาหารเฉพาะบุคคล
                        </p>
                    </div>
                </div>
                <div class="timeline-item">
                    <div class="timeline-marker">
                        <span class="timeline-day">เฟส 2</span><span
                            class="timeline-range">สัปดาห์ 5-8</span
                        >
                    </div>
                    <div class="timeline-content">
                        <h3>⚡ ปรับเปลี่ยน — Optimization Phase</h3>
                        <p>
                            ปฏิบัติตามแผนอาหาร + ไลฟ์สไตล์ที่วิเคราะห์จาก Data
                            ปรับละเอียดทุกสัปดาห์ เริ่มเห็นน้ำตาลนิ่งขึ้น —
                            หมอทิมประสานแพทย์ประจำตัวเรื่องการลดยา
                        </p>
                    </div>
                </div>
                <div class="timeline-item timeline-item-final">
                    <div class="timeline-marker">
                        <span class="timeline-day">เฟส 3</span><span
                            class="timeline-range">สัปดาห์ 9-12</span
                        >
                    </div>
                    <div class="timeline-content">
                        <h3>🎯 รักษาผลลัพธ์ — Sustainability Phase</h3>
                        <p>
                            สร้างนิสัยถาวร วัดผล HbA1c ซ้ำ
                            วางแผนระยะยาวเพื่อให้เบาหวาน<strong
                                >สงบอย่างยั่งยืน</strong
                            > — ไม่กลับมาอีก
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ═══ SECTION 6: SOCIAL PROOF ═══ -->
    <section class="proof-section">
        <div class="section-inner">
            <span class="section-badge">พิสูจน์แล้วจากคนจริง</span>
            <h2 class="proof-title">คนเหล่านี้เลิกยาได้แล้ว — คุณก็ทำได้</h2>
            <div class="proof-grid">
                <div class="proof-card">
                    <div class="proof-stars">★★★★★</div>
                    <blockquote>
                        "กินยา 3 ตัวมา 5 ปี หลัง VIP Coaching <strong
                            >หยุดยาได้หมด</strong
                        > HbA1c จาก 8.2 เหลือ 5.7 หมอทิมเปลี่ยนชีวิตผมจริงๆ"
                    </blockquote>
                    <div class="proof-author">
                        <div class="proof-avatar">ป</div>
                        <div>
                            <strong>คุณประสิทธิ์</strong><span
                                >อายุ 58 ปี · กรุงเทพฯ · เบาหวานชนิดที่ 2</span
                            >
                        </div>
                    </div>
                </div>
                <div class="proof-card">
                    <div class="proof-stars">★★★★★</div>
                    <blockquote>
                        "แค่สัปดาห์ที่ 3 กราฟน้ำตาลเริ่มนิ่ง <strong
                            >ลดยาได้ 2 ตัวใน 8 สัปดาห์</strong
                        > ไม่เคยคิดว่าจะเลิกยาได้จริงค่ะ"
                    </blockquote>
                    <div class="proof-author">
                        <div class="proof-avatar">อ</div>
                        <div>
                            <strong>คุณอรวรรณ</strong><span
                                >อายุ 49 ปี · เชียงใหม่ · เบาหวาน + ดื้ออินซูลิน</span
                            >
                        </div>
                    </div>
                </div>
                <div class="proof-card">
                    <div class="proof-stars">★★★★★</div>
                    <blockquote>
                        "มี LINE ถึงหมอทิมโดยตรง ถามได้ทุกเรื่อง <strong
                            >ลด 12 กก. ใน 12 สัปดาห์</strong
                        > น้ำตาลปกติ ไม่ต้องกินยาอีกเลย"
                    </blockquote>
                    <div class="proof-author">
                        <div class="proof-avatar">ส</div>
                        <div>
                            <strong>คุณสมชาย</strong><span
                                >อายุ 55 ปี · ชลบุรี · Prediabetes + อ้วนลงพุง</span
                            >
                        </div>
                    </div>
                </div>
            </div>
