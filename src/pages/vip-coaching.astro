        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }
    .benefit-icon {
        font-size: 28px;
    }
    .benefit-card h3 {
        font-size: 18px;
        font-weight: 700;
        color: white;
        margin-bottom: 10px;
    }
    .benefit-card p {
        font-size: 15px;
        line-height: 1.6;
        color: var(--cgm-text-muted);
    }
