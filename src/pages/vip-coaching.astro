    .compare-section {
        background: var(--cgm-surface);
        border-top: 1px solid var(--cgm-border);
    }
    .compare-title {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 800;
        color: white;
        text-align: center;
        margin-bottom: 48px;
